local ESP_OBJECTS = {}

local function setupESP(player)
    if not Drawing or player == LocalPlayer then return end
    local skeletonLines = {}
    for i = 1, #SKELETON_CONNECTIONS do
        skeletonLines[i] = newDrawing("Line", { Thickness = 1, Color = Color3.new(1,1,1), Transparency = 1 })
    end
    local cornerLines = {}
    for i = 1, 8 do
        cornerLines[i] = newDrawing("Line", { Thickness = 1.5, Color = Color3.fromRGB(240,240,240) })
    end
    ESP_OBJECTS[player] = {
        Box        = newDrawing("Square", { Color = Color3.fromRGB(240,240,240), Thickness = 1, Filled = false }),
        BoxFill    = newDrawing("Square", { Color = Color3.fromRGB(240,240,240), Thickness = 0, Filled = true, Transparency = 0.7, Visible = false }),
        CornerLines= cornerLines,
        Tracer     = newDrawing("Line",   { Color = Color3.fromRGB(200,200,200), Thickness = 1 }),
        Name       = newDrawing("Text",   { Color = Color3.new(1,1,1), Size = 13, Center = true, Outline = true }),
        DistText   = newDrawing("Text",   { Color = Color3.fromRGB(200,200,200), Size = 12, Center = true, Outline = true }),
        LevelText  = newDrawing("Text",   { Color = Color3.fromRGB(200,200,200), Size = 12, Center = true, Outline = true }),
        WinText    = newDrawing("Text",   { Color = Color3.fromRGB(200,200,200), Size = 12, Center = true, Outline = true }),
        HealthBG   = newDrawing("Line",   { Thickness = 4, Color = Color3.fromRGB(15,15,15) }),
        HealthSegs = (function()
            local segs = {}
            for i = 1, 20 do
                local t = (i - 1) / 19
                segs[i] = newDrawing("Line", { Thickness = 3, Color = Color3.fromRGB(math.floor(255*t), math.floor(255*(1-t)), 0) })
            end
            return segs
        end)(),
        Skeleton   = skeletonLines,
    }
end

local function hideAll(obj)
    obj.Box.Visible      = false; obj.BoxFill.Visible   = false
    obj.Tracer.Visible   = false; obj.Name.Visible      = false
    obj.DistText.Visible = false; obj.LevelText.Visible = false
    obj.WinText.Visible  = false; obj.HealthBG.Visible  = false
    for _, ln in ipairs(obj.CornerLines) do ln.Visible = false end
    for _, ln in ipairs(obj.HealthSegs)  do ln.Visible = false end
    for _, ln in ipairs(obj.Skeleton)    do ln.Visible = false end
end

local function removeESP(player)
    local obj = ESP_OBJECTS[player]
    if not obj then return end
    for _, v in pairs(obj) do
        if type(v) == "table" then
            for _, ln in ipairs(v) do pcall(function() ln:Remove() end) end
        else
            pcall(function() v:Remove() end)
        end
    end
    ESP_OBJECTS[player] = nil
end

local function updateESP(player)
    local obj = ESP_OBJECTS[player]
    if not obj then return end

    local char = player.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local active = STATE.ESP and STATE.Master and isEnemy(player)
        and hrp and hum and hum.Health > 0

    if not active then hideAll(obj); return end

    local hrpPos, onScreen, depth = worldToScreen(hrp.Position)
    local dist = getDistance(player)

    if not onScreen or depth <= 0 or dist > STATE.ESPMaxDistance then hideAll(obj); return end

    local topScreen  = worldToScreen(hrp.Position + Vector3.new(0, 3.1, 0))
    local footScreen = worldToScreen(hrp.Position - Vector3.new(0, 3.0, 0))
    local height     = math.max(math.abs(footScreen.Y - topScreen.Y), 2)
    local width      = height * 0.55
    local espClr     = visualColor(STATE.ESPColorR, STATE.ESPColorG, STATE.ESPColorB)
    local centerX    = hrpPos.X
    local left       = centerX - width/2
    local right      = centerX + width/2
    local top        = topScreen.Y
    local bot        = footScreen.Y

    local style      = STATE.ESPBoxStyle
    local showFull   = style == "Full Box"
    local showCorner = style == "Corner Box"
    local espFont    = Drawing.Fonts[STATE.ESPFont] or Drawing.Fonts.UI
    local espSize    = STATE.ESPTextSize

    obj.Box.Visible = showFull
    if showFull then
        obj.Box.Size     = Vector2.new(width, height)
        obj.Box.Position = Vector2.new(left, top)
        obj.Box.Color    = espClr
    end

    obj.BoxFill.Visible = showFull and STATE.ESPBoxFill
    if obj.BoxFill.Visible then
        obj.BoxFill.Size     = Vector2.new(width, height)
        obj.BoxFill.Position = Vector2.new(left, top)
        obj.BoxFill.Color    = espClr
    end

    -- corner box: 8 lines (4 corners × horizontal + vertical arm), length = 25% of dimension
    local cx = width  * 0.25
    local cy = height * 0.25
    local corners = {
        { Vector2.new(left,  top), Vector2.new(left + cx, top),  Vector2.new(left,  top + cy)  },
        { Vector2.new(right, top), Vector2.new(right - cx, top), Vector2.new(right, top + cy)  },
        { Vector2.new(left,  bot), Vector2.new(left + cx, bot),  Vector2.new(left,  bot - cy)  },
        { Vector2.new(right, bot), Vector2.new(right - cx, bot), Vector2.new(right, bot - cy)  },
    }
    local li = 1
    for _, c in ipairs(corners) do
        obj.CornerLines[li].From    = c[1]; obj.CornerLines[li].To    = c[2]
        obj.CornerLines[li].Color   = espClr; obj.CornerLines[li].Visible = showCorner
        obj.CornerLines[li+1].From  = c[1]; obj.CornerLines[li+1].To  = c[3]
        obj.CornerLines[li+1].Color = espClr; obj.CornerLines[li+1].Visible = showCorner
        li = li + 2
    end

    obj.Tracer.Visible = STATE.ESPTracer
    if STATE.ESPTracer then
        obj.Tracer.From  = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
        obj.Tracer.To    = Vector2.new(centerX, bot)
        obj.Tracer.Color = espClr
    end

    local nameOffset = espSize + 2
    obj.Name.Visible = STATE.ESPName
    if STATE.ESPName then
        obj.Name.Text     = STATE.StreamingMode and STATE.StreamingAlias or player.DisplayName
        obj.Name.Size     = espSize
        obj.Name.Font     = espFont
        obj.Name.Position = Vector2.new(centerX, top - nameOffset)
        obj.Name.Color    = espClr
    end

    -- below-box text stack: distance, level, win streak
    local belowOffset = 3
    local smallSize   = math.max(espSize - 1, 8)
    obj.DistText.Visible = STATE.ESPDistance
    if STATE.ESPDistance then
        obj.DistText.Text     = math.floor(dist) .. "m"
        obj.DistText.Size     = smallSize
        obj.DistText.Font     = espFont
        obj.DistText.Position = Vector2.new(centerX, bot + belowOffset)
        obj.DistText.Color    = espClr
        belowOffset = belowOffset + smallSize + 2
    end

    local cls = player:FindFirstChild("CustomLeaderstats")
    obj.LevelText.Visible = STATE.ESPLevel
    if STATE.ESPLevel then
        local lvlVal = cls and cls:FindFirstChild("Level")
        obj.LevelText.Text     = "Lv " .. (lvlVal and lvlVal.Value or "?")
        obj.LevelText.Size     = smallSize
        obj.LevelText.Font     = espFont
        obj.LevelText.Position = Vector2.new(centerX, bot + belowOffset)
        obj.LevelText.Color    = espClr
        belowOffset = belowOffset + smallSize + 2
    end

    obj.WinText.Visible = STATE.ESPWinStreak
    if STATE.ESPWinStreak then
        local wsVal = cls and cls:FindFirstChild("Win Streak")
        obj.WinText.Text     = "W " .. (wsVal and wsVal.Value or "?")
        obj.WinText.Size     = smallSize
        obj.WinText.Font     = espFont
        obj.WinText.Position = Vector2.new(centerX, bot + belowOffset)
        obj.WinText.Color    = espClr
    end

    -- health bar: 20-segment gradient, top=green (index 1) to bottom=red (index 20)
    -- segments cover the entire bar height; only filled portion (top health%) is shown
    if STATE.ESPHealthBar then
        local ratio   = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        local barX    = left - 6
        local segH    = height / 20
        local filledY = bot - height * ratio  -- screen Y where fill starts (above = unfilled)
        obj.HealthBG.From    = Vector2.new(barX, top)
        obj.HealthBG.To      = Vector2.new(barX, bot)
        obj.HealthBG.Visible = true
        for i, seg in ipairs(obj.HealthSegs) do
            local segTop = top + (i - 1) * segH
            local segBot = segTop + segH
            if segBot >= filledY then
                seg.From    = Vector2.new(barX, math.max(segTop, filledY))
                seg.To      = Vector2.new(barX, segBot)
                seg.Visible = true
            else
                seg.Visible = false
            end
        end
    else
        obj.HealthBG.Visible = false
        for _, seg in ipairs(obj.HealthSegs) do seg.Visible = false end
    end

    if STATE.ESPSkeleton then
        for i, conn in ipairs(SKELETON_CONNECTIONS) do
            local p1 = char:FindFirstChild(conn[1])
            local p2 = char:FindFirstChild(conn[2])
            local ln = obj.Skeleton[i]
            if p1 and p2 then
                local s1, on1 = worldToScreen(p1.Position)
                local s2, on2 = worldToScreen(p2.Position)
                ln.Visible = on1 or on2
                if ln.Visible then ln.From = s1; ln.To = s2; ln.Color = espClr end
            else
                ln.Visible = false
            end
        end
    else
        for _, ln in ipairs(obj.Skeleton) do ln.Visible = false end
    end
end

