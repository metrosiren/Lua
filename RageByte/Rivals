-- ANTICHEAT BYPASS
-----------------------------------
do
    local _acApplied = false
    local _acDescConn = nil
    local _prevACBypass = STATE.AntiCheatBypass

    -- Install setmetatable hook once; intercepts only while STATE.AntiCheatBypass is on
    pcall(function()
        local _orig
        _orig = hookfunction(getrenv().setmetatable, newcclosure(function(tbl, mt)
            if STATE.AntiCheatBypass and mt and typeof(mt) == "table" and rawget(mt, "__mode") == "kv" then
                local tr = debug.traceback()
                if tr:find("MiscellaneousController") then
                    return _orig({1, 2, 3}, {})
                end
            end
            return _orig(tbl, mt)
        end))
    end)

    RunService.Stepped:Connect(function()
        -- One-shot: run bypass ops the first time the toggle is enabled
        if STATE.AntiCheatBypass and not _acApplied then
            _acApplied = true
            task.spawn(function()
                -- Disable scripts with AC-related names
                pcall(function()
                    local tags = { "anticheat", "ac", "detection", "ban", "kick", "security", "moderation" }
                    local function proc(o)
                        pcall(function()
                            if not (o:IsA("LocalScript") or o:IsA("ModuleScript")) then return end
                            local ok, nm = pcall(function() return o.Name:lower() end)
                            if not ok then return end
                            for _, t in ipairs(tags) do
                                if nm:find(t) then pcall(function() o.Disabled = true end) break end
                            end
                        end)
                    end
                    for _, o in ipairs(game:GetDescendants()) do proc(o) end
                    _acDescConn = game.DescendantAdded:Connect(proc)
                end)
                -- Decoy remote to absorb kick events
                pcall(function()
                    local ev = Instance.new("RemoteEvent")
                    ev.Name = "ClientAlert"
                    ev.Parent = LocalPlayer
                end)
                -- Patch ban/kick functions found in the GC
                pcall(function()
                    local rf  = game:GetService("ReplicatedFirst")
                    local tgt = rf:WaitForChild("LocalScript3", 10)
                    for _, fn in ipairs(getgc(false)) do
                        if type(fn) ~= "function" then continue end
                        local ok1, env = pcall(getfenv, fn)
                        if not ok1 or type(env) ~= "table" then continue end
                        local ok2, scr = pcall(function() return rawget(env, "script") end)
                        if not ok2 or not scr or typeof(scr) ~= "Instance" then continue end
                        local ok3, ss = pcall(tostring, scr)
                        if not ok3 then continue end
                        if not (scr == tgt or (type(ss) == "string" and ss:find("LoadingScreen"))) then continue end
                        local ok4, consts = pcall(debug.getconstants, fn)
                        if not ok4 or type(consts) ~= "table" then continue end
                        for _, c in ipairs(consts) do
                            if type(c) == "string" and (c:find("TakeTheL") or c:find("ban") or c:find("kick")) then
                                pcall(hookfunction, fn, function() end)
                                break
                            end
                        end
                    end
                end)
            end)
        end
        -- Toggle-off: stop watching for new AC scripts
        if STATE.AntiCheatBypass ~= _prevACBypass then
            _prevACBypass = STATE.AntiCheatBypass
            if not STATE.AntiCheatBypass and _acDescConn then
                _acDescConn:Disconnect()
                _acDescConn = nil
            end
        end
    end)
end

