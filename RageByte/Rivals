local dragging, dragInput, dragStart, startPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = uiMain.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        uiMain.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local function sendNotification(title, text, duration)
    local notifArea = screenGui:FindFirstChild("NotifArea")
    if not notifArea then
        notifArea = Instance.new("Frame", screenGui)
        notifArea.Name = "NotifArea"
        notifArea.Size = UDim2.new(0, 260, 1, -40)
        notifArea.Position = UDim2.new(1, -280, 0, 20)
        notifArea.BackgroundTransparency = 1
        
        local notifLayout = Instance.new("UIListLayout", notifArea)
        notifLayout.SortOrder = Enum.SortOrder.LayoutOrder
        notifLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
        notifLayout.Padding = UDim.new(0, 10)
    end

    local notif = Instance.new("Frame", notifArea)
    notif.Size = UDim2.new(1, 0, 0, 65)
    notif.BackgroundColor3 = UI_SECTION
    notif.BorderSizePixel = 0
    notif.BackgroundTransparency = 1
    
    local stroke = Instance.new("UIStroke", notif)
    stroke.Color = UI_STROKE
    stroke.Thickness = 1
    stroke.Transparency = 1
    
    local accent = Instance.new("Frame", notif)
    accent.Size = UDim2.new(0, 3, 1, 0)
    accent.BackgroundColor3 = UI_ACCENT
    accent.BorderSizePixel = 0
    accent.BackgroundTransparency = 1
    
    local titleLbl = Instance.new("TextLabel", notif)
    titleLbl.Size = UDim2.new(1, -30, 0, 20)
    titleLbl.Position = UDim2.new(0, 15, 0, 10)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = UI_ACCENT
    titleLbl.Font = FONT_BOLD
    titleLbl.TextSize = 14
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextTransparency = 1
    
    local textLbl = Instance.new("TextLabel", notif)
    textLbl.Size = UDim2.new(1, -30, 0, 25)
    textLbl.Position = UDim2.new(0, 15, 0, 30)
    textLbl.BackgroundTransparency = 1
    textLbl.Text = text
    textLbl.TextColor3 = UI_TEXT
    textLbl.Font = FONT_REG
    textLbl.TextSize = 13
    textLbl.TextWrapped = true
    textLbl.TextXAlignment = Enum.TextXAlignment.Left
    textLbl.TextTransparency = 1
    
    TweenService:Create(notif, TWEEN_INFO, {BackgroundTransparency = 0}):Play()
    TweenService:Create(stroke, TWEEN_INFO, {Transparency = 0}):Play()
    TweenService:Create(accent, TWEEN_INFO, {BackgroundTransparency = 0}):Play()
    TweenService:Create(titleLbl, TWEEN_INFO, {TextTransparency = 0}):Play()
    TweenService:Create(textLbl, TWEEN_INFO, {TextTransparency = 0}):Play()
    
    task.delay(duration or 5, function()
        local tw = TweenService:Create(notif, TWEEN_INFO, {BackgroundTransparency = 1})
        TweenService:Create(stroke, TWEEN_INFO, {Transparency = 1}):Play()
        TweenService:Create(accent, TWEEN_INFO, {BackgroundTransparency = 1}):Play()
        TweenService:Create(titleLbl, TWEEN_INFO, {TextTransparency = 1}):Play()
        TweenService:Create(textLbl, TWEEN_INFO, {TextTransparency = 1}):Play()
        tw:Play()
        tw.Completed:Wait()
        notif:Destroy()
    end)
end

