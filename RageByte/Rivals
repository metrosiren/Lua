local _spinCXLines = {}
local _spinCXAngle = 0
local _spinCXReady = false
local _spinCXSpeed = 120  -- degrees per second

local function setupSpinCrosshair()
    if _spinCXReady then return end
    _spinCXReady = true
    if not Drawing then return end
    -- 4 radiating arms
    for i = 1, 4 do
        local ln = Drawing.new("Line")
        ln.Thickness = 2
        ln.Color = Color3.new(1, 1, 1)
        ln.Transparency = 1
        ln.Visible = false
        _spinCXLines[i] = ln
    end
    -- Center dot
    local dot = Drawing.new("Circle")
    dot.Radius = 2
    dot.Filled = true
    dot.NumSides = 8
    dot.Thickness = 1
    dot.Color = Color3.new(1, 1, 1)
    dot.Transparency = 1
    dot.Visible = false
    _spinCXLines[5] = dot
end

local function teardownSpinCrosshair()
    _spinCXReady = false
    for i = 1, 5 do
        if _spinCXLines[i] then
            pcall(function() _spinCXLines[i]:Remove() end)
            _spinCXLines[i] = nil
        end
    end
end

RunService.RenderStepped:Connect(function(dt)
    if STATE.SpinCrosshair and STATE.Master then
        if not _spinCXReady then setupSpinCrosshair() end
        _spinCXAngle = (_spinCXAngle + _spinCXSpeed * dt) % 360
        local cx    = Camera.ViewportSize.X / 2
        local cy    = Camera.ViewportSize.Y / 2
        local inner = 6
        local outer = 20
        local color = STATE.RainbowVisuals and getRainbow(0.5) or Color3.new(1, 1, 1)
        for i = 1, 4 do
            local angle = math.rad(_spinCXAngle + (i - 1) * 90)
            local ln = _spinCXLines[i]
            if ln then
                ln.From    = Vector2.new(cx + math.cos(angle) * inner, cy + math.sin(angle) * inner)
                ln.To      = Vector2.new(cx + math.cos(angle) * outer, cy + math.sin(angle) * outer)
                ln.Color   = color
                ln.Visible = true
            end
        end
        if _spinCXLines[5] then
            _spinCXLines[5].Position = Vector2.new(cx, cy)
            _spinCXLines[5].Color    = color
            _spinCXLines[5].Visible  = true
        end
    elseif _spinCXReady then
        teardownSpinCrosshair()
    end
end)

