local CHAMS_OBJECTS = {}

local function applyChams(player, char)
    task.defer(function()
        if not char or not char.Parent then return end
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Highlight") and v.Name == "_RR_Chams" then pcall(function() v:Destroy() end) end
        end
        local hl = Instance.new("Highlight")
        hl.Name = "_RR_Chams"
        hl.FillColor = Color3.fromRGB(STATE.ChamsR, STATE.ChamsG, STATE.ChamsB)
        hl.OutlineTransparency = 1; hl.FillTransparency = 0.5
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Enabled = STATE.ChamsESP and STATE.Master
        hl.Parent = char
        if CHAMS_OBJECTS[player] then CHAMS_OBJECTS[player].hl = hl end
    end)
end

local function setupChams(player)
    if player == LocalPlayer then return end
    local old = CHAMS_OBJECTS[player]
    if old and old.conn then pcall(function() old.conn:Disconnect() end) end
    CHAMS_OBJECTS[player] = {}
    if player.Character then applyChams(player, player.Character) end
    CHAMS_OBJECTS[player].conn = player.CharacterAdded:Connect(function(char)
        applyChams(player, char)
    end)
end

local function cleanupChams(player)
    local data = CHAMS_OBJECTS[player]
    if not data then return end
    pcall(function()
        if data.conn then data.conn:Disconnect() end
        if data.hl and data.hl.Parent then data.hl:Destroy() end
    end)
    CHAMS_OBJECTS[player] = nil
end

