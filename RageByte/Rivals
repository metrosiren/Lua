    function _ds:__find()
        local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        local closest, closestDist = nil, math.huge
        local lChar = LocalPlayer.Character
        local lRoot = lChar and lChar:FindFirstChild("HumanoidRootPart")
        for _, player in next, Players:GetPlayers() do
            if player == LocalPlayer then continue end
            if STATE.TeamCheck and player:GetAttribute("TeamID") == LocalPlayer:GetAttribute("TeamID") then continue end
            local char = player.Character; if not char then continue end
            local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            local hum  = char:FindFirstChildWhichIsA("Humanoid")
            if not (head and hum and hum.Health > 0) then continue end
            if lRoot then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root and (root.Position - lRoot.Position).Magnitude > 300 then continue end
            end
            local screenPos, _, depth = worldToScreen(head.Position)
            if depth <= 0 then continue end
            local dist = (screenPos - center).Magnitude
            if dist < closestDist then closestDist = dist; closest = player end
        end
        return closest
    end

    function _ds:__desync_start(target)
        if not target or not target.Character then return end
        local tHum = target.Character:FindFirstChild("Humanoid")
        if not tHum or tHum.Health <= 0 then return end
        if self.__conn2 then self.__conn2:Disconnect() end
        self.__desync = true; self.__curr = target
        self.__conn2 = RunService.Heartbeat:Connect(function()
            if not self.__desync then return end
            if not self.__curr or not self.__curr.Character then self:__desync_stop(); return end
            local tHumCheck = self.__curr.Character:FindFirstChild("Humanoid")
            if not tHumCheck or tHumCheck.Health <= 0 then self:__desync_stop(); return end
            local rootPart = _dsRoot.__root; if not rootPart then return end
            local tgtRoot  = self.__curr.Character:FindFirstChild("HumanoidRootPart")
            if not tgtRoot then self:__desync_stop(); return end
            local savedCF, savedVel, savedRot = rootPart.CFrame, rootPart.Velocity, rootPart.RotVelocity
            rootPart.CFrame = tgtRoot.CFrame * CFrame.new(0,-5,0)
            RunService:BindToRenderStep("__RR_restore", 101, function()
                if rootPart and rootPart.Parent then
                    rootPart.CFrame = savedCF; rootPart.Velocity = savedVel; rootPart.RotVelocity = savedRot
                end
                RunService:UnbindFromRenderStep("__RR_restore")
            end)
        end)
    end

    function _ds:__desync_stop()
        self.__desync = false
        pcall(function() RunService:UnbindFromRenderStep("__RR_restore") end)
        if self.__conn2 then self.__conn2:Disconnect(); self.__conn2 = nil end
        self.__curr = nil
    end

    function _ds:__startHeartbeat()
        if self.__conn1 then self.__conn1:Disconnect() end
        self.__conn1 = RunService.Heartbeat:Connect(function()
            if not self.__active then return end
            local newTarget = self:__find()
            if self.__desync and self.__target then
                local alive = self.__target.Character
                    and self.__target.Character:FindFirstChild("Humanoid")
                    and self.__target.Character.Humanoid.Health > 0
                if not alive then self:__desync_stop(); self.__target = nil end
            end
            if not self.__desync then self.__target = newTarget end
        end)
    end

    function _ds:enable()
        if self.__active then return end
        self.__active = true; self:__startHeartbeat()
    end

    function _ds:disable()
        self.__active = false; self:__desync_stop()
        pcall(function() RunService:UnbindFromRenderStep("__RR_restore") end)
        if self.__conn1 then self.__conn1:Disconnect(); self.__conn1 = nil end
        if self.__task1 then task.cancel(self.__task1); self.__task1 = nil end
        self.__target = nil
    end

    function _ds:shoot(packetArgs, tgt)
        local head = tgt.Character and tgt.Character:FindFirstChild("Head"); if not head then return end
        local tHum = tgt.Character:FindFirstChild("Humanoid")
        if not tHum or tHum.Health <= 0 then self:__desync_stop(); return end
        if not self.__desync or self.__curr ~= tgt then self:__desync_start(tgt); task.wait(0.1) end
        if self.__task1 then task.cancel(self.__task1); self.__task1 = nil end
        if not tgt.Character then self:__desync_stop(); return end
        tHum = tgt.Character:FindFirstChild("Humanoid")
        if not tHum or tHum.Health <= 0 then self:__desync_stop(); return end
        head = tgt.Character:FindFirstChild("Head"); if not head then return end
        local targetPos    = head.Position
        local targetCFrame = head.CFrame
        local shotOrigin   = targetPos - Vector3.new(0,5,0)
        local lookDir      = CFrame.lookAt(shotOrigin, targetPos)
        local noise        = Vector3.new(math.random(), math.random(), math.random())
        local localHitCF   = targetCFrame:ToObjectSpace(CFrame.new(targetPos + noise))
        local encode       = type(UtilityModule) == "table" and UtilityModule.EncodeCFrame
        packetArgs[utf8.char(0)] = encode and UtilityModule:EncodeCFrame(CFrame.new(shotOrigin, targetPos) * CFrame.Angles(lookDir:ToOrientation())) or CFrame.new(shotOrigin, targetPos)
        packetArgs[utf8.char(1)] = encode and UtilityModule:EncodeCFrame(CFrame.new(targetPos) * CFrame.Angles(lookDir:ToOrientation())) or CFrame.new(targetPos)
        packetArgs[utf8.char(2)] = head
        packetArgs[utf8.char(3)] = encode and UtilityModule:EncodeCFrame(localHitCF) or localHitCF
        self.__task1 = task.delay(0.15, function() self:__desync_stop() end)
    end
end

customEnv.SilentAim.Shutdown = function(self)
    self.Active = false; _ds:disable()
    if self.Connection1 then self.Connection1:Disconnect(); self.Connection1 = nil end
    if self.OriginalShoot and type(GunModule) == "table" then GunModule.StartShooting = self.OriginalShoot end
end

customEnv.SilentAim.Connection1 = RunService.Heartbeat:Connect(function()
    if STATE.SilentAim and STATE.Master then
        if STATE.SilentAimMode == "Desync" then
            _ds:enable()
            customEnv.SilentAim.Target = _ds.__target
        else
            _ds:disable()
            customEnv.SilentAim.Target = getSilentAimTarget()
        end
    else
        _ds:disable()
        customEnv.SilentAim.Target = nil
    end
end)

task.delay(0.5, function()
    do local ok, m = pcall(function() return require(LocalPlayer.PlayerScripts.Modules.ItemTypes.Gun) end)
        if ok and type(m) == "table" then GunModule = m end end
    task.wait()
    do local ok, m = pcall(function() return require(ReplicatedStorage.Modules.Utility) end)
        if ok and type(m) == "table" then UtilityModule = m end end
    if not (type(GunModule) == "table" and GunModule.StartShooting) then return end
    customEnv.SilentAim.OriginalShoot = GunModule.StartShooting
    GunModule.StartShooting = function(self, ...)
        local args = { customEnv.SilentAim.OriginalShoot(self, ...) }
        if not self.ClientFighter or not self.ClientFighter.IsLocalPlayer
            or type(args[3]) ~= "table" or not STATE.SilentAim or not STATE.Master
            or not customEnv.SilentAim.Target or not customEnv.SilentAim.Target.Character
            or math.random(100) > STATE.SilentAimHitChance then
            return unpack(args)
        end
        args[4] = true
        local tgt  = customEnv.SilentAim.Target
        local head = tgt.Character:FindFirstChild("Head")
        if not head then return unpack(args) end
        local targetPos    = head.Position
        local targetCFrame = head.CFrame
        local encode       = type(UtilityModule) == "table" and UtilityModule.EncodeCFrame
        if STATE.SilentAimMode == "Desync" then
            local tHum = tgt.Character:FindFirstChild("Humanoid")
            if not tHum or tHum.Health <= 0 then _ds:__desync_stop(); return unpack(args) end
            _ds:shoot(args[3], tgt)
        else
            local myChar     = LocalPlayer.Character
            local myRoot     = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local shotOrigin = myRoot and myRoot.Position or (targetPos - Vector3.new(0,5,0))
            local lookDir    = CFrame.lookAt(shotOrigin, targetPos)
            local rx, ry, rz = lookDir:ToOrientation()
            local originCF   = CFrame.new(shotOrigin, targetPos) * CFrame.Angles(rx, ry, rz)
            local impactCF   = CFrame.new(targetPos)             * CFrame.Angles(rx, ry, rz)
            local noise      = Vector3.new(math.random(), math.random(), math.random())
            local localHitCF = targetCFrame:ToObjectSpace(CFrame.new(targetPos + noise))
            args[3][utf8.char(0)] = encode and UtilityModule:EncodeCFrame(originCF)   or originCF
            args[3][utf8.char(1)] = encode and UtilityModule:EncodeCFrame(impactCF)   or impactCF
            args[3][utf8.char(2)] = head
            args[3][utf8.char(3)] = encode and UtilityModule:EncodeCFrame(localHitCF) or localHitCF
        end
        return unpack(args)
    end
end)

-- ─── Unlock Skins ────────────────────────────────────────────────────────────

do
    local _skinHooked = false
    RunService.Stepped:Connect(function()
        if not STATE.UnlockSkins or _skinHooked then return end
        _skinHooked = true
        task.spawn(function()
            local ctrl = LocalPlayer.PlayerScripts.Controllers
            local mods = ReplicatedStorage:WaitForChild("Modules", 10)
            if not mods then return end
            local enumLib, cosLib, datCtrl
            pcall(function() enumLib = require(mods:WaitForChild("EnumLibrary", 10)) end); task.wait()
            pcall(function() cosLib  = require(mods:WaitForChild("CosmeticLibrary", 10)) end); task.wait()
            pcall(function() datCtrl = require(ctrl:WaitForChild("PlayerDataController", 10)) end); task.wait()
            if not cosLib or not datCtrl then return end

            local eq, favs = {}, {}
            local buildingWep = nil
            local cosTypes = { "Skin","Wrap","Charm","Dance","Emote" }
            local function isCosType(c)
                if not c then return false end
                for _, t in ipairs(cosTypes) do if c.Type == t then return true end end
                return false
            end
            local function mkCosmetic(nm, ctype, opts)
                local base = cosLib.Cosmetics[nm]; if not base then return nil end
                local d = {}; for k, v in pairs(base) do d[k] = v end
                d.Name = nm; d.Type = d.Type or ctype; d.Seed = d.Seed or math.random(1, 1000000)
                if enumLib then
                    local s, eid = pcall(function() return enumLib:ToEnum(nm) end)
                    if s and eid then d.Enum = eid; d.ObjectID = d.ObjectID or eid end
                end
                if opts then
                    if opts.inverted ~= nil then d.Inverted = opts.inverted end
                    if opts.favoritesOnly ~= nil then d.OnlyUseFavorites = opts.favoritesOnly end
                end
                return d
            end
            local cfgFile = "rivals_unlocker_config.json"
            local saveLock = false
            pcall(function()
                if not (isfile and readfile) or not isfile(cfgFile) then return end
                local ok, raw = pcall(readfile, cfgFile); if not ok or raw == "" then return end
                local ok2, dec = pcall(function() return HttpService:JSONDecode(raw) end)
                if not ok2 or not dec then return end
                if dec.favorites then favs = dec.favorites end
                if dec.equipped then
                    for wn, cos in pairs(dec.equipped) do
                        eq[wn] = {}
                        for ct, sd in pairs(cos) do
                            if sd and sd.Name and cosLib.Cosmetics[sd.Name] then
                                local cl = mkCosmetic(sd.Name, ct, { inverted = sd.Inverted, favoritesOnly = sd.OnlyUseFavorites })
                                if cl then eq[wn][ct] = cl end
                            end
                        end
                        if not next(eq[wn]) then eq[wn] = nil end
                    end
                end
            end)
            local function saveCfg()
                if not writefile or saveLock then return end
                saveLock = true
                task.spawn(function()
                    task.wait(1)
                    local out = {}
                    for wn, cos in pairs(eq) do
                        out[wn] = {}
                        for ct, cd in pairs(cos) do
                            if cd and cd.Name then
                                out[wn][ct] = { Name = cd.Name, Inverted = cd.Inverted, OnlyUseFavorites = cd.OnlyUseFavorites }
                            end
                        end
                    end
                    local ok, enc = pcall(function() return HttpService:JSONEncode({ equipped = out, favorites = favs }) end)
                    if ok then pcall(writefile, cfgFile, enc) end
                    saveLock = false
                end)
            end
            local origOwns = cosLib.OwnsCosmetic
            cosLib.OwnsCosmeticNormally = function(_, _, nm)
                local c = cosLib.Cosmetics[nm]; return STATE.UnlockSkins and c ~= nil and c.Type == "Skin" or false
            end
            cosLib.OwnsCosmeticUniversally = cosLib.OwnsCosmeticNormally
            cosLib.OwnsCosmeticForWeapon   = cosLib.OwnsCosmeticNormally
            cosLib.OwnsCosmetic = function(self, inv, nm, wep)
                if not STATE.UnlockSkins then return origOwns(self, inv, nm, wep) end
                if nm:find("MISSING_") or nm == "Bubble Gun" then return origOwns(self, inv, nm, wep) end
                local c = cosLib.Cosmetics[nm]
                return (c and isCosType(c)) or origOwns(self, inv, nm, wep)
            end
            local origGet = datCtrl.Get
            datCtrl.Get = function(self, key)
                local val = origGet(self, key)
                if not STATE.UnlockSkins then return val end
                if key == "CosmeticInventory" then
                    local prx = {}
                    if val then for k, v in pairs(val) do local c = cosLib.Cosmetics[k]; if c and isCosType(c) then prx[k] = v end end end
                    return setmetatable(prx, { __index = function(_, k)
                        local c = cosLib.Cosmetics[k]; return (c and isCosType(c)) and true or nil
                    end })
                end
                if key == "FavoritedCosmetics" then
                    local res = val and table.clone(val) or {}
                    for wn2, fv in pairs(favs) do
                        res[wn2] = res[wn2] or {}
                        for nm2, isFav in pairs(fv) do
                            local c = cosLib.Cosmetics[nm2]; if c and isCosType(c) then res[wn2][nm2] = isFav end
                        end
                    end
                    return res
                end
                return val
            end
            local origGetWep = datCtrl.GetWeaponData
            datCtrl.GetWeaponData = function(self, wn)
                local d = origGetWep(self, wn); if not d or not STATE.UnlockSkins then return d end
                local m = {}; for k, v in pairs(d) do m[k] = v end; m.Name = wn
                if eq[wn] then for ct, cd in pairs(eq[wn]) do m[ct] = cd end end
                return m
            end
            if hookmetamethod then
                local remotes  = ReplicatedStorage:FindFirstChild("Remotes")
                local dataRem  = remotes and remotes:FindFirstChild("Data")
                local equipRem = dataRem and dataRem:FindFirstChild("EquipCosmetic")
                local favRem   = dataRem and dataRem:FindFirstChild("FavoriteCosmetic")
                if equipRem then
                    local onc
                    onc = hookmetamethod(game, "__namecall", function(self, ...)
                        if getnamecallmethod() ~= "FireServer" then return onc(self, ...) end
                        if not STATE.UnlockSkins then return onc(self, ...) end
                        local a = { ... }
                        if self == equipRem then
                            local wn, ct, cn, opts = a[1], a[2], a[3], a[4] or {}
                            if cn and cn ~= "None" and cn ~= "" then
                                local inv = datCtrl:Get("CosmeticInventory")
                                if inv and rawget(inv, cn) then return onc(self, ...) end
                            end
                            eq[wn] = eq[wn] or {}
                            if not cn or cn == "None" or cn == "" then
                                eq[wn][ct] = nil; if not next(eq[wn]) then eq[wn] = nil end
                            else
                                local cl = mkCosmetic(cn, ct, { inverted = opts.IsInverted, favoritesOnly = opts.OnlyUseFavorites })
                                if cl then eq[wn][ct] = cl end
                            end
                            task.defer(function() pcall(function() datCtrl.CurrentData:Replicate("WeaponInventory") end) end)
                            saveCfg(); return
                        end
                        if self == favRem then
                            local cos = cosLib.Cosmetics[a[2]]
                            if cos then
                                favs[a[1]] = favs[a[1]] or {}; favs[a[1]][a[2]] = a[3] or nil
                                task.spawn(function() pcall(function() datCtrl.CurrentData:Replicate("FavoritedCosmetics") end) end)
                                saveCfg()
                            end
                            return
                        end
                        return onc(self, ...)
                    end)
                end
            end
            local cliItem
            task.wait()
            pcall(function() cliItem = require(LocalPlayer.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem) end)
            if cliItem and cliItem._CreateViewModel then
                local origCVM = cliItem._CreateViewModel
                cliItem._CreateViewModel = function(self, vmRef)
                    local wn = self.Name
                    local wp = self.ClientFighter and self.ClientFighter.Player
                    buildingWep = (wp == LocalPlayer) and wn or nil
                    if wp == LocalPlayer and STATE.UnlockSkins and eq[wn] then
                        local dk  = self:ToEnum("Data")
                        local ref = vmRef[dk] or vmRef.Data
                        if ref then
                            if eq[wn].Skin  then ref[self:ToEnum("Skin")]  = eq[wn].Skin; ref[self:ToEnum("Name")] = eq[wn].Skin.Name end
                            if eq[wn].Charm then ref[self:ToEnum("Charm")] = eq[wn].Charm end
                            if eq[wn].Wrap  then ref[self:ToEnum("Wrap")]  = eq[wn].Wrap  end
                        end
                    end
                    local r = origCVM(self, vmRef); buildingWep = nil; return r
                end
            end
            local vmMod = LocalPlayer.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem:FindFirstChild("ClientViewModel")
            if vmMod then
                task.wait()
                local CVM = require(vmMod); local origNew = CVM.new
                CVM.new = function(repData, cliItm)
                    local wp = cliItm.ClientFighter and cliItm.ClientFighter.Player
                    local wn = buildingWep or cliItm.Name
                    if wp == LocalPlayer and STATE.UnlockSkins and eq[wn] then
                        local RC = require(ReplicatedStorage.Modules.ReplicatedClass)
                        local dk = RC:ToEnum("Data")
                        repData[dk] = repData[dk] or {}
                        local cos = eq[wn]
                        if cos.Skin  then repData[dk][RC:ToEnum("Skin")]  = cos.Skin  end
                        if cos.Charm then repData[dk][RC:ToEnum("Charm")] = cos.Charm end
                        if cos.Wrap  then repData[dk][RC:ToEnum("Wrap")]  = cos.Wrap  end
                    end
                    return origNew(repData, cliItm)
                end
            end
        end)
    end)
end
