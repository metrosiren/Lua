-- ─── Utility ────────────────────────────────────────────────────────────────

local function getCharacter(player)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then return char end
    local entities = workspace:FindFirstChild("Assets")
        and workspace.Assets:FindFirstChild("Temp")
        and workspace.Assets.Temp:FindFirstChild("Entities")
    if entities then
        for _, ent in ipairs(entities:GetChildren()) do
            if ent.Name == player.Name and ent:FindFirstChild("HumanoidRootPart") then
                return ent
            end
        end
    end
    return char
end

local function isAlive(player)
    local char = getCharacter(player)
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    return hum ~= nil and hum.Health > 0
end

local function worldToScreen(pos)
    local vec, onScreen = Camera:WorldToViewportPoint(pos)
    return Vector2.new(vec.X, vec.Y), onScreen, vec.Z
end

local function isVisible(part)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local localChar = LocalPlayer.Character
    params.FilterDescendantsInstances = localChar and { localChar } or {}
    local origin = Camera.CFrame.Position
    local result = workspace:Raycast(origin, part.Position - origin, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

local function getDistance(player)
    local char    = getCharacter(player)
    local lChar   = LocalPlayer.Character
    if not char or not lChar then return math.huge end
    local r1 = char:FindFirstChild("HumanoidRootPart")
    local r2 = lChar:FindFirstChild("HumanoidRootPart")
    if not r1 or not r2 then return math.huge end
    return (r1.Position - r2.Position).Magnitude
end

local function isEnemy(player)
    if not STATE.TeamCheck then return true end
    return player.Team == nil or LocalPlayer.Team == nil or player.Team ~= LocalPlayer.Team
end

local _rbColor = Color3.new(1, 1, 1)
