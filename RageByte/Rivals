local function serverHop()
    task.spawn(function()
        local TS      = game:GetService("TeleportService")
        local placeId = game.PlaceId
        local jobId   = game.JobId
        local found, cursor = nil, ""
        repeat
            local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100%s")
                :format(placeId, cursor ~= "" and ("&cursor=" .. cursor) or "")
            local ok, raw = pcall(function() return game:HttpGet(url) end)
            if not ok then break end
            local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
            if not ok2 or type(data) ~= "table" or type(data.data) ~= "table" then break end
            for _, server in ipairs(data.data) do
                if server.id ~= jobId and type(server.id) == "string"
                    and type(server.playing) == "number" and server.playing < server.maxPlayers then
                    found = server.id; break
                end
            end
            cursor = (data.nextPageCursor and tostring(data.nextPageCursor)) or ""
        until found or cursor == "" or cursor == "null"
        if found then
            notify("Server Hop: Jumping to a new server..."); task.wait(1)
            pcall(function() TS:TeleportToPlaceInstance(placeId, found, LocalPlayer) end)
        else
            notify("Server Hop: No available servers found.")
        end
    end)
end

