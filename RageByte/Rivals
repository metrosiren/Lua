local function hookHumanoid(hum)
    -- capture game-original values before we ever modify them
    origHumStats.WalkSpeed = hum.WalkSpeed
    origHumStats.JumpPower = hum.JumpPower
    hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if STATE.WalkSpeedEnabled and STATE.Master and hum.WalkSpeed ~= STATE.WalkSpeed then
            hum.WalkSpeed = STATE.WalkSpeed
        end
    end)
    hum:GetPropertyChangedSignal("JumpPower"):Connect(function()
        if STATE.JumpPowerEnabled and STATE.Master and hum.JumpPower ~= STATE.JumpPower then
            hum.JumpPower = STATE.JumpPower
        end
    end)
    if STATE.WalkSpeedEnabled and STATE.Master then hum.WalkSpeed = STATE.WalkSpeed end
    if STATE.JumpPowerEnabled and STATE.Master then hum.JumpPower = STATE.JumpPower end
end

