do
    local _acApplied = false
    local _acDescConn = nil
    local _prevACBypass = STATE.AntiCheatBypass

    RunService.Stepped:Connect(function()
        -- One-shot: run bypass ops the first time the toggle is enabled
        if STATE.AntiCheatBypass and not _acApplied then
            _acApplied = true
            task.delay(2, function()
                -- Disable scripts with AC-related names
                pcall(function()
                    local tags = { "anticheat", "ac", "detection", "ban", "kick", "security", "moderation" }
                    local function proc(o)
                        pcall(function()
                            if not (o:IsA("LocalScript") or o:IsA("ModuleScript")) then return end
                            local ok, nm = pcall(function() return o.Name:lower() end)
                            if not ok then return end
                            for _, t in ipairs(tags) do
                                if nm:find(t) then pcall(function() o.Disabled = true end) break end
                            end
                        end)
                    end
                    for _, o in ipairs(game:GetDescendants()) do proc(o) end
                    _acDescConn = game.DescendantAdded:Connect(proc)
                end)
                -- Decoy remote to absorb kick events
                pcall(function()
                    local ev = Instance.new("RemoteEvent")
                    ev.Name = "ClientAlert"
                    ev.Parent = LocalPlayer
                end)
                dbg("AC", "bypass applied")
            end)
        end
        -- Toggle-off: stop watching for new AC scripts
        if STATE.AntiCheatBypass ~= _prevACBypass then
            _prevACBypass = STATE.AntiCheatBypass
            if not STATE.AntiCheatBypass and _acDescConn then
                _acDescConn:Disconnect()
                _acDescConn = nil
            end
        end
    end)
end

