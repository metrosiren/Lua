-----------------------------------
local customEnv = getgenv and getgenv() or _G
if customEnv.SilentAim then customEnv.SilentAim:Shutdown() end
customEnv.SilentAim = { Active = false, Desync = false }

local GunModule = pcall(function() return require(LocalPlayer.PlayerScripts.Modules.ItemTypes.Gun) end) and require(LocalPlayer.PlayerScripts.Modules.ItemTypes.Gun) or nil
local UtilityModule = pcall(function() return require(ReplicatedStorage.Modules.Utility) end) and require(ReplicatedStorage.Modules.Utility) or nil

customEnv.SilentAim.Shutdown = function(self)
    self.Active = false
    if self.Connection1 then self.Connection1:Disconnect() end
    if self.Connection2 then self.Connection2:Disconnect() end
    if self.Task then task.cancel(self.Task) end
    if self.OriginalShoot and type(GunModule) == "table" then GunModule.StartShooting = self.OriginalShoot end
end

customEnv.SilentAim.Connection1 = RunService.Heartbeat:Connect(function()
    if STATE.SilentAim and STATE.Master then customEnv.SilentAim.Target = getSilentAimTarget() end
end)

if type(GunModule) == "table" and GunModule.StartShooting then
    customEnv.SilentAim.OriginalShoot = GunModule.StartShooting
    GunModule.StartShooting = function(self, ...)
        local args = { customEnv.SilentAim.OriginalShoot(self, ...) }
        if not self.ClientFighter or not self.ClientFighter.IsLocalPlayer or type(args[3]) ~= "table" or not STATE.SilentAim or not STATE.Master or not customEnv.SilentAim.Target or not customEnv.SilentAim.Target.Character then
            return unpack(args)
        end
        args[4] = true
        local tgt = customEnv.SilentAim.Target
        if not customEnv.SilentAim.Desync or customEnv.SilentAim.CurrentTarget ~= tgt then
            if customEnv.SilentAim.Connection2 then customEnv.SilentAim.Connection2:Disconnect() end
            customEnv.SilentAim.Desync = true
            customEnv.SilentAim.CurrentTarget = tgt
            customEnv.SilentAim.Connection2 = RunService.Heartbeat:Connect(function()
                if not customEnv.SilentAim.Desync then return end
                local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tgtRoot = tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
                if not myRoot or not tgtRoot then customEnv.SilentAim.Desync = false return end
                local oldCFrame, oldVel, oldRot = myRoot.CFrame, myRoot.Velocity, myRoot.RotVelocity
                myRoot.CFrame = tgtRoot.CFrame * CFrame.new(0, -5, 0)
                RunService:BindToRenderStep("RestorePosition", 101, function()
                    if myRoot then myRoot.CFrame, myRoot.Velocity, myRoot.RotVelocity = oldCFrame, oldVel, oldRot end
                    RunService:UnbindFromRenderStep("RestorePosition")
                end)
            end)
            task.wait(0.1)
        end
        if customEnv.SilentAim.Task then task.cancel(customEnv.SilentAim.Task) end
        local head = tgt.Character:FindFirstChild("Head")
        if not head then return unpack(args) end
        local targetPos, targetCFrame = head.Position, head.CFrame
        local startPos = targetPos - Vector3.new(0, 5, 0)
        local lookCFrame = CFrame.lookAt(startPos, targetPos)
        local encode = type(UtilityModule) == "table" and UtilityModule.EncodeCFrame
        args[3][utf8.char(0)] = encode and UtilityModule:EncodeCFrame(CFrame.new(startPos, targetPos) * CFrame.Angles(lookCFrame:ToOrientation())) or CFrame.new(startPos, targetPos) * CFrame.Angles(lookCFrame:ToOrientation())
        args[3][utf8.char(1)] = encode and UtilityModule:EncodeCFrame(CFrame.new(targetPos) * CFrame.Angles(lookCFrame:ToOrientation())) or CFrame.new(targetPos) * CFrame.Angles(lookCFrame:ToOrientation())
        args[3][utf8.char(2)] = head
        args[3][utf8.char(3)] = encode and UtilityModule:EncodeCFrame(targetCFrame:ToObjectSpace(CFrame.new(targetPos + Vector3.new(math.random(), math.random(), math.random())))) or targetCFrame:ToObjectSpace(CFrame.new(targetPos))
        customEnv.SilentAim.Task = task.delay(0.15, function()
            customEnv.SilentAim.Desync = false
            if customEnv.SilentAim.Connection2 then customEnv.SilentAim.Connection2:Disconnect() customEnv.SilentAim.Connection2 = nil end
        end)
        return unpack(args)
    end
end

