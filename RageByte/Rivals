-- AIM TRAJECTORY VISUALIZER
-----------------------------------

local TRAJ_DATA = {}         -- [player] = { points = {} }
local TRAJ_MAX_PTS   = 15
local TRAJ_LOOK_DIST = 12    -- studs forward to project each sample
local TRAJ_SUBSEG    = 5     -- Catmull-Rom sub-divisions per gap
local TRAJ_INTERVAL  = 1/30  -- sample rate (seconds)
local _trajAccum = 0
local TRAJ_LINE_POOL = {}
local TRAJ_LINES_USED = 0

-- Catmull-Rom interpolation for Vector2
local function catmullV2(p0, p1, p2, p3, t)
    local t2 = t * t
    local t3 = t2 * t
    return 0.5 * (
        (2 * p1)
        + (-p0 + p2) * t
        + (2*p0 - 5*p1 + 4*p2 - p3) * t2
        + (-p0 + 3*p1 - 3*p2 + p3) * t3
    )
end

local function getTrajLine(idx)
    if not TRAJ_LINE_POOL[idx] then
        local ln = Drawing.new("Line")
        ln.Thickness = 2.5
        ln.Visible = false
        TRAJ_LINE_POOL[idx] = ln
    end
    return TRAJ_LINE_POOL[idx]
end

local function setupTrajectory(player)
    TRAJ_DATA[player] = { points = {} }
end

local function cleanupTrajectory(player)
    TRAJ_DATA[player] = nil
end

for _, p in pairs(Players:GetPlayers()) do setupTrajectory(p) end
Players.PlayerAdded:Connect(setupTrajectory)
Players.PlayerRemoving:Connect(cleanupTrajectory)

-- Sample each player's look-target at fixed rate
RunService.Heartbeat:Connect(function(dt)
    _trajAccum = _trajAccum + dt
    if _trajAccum < TRAJ_INTERVAL then return end
    _trajAccum = _trajAccum % TRAJ_INTERVAL
    if not STATE.AimTrajectory or not STATE.Master then return end
    for player, data in pairs(TRAJ_DATA) do
        local target
        if player == LocalPlayer then
            -- local player: sample exactly where their camera is aimed
            if Camera then
                target = Camera.CFrame.Position + Camera.CFrame.LookVector * TRAJ_LOOK_DIST
            end
        else
            local char = getCharacter(player)
            local head = char and (char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart"))
            if not head then continue end
            target = head.Position + head.CFrame.LookVector * TRAJ_LOOK_DIST
        end
        if not target then continue end
        local pts = data.points
        pts[#pts + 1] = target
        while #pts > TRAJ_MAX_PTS do table.remove(pts, 1) end
    end
end)

-- Render smooth bezier trails
RunService.RenderStepped:Connect(function()
    local lineIdx = 0
    local color = STATE.RainbowVisuals and getRainbow(0.67) or Color3.fromRGB(STATE.AimTrajR, STATE.AimTrajG, STATE.AimTrajB)

    if STATE.AimTrajectory and STATE.Master then
        for player, data in pairs(TRAJ_DATA) do
            local isLocal = (player == LocalPlayer)
            local isEnemy = not STATE.TeamCheck
                or player.Team == nil
                or LocalPlayer.Team == nil
                or player.Team ~= LocalPlayer.Team
            if not isLocal and not isEnemy then continue end

            local pts = data.points
            local n = #pts
            if n < 4 then continue end

            -- Project world-space history to screen
            local sp = {}
            for i, wp in ipairs(pts) do
                local s, _, depth = worldToScreen(wp)
                sp[i] = (depth > 0) and s or false
            end

            -- Catmull-Rom through all consecutive valid quads
            for i = 2, n - 2 do
                local p0, p1, p2, p3 = sp[i-1], sp[i], sp[i+1], sp[i+2]
                if not (p0 and p1 and p2 and p3) then continue end
                local ageFrac  = (i - 1) / (n - 1)   -- 0=oldest, 1=newest
                local transp   = 1 - ageFrac * 0.97   -- oldest: invisible, newest: nearly fully opaque
                for s = 0, TRAJ_SUBSEG - 1 do
                    local t0   = s / TRAJ_SUBSEG
                    local t1   = (s + 1) / TRAJ_SUBSEG
                    local from = catmullV2(p0, p1, p2, p3, t0)
                    local to   = catmullV2(p0, p1, p2, p3, t1)
                    lineIdx = lineIdx + 1
                    local ln = getTrajLine(lineIdx)
                    ln.From  = from
                    ln.To    = to
                    ln.Color = color
                    ln.Transparency = transp
                    ln.Visible = true
                end
            end
        end
    end

    -- Hide any leftover pooled lines from prior frames
    for i = lineIdx + 1, TRAJ_LINES_USED do
        if TRAJ_LINE_POOL[i] then TRAJ_LINE_POOL[i].Visible = false end
    end
    TRAJ_LINES_USED = lineIdx
end)

