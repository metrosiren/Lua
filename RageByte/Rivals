local function getClosestPlayerAim()
    local closest, closestDist = nil, STATE.AimFOV
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if STATE.ESPTeamCheck and player.Team ~= nil and LocalPlayer.Team ~= nil and player.Team == LocalPlayer.Team then continue end
        if not isAlive(player) then continue end
        
        local char = getCharacter(player)
        if not char then continue end
        local part = char:FindFirstChild(STATE.AimPart) or char:FindFirstChild("Head")
        if not part then continue end

        local screenPos, onScreen = worldToScreen(part.Position)
        if not onScreen then continue end
        if STATE.AimVisibleOnly and not isVisible(part) then continue end
        if STATE.AimMaxDistance > 0 and getDistance(player) > STATE.AimMaxDistance then continue end

        local dist = (screenPos - center).Magnitude
        if dist < closestDist then
            closest = player
            closestDist = dist
        end
    end
    return closest
end

-- Silent aim variant: no FOV cap, no visibility check, no distance limit (true wallbang)
local function getSilentAimTarget()
    local closest, closestDist = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if STATE.ESPTeamCheck and player.Team ~= nil and LocalPlayer.Team ~= nil and player.Team == LocalPlayer.Team then continue end
        if not isAlive(player) then continue end
        local char = getCharacter(player)
        if not char then continue end
        local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        local screenPos, _, depth = worldToScreen(part.Position)
        if depth <= 0 then continue end  -- behind camera
        local dist = (screenPos - center).Magnitude
        if dist < closestDist then
            closest = player
            closestDist = dist
        end
    end
    return closest
end

local function aimAt(target)
    local char = getCharacter(target)
    if not char then return end
    local part = char:FindFirstChild(STATE.AimPart) or char:FindFirstChild("Head")
    if not part then return end

    local screenPos, onScreen = worldToScreen(part.Position)
    if not onScreen then return end

    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local delta = screenPos - center

    -- Remap slider 1-20 → divisor 0.05-2.0 (non-linear).
    -- At 1: divisor ≈ 0.05 → move = delta*20 (very aggressive snap/overshoot).
    -- At ~5: divisor ≈ 0.5  → still fast but stable.
    -- At 20: divisor = 2.0  → smooth tracking.
    local smooth = math.max(STATE.AimSmoothness * 0.1, 0.05)
    local move = delta / smooth

    if STATE.AimHumanize then
        move = move + Vector2.new(math.random(-2, 2), math.random(-2, 2))
    end

    if mousemoverel then
        mousemoverel(math.floor(move.X), math.floor(move.Y))
    end
end

local lastTrigger = 0
local function tryTriggerbot()
    if not STATE.Triggerbot then return end
    local now = tick() * 1000
    if now - lastTrigger < STATE.TriggerbotDelay then return end

    local target = getClosestPlayerAim()
    if not target then return end
    local char = getCharacter(target)
    if not char then return end
    local part = char:FindFirstChild(STATE.AimPart) or char:FindFirstChild("Head")
    if not part then return end

    local screenPos, onScreen = worldToScreen(part.Position)
    if not onScreen then return end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    if (screenPos - center).Magnitude < 15 then
        if mouse1click then mouse1click() end
        lastTrigger = now
    end
end

