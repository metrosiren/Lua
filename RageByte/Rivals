local function cloneImpactMarker(original)
    if not STATE.ImpactMarkers or not STATE.Master then return end
    local clone = original:Clone()
    pcall(function()
        local color = Color3.fromRGB(STATE.ImpactR, STATE.ImpactG, STATE.ImpactB)
        if clone:IsA("BasePart") then clone.Color = color end
        for _, v in ipairs(clone:GetDescendants()) do
            if v:IsA("BasePart") then v.Color = color end
            if v:IsA("Beam") then v.Color = ColorSequence.new(color) end
            if v:IsA("ParticleEmitter") then v.Color = ColorSequence.new(color) end
        end
    end)
    clone:SetAttribute("IsClone", true)
    clone.Parent = workspace
    task.spawn(function()
        task.wait(2)
        pcall(function() clone:Destroy() end)
    end)
end

task.defer(function()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Beam") then pcall(cloneBeam, obj) end
        if obj.Name == "ImpactMarkerBullet" and not obj:GetAttribute("IsClone") then pcall(cloneImpactMarker, obj) end
    end
