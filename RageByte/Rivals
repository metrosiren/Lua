            local lineTarget = STATE.SilentAim and getSilentAimTarget()
                or (STATE.Aimbot and getClosestInFOV())
            if lineTarget then
                local char = getCharacter(lineTarget)
                local part = char and (char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart"))
                if part then
                    local sp, onScreen, depth = worldToScreen(part.Position)
                    if onScreen and depth > 0 and getDistance(lineTarget) <= 400 then
                        TargetLineDrawing.From    = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                        TargetLineDrawing.To      = sp
                        TargetLineDrawing.Color   = STATE.RainbowVisuals and _rbColor or Color3.fromRGB(255,50,50)
                        TargetLineDrawing.Visible = true
                    else
                        TargetLineDrawing.Visible = false
                    end
                else
                    TargetLineDrawing.Visible = false
                end
            else
                TargetLineDrawing.Visible = false
            end
        else
            TargetLineDrawing.Visible = false
        end
    end

    if Drawing then
        for player, _ in pairs(ESP_OBJECTS) do updateESP(player) end
    end

    do
        local chamsActive = STATE.ChamsESP and STATE.Master
        local chamsColor  = visualColor(STATE.ChamsR, STATE.ChamsG, STATE.ChamsB)
        for player, data in pairs(CHAMS_OBJECTS) do
            if data.hl and data.hl.Parent then
                local char   = player.Character
                local hum    = char and char:FindFirstChildOfClass("Humanoid")
                data.hl.Enabled   = chamsActive and isEnemy(player) and hum ~= nil and hum.Health > 0
                data.hl.FillColor = chamsColor
            end
        end
    end

    do
        local trajColor = visualColor(STATE.AimTrajR, STATE.AimTrajG, STATE.AimTrajB)
        local lineIdx   = 0
        if STATE.AimTrajectory and STATE.Master then
            for player, data in pairs(TRAJ_DATA) do
                if player ~= LocalPlayer and not isEnemy(player) then continue end
                local pts = data.points
                local n   = #pts
                if n < 4 then continue end
                local sp = {}
                for i, wp in ipairs(pts) do
                    local s, _, depth = worldToScreen(wp)
                    sp[i] = depth > 0 and s or false
                end
                for i = 2, n - 2 do
                    local p0, p1, p2, p3 = sp[i-1], sp[i], sp[i+1], sp[i+2]
                    if not (p0 and p1 and p2 and p3) then continue end
                    local transp = 1 - ((i-1)/(n-1)) * 0.97
                    for s = 0, TRAJ_SUBSEG - 1 do
                        if lineIdx >= TRAJ_MAX_LINES then break end
                        lineIdx = lineIdx + 1
                        local ln = getTrajLine(lineIdx)
                        if ln then
                            ln.From = catmullV2(p0,p1,p2,p3, s/TRAJ_SUBSEG)
                            ln.To   = catmullV2(p0,p1,p2,p3, (s+1)/TRAJ_SUBSEG)
                            ln.Color = trajColor; ln.Transparency = transp; ln.Visible = true
                        end
                    end
                end
            end
        end
        for i = lineIdx + 1, TRAJ_LINES_USED do
            if TRAJ_LINE_POOL[i] then TRAJ_LINE_POOL[i].Visible = false end
        end
        TRAJ_LINES_USED = lineIdx
    end

    if STATE.SpinCrosshair and STATE.Master then
        if not _spinReady then setupSpinCrosshair() end
        _spinAngle = (_spinAngle + SPIN_SPEED * dt) % 360
        local cx, cy  = Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2
        local color   = visualColor(255, 255, 255)
        for i = 1, 4 do
            local angle = math.rad(_spinAngle + (i-1)*90)
            local ln    = _spinLines[i]
            if ln then
                ln.From    = Vector2.new(cx + math.cos(angle)*6,  cy + math.sin(angle)*6)
                ln.To      = Vector2.new(cx + math.cos(angle)*20, cy + math.sin(angle)*20)
                ln.Color   = color; ln.Visible = true
            end
        end
        if _spinLines[5] then
            _spinLines[5].Position = Vector2.new(cx, cy)
            _spinLines[5].Color    = color; _spinLines[5].Visible = true
        end
    elseif _spinReady then
        teardownSpinCrosshair()
    end

    updateFly()
end)

