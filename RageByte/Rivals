local function catmullV2(p0, p1, p2, p3, t)
    local t2, t3 = t*t, t*t*t
    return 0.5 * ((2*p1) + (-p0+p2)*t + (2*p0-5*p1+4*p2-p3)*t2 + (-p0+3*p1-3*p2+p3)*t3)
end

local function getTrajLine(idx)
    if not Drawing or idx > TRAJ_MAX_LINES then return nil end
    if not TRAJ_LINE_POOL[idx] then
        TRAJ_LINE_POOL[idx] = newDrawing("Line", { Thickness = 2.5, Visible = false })
    end
    return TRAJ_LINE_POOL[idx]
end

