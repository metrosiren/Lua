-- SILENT AIM (WALLBANG) OVERRIDE
-----------------------------------
local customEnv = getgenv and getgenv() or _G
if customEnv.SilentAim then customEnv.SilentAim:Shutdown() end
customEnv.SilentAim = { Active = false }

local GunModule, UtilityModule
-- requires are loaded async after 0.5s to avoid blocking the main thread

-- Desync object (fixed, OOP)
local _ds = {}
do
    _ds.__active     = false
    _ds.__target     = nil
    _ds.__desync     = false
    _ds.__conn1      = nil
    _ds.__conn2      = nil
    _ds.__task1      = nil
    _ds.__curr       = nil
    _ds.__lastTarget = nil

    local _dsRoot = setmetatable({}, {
        __index = function(_, key)
            local char = LocalPlayer.Character
            if not char then return nil end
            if key == "__root" then return char:FindFirstChild("HumanoidRootPart")
            elseif key == "__head" then return char:FindFirstChild("Head") end
            return nil
        end
    })

    function _ds:__find()
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local closest, closestDist = nil, math.huge
        local localChar = LocalPlayer.Character
        local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
        for _, player in next, Players:GetPlayers() do
            if player == LocalPlayer then continue end
            if STATE.TeamCheck and player:GetAttribute("TeamID") == LocalPlayer:GetAttribute("TeamID") then continue end
            local char = player.Character
            if not char then continue end
            local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            local hum  = char:FindFirstChildWhichIsA("Humanoid")
            if not (head and hum and hum.Health > 0) then continue end
            -- max range check (300 studs)
            if localRoot then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root and (root.Position - localRoot.Position).Magnitude > 300 then continue end
            end
            local screenPos, _, depth = worldToScreen(head.Position)
            if depth <= 0 then continue end  -- behind camera only
            local dist = (screenPos - center).Magnitude
            if dist < closestDist then closestDist = dist; closest = player end
        end
        return closest
    end

    function _ds:__desync_start(target)
        if not target or not target.Character then return end
        local tHum = target.Character:FindFirstChild("Humanoid")
        if not tHum or tHum.Health <= 0 then return end
        if self.__conn2 then self.__conn2:Disconnect() end
        self.__desync = true
        self.__curr   = target

        self.__conn2 = RunService.Heartbeat:Connect(function()
            if not self.__desync then return end
            if not self.__curr or not self.__curr.Character then
                self:__desync_stop(); return
            end
            local tHumCheck = self.__curr.Character:FindFirstChild("Humanoid")
            if not tHumCheck or tHumCheck.Health <= 0 then
                self:__desync_stop(); return
            end
            local rootPart = _dsRoot.__root
            if not rootPart then return end
            local tgtRoot = self.__curr.Character:FindFirstChild("HumanoidRootPart")
            if not tgtRoot then self:__desync_stop(); return end

            local savedCF  = rootPart.CFrame
            local savedVel = rootPart.Velocity
            local savedRot = rootPart.RotVelocity
            rootPart.CFrame = tgtRoot.CFrame * CFrame.new(0, -5, 0)

            RunService:BindToRenderStep("__RR_restore", 101, function()
                if rootPart and rootPart.Parent then
                    rootPart.CFrame      = savedCF
                    rootPart.Velocity    = savedVel
                    rootPart.RotVelocity = savedRot
                end
                RunService:UnbindFromRenderStep("__RR_restore")
            end)
        end)
    end

    function _ds:__desync_stop()
        self.__desync = false
        pcall(function() RunService:UnbindFromRenderStep("__RR_restore") end)
        if self.__conn2 then self.__conn2:Disconnect(); self.__conn2 = nil end
        self.__curr = nil
    end

    function _ds:__startHeartbeat()
        if self.__conn1 then self.__conn1:Disconnect() end
        self.__conn1 = RunService.Heartbeat:Connect(function()
            if not self.__active then return end
            local newTarget = self:__find()
            -- If target died while desync active, stop immediately
            if self.__desync and self.__target then
                local alive = self.__target.Character
                    and self.__target.Character:FindFirstChild("Humanoid")
                    and self.__target.Character.Humanoid.Health > 0
                if not alive then
                    self:__desync_stop()
                    self.__target = nil
                end
            end
            -- Don't switch targets while desync is running
            if not self.__desync then
                self.__target = newTarget
            end
        end)
    end

    function _ds:enable()
        if self.__active then return end
        self.__active = true
        self:__startHeartbeat()
    end

    function _ds:disable()
        self.__active = false
        self:__desync_stop()
        pcall(function() RunService:UnbindFromRenderStep("__RR_restore") end)
        if self.__conn1 then self.__conn1:Disconnect(); self.__conn1 = nil end
        if self.__task1 then task.cancel(self.__task1); self.__task1 = nil end
        self.__target = nil
    end

    function _ds:shoot(packetArgs, tgt)
        local head = tgt.Character and tgt.Character:FindFirstChild("Head")
        if not head then return end
        local tHum = tgt.Character:FindFirstChild("Humanoid")
        if not tHum or tHum.Health <= 0 then self:__desync_stop(); return end

        if not self.__desync or self.__curr ~= tgt then
            self:__desync_start(tgt)
            task.wait(0.1)
        end

        if self.__task1 then task.cancel(self.__task1); self.__task1 = nil end

        -- Re-validate after wait
        if not tgt.Character then self:__desync_stop(); return end
        tHum = tgt.Character:FindFirstChild("Humanoid")
        if not tHum or tHum.Health <= 0 then self:__desync_stop(); return end
        head = tgt.Character:FindFirstChild("Head")
        if not head then return end

        local targetPos    = head.Position
        local targetCFrame = head.CFrame
        local shotOrigin   = targetPos - Vector3.new(0, 5, 0)
        local lookDir      = CFrame.lookAt(shotOrigin, targetPos)
        local noise        = Vector3.new(math.random(), math.random(), math.random())
        local localHitCF   = targetCFrame:ToObjectSpace(CFrame.new(targetPos + noise))
        local encode       = type(UtilityModule) == "table" and UtilityModule.EncodeCFrame

        packetArgs[utf8.char(0)] = encode and UtilityModule:EncodeCFrame(CFrame.new(shotOrigin, targetPos) * CFrame.Angles(lookDir:ToOrientation())) or CFrame.new(shotOrigin, targetPos)
        packetArgs[utf8.char(1)] = encode and UtilityModule:EncodeCFrame(CFrame.new(targetPos) * CFrame.Angles(lookDir:ToOrientation())) or CFrame.new(targetPos)
        packetArgs[utf8.char(2)] = head
        packetArgs[utf8.char(3)] = encode and UtilityModule:EncodeCFrame(localHitCF) or localHitCF

        self.__task1 = task.delay(0.15, function() self:__desync_stop() end)
    end
end

customEnv.SilentAim.Shutdown = function(self)
    self.Active = false
    _ds:disable()
    if self.Connection1 then self.Connection1:Disconnect(); self.Connection1 = nil end
    if self.OriginalShoot and type(GunModule) == "table" then GunModule.StartShooting = self.OriginalShoot end
end

customEnv.SilentAim.Connection1 = RunService.Heartbeat:Connect(function()
    if STATE.SilentAim and STATE.Master then
        if STATE.SilentAimMode == "Desync" then
            _ds:enable()
            customEnv.SilentAim.Target = _ds.__target
        else
            _ds:disable()
            customEnv.SilentAim.Target = getSilentAimTarget()
        end
    else
        _ds:disable()
        customEnv.SilentAim.Target = nil
    end
end)

-- Load modules and hook StartShooting after 0.5s so they don't block the main thread
task.delay(0.5, function()
    dbg("SA", "requiring Gun module (async)")
    do local ok, m = pcall(function() return require(LocalPlayer.PlayerScripts.Modules.ItemTypes.Gun) end); if ok and type(m) == "table" then GunModule = m end end
    dbg("SA", "Gun done type=" .. type(GunModule))
    dbg("SA", "requiring Utility module (async)")
    do local ok, m = pcall(function() return require(ReplicatedStorage.Modules.Utility) end); if ok and type(m) == "table" then UtilityModule = m end end
    dbg("SA", "Utility done type=" .. type(UtilityModule))
    if type(GunModule) == "table" and GunModule.StartShooting then
        dbg("SA", "hooking GunModule.StartShooting")
        customEnv.SilentAim.OriginalShoot = GunModule.StartShooting
        GunModule.StartShooting = function(self, ...)
            local args = { customEnv.SilentAim.OriginalShoot(self, ...) }
            if not self.ClientFighter or not self.ClientFighter.IsLocalPlayer
               or type(args[3]) ~= "table"
               or not STATE.SilentAim or not STATE.Master
               or not customEnv.SilentAim.Target
               or not customEnv.SilentAim.Target.Character then
                return unpack(args)
            end
            args[4] = true
            local tgt  = customEnv.SilentAim.Target
            local head = tgt.Character:FindFirstChild("Head")
            if not head then return unpack(args) end

            local targetPos    = head.Position
            local targetCFrame = head.CFrame
            local encode       = type(UtilityModule) == "table" and UtilityModule.EncodeCFrame

            if STATE.SilentAimMode == "Desync" then
                local tHum = tgt.Character:FindFirstChild("Humanoid")
                if not tHum or tHum.Health <= 0 then
                    _ds:__desync_stop()
                    return unpack(args)
                end
                _ds:shoot(args[3], tgt)
            else
                -- Regular mode: real HRP origin, wallbang, no desync
                local myChar     = LocalPlayer.Character
                local myRoot     = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local shotOrigin = myRoot and myRoot.Position or (targetPos - Vector3.new(0, 5, 0))
                local lookDir    = CFrame.lookAt(shotOrigin, targetPos)
                local rx, ry, rz = lookDir:ToOrientation()
                local originCF   = CFrame.new(shotOrigin, targetPos) * CFrame.Angles(rx, ry, rz)
                local impactCF   = CFrame.new(targetPos)             * CFrame.Angles(rx, ry, rz)
                local noise      = Vector3.new(math.random(), math.random(), math.random())
                local localHitCF = targetCFrame:ToObjectSpace(CFrame.new(targetPos + noise))

                args[3][utf8.char(0)] = encode and UtilityModule:EncodeCFrame(originCF)   or originCF
                args[3][utf8.char(1)] = encode and UtilityModule:EncodeCFrame(impactCF)   or impactCF
                args[3][utf8.char(2)] = head
                args[3][utf8.char(3)] = encode and UtilityModule:EncodeCFrame(localHitCF) or localHitCF
            end

            return unpack(args)
        end
    end
end)

