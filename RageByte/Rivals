local function updateQueue()
    playerQueue = {}
    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hum = p.Character:FindFirstChild("Humanoid")
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 and localRoot then
                if (root.Position - localRoot.Position).Magnitude <= MAX_STUD_DISTANCE then
                    table.insert(playerQueue, p)
                end
            end
        end
    end
    
    if currentIndex > #playerQueue or #playerQueue == 0 then
        currentIndex = 1
    end
    targetPlayer = playerQueue[currentIndex]
end

RunService.Heartbeat:Connect(function()
    if not STATE.Master then return end
    updateQueue()
    
    if STATE.Teleport and targetPlayer and targetPlayer.Character and LocalPlayer.Character then
        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot and localRoot then
            pcall(function()
                localRoot.CFrame = CFrame.new(targetRoot.Position + Vector3.new(0, TP_HEIGHT, 0))
            end)
        end
    end
end)

