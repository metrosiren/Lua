local tabButtons = {}
local tabPages = {}
local currentTabIdx = 1

local function selectTab(idx)
    currentTabIdx = idx
    for i, p in pairs(tabPages) do 
        p.Visible = (i == idx)
        if i == idx then p.CanvasPosition = Vector2.new(0, 0) end
    end
    for i, b in pairs(tabButtons) do
        local isSelected = (i == idx)
        
        TweenService:Create(b.btn, TWEEN_INFO, {
            BackgroundColor3 = isSelected and Color3.fromRGB(22, 22, 26) or UI_SECTION,
            BackgroundTransparency = isSelected and 0 or 1
        }):Play()

        TweenService:Create(b.btn, TWEEN_INFO, {
            TextColor3 = isSelected and UI_TEXT or UI_TEXT_MUTED
        }):Play()

        TweenService:Create(b.indicator, TWEEN_INFO, {
            BackgroundTransparency = isSelected and 0 or 1
        }):Play()
    end
end

local function createTab(tabName)
    local btn = Instance.new("TextButton", sidebar)
    btn.Size = UDim2.new(1, 0, 0, 36)
    btn.BackgroundTransparency = 1
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.Text = "    " .. tabName
    btn.TextColor3 = UI_TEXT_MUTED
    btn.Font = FONT_REG
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left

    local indicator = Instance.new("Frame", btn)
    indicator.Size = UDim2.new(0, 3, 0, 20)
    indicator.Position = UDim2.new(0, 0, 0.5, -10)
    indicator.BackgroundColor3 = UI_ACCENT
    indicator.BorderSizePixel = 0
    indicator.BackgroundTransparency = 1

    local page = Instance.new("ScrollingFrame", contentArea)
    page.Size = UDim2.new(1, -24, 1, -24)
    page.Position = UDim2.new(0, 12, 0, 12)
    page.BackgroundTransparency = 1
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = UI_STROKE
    page.BorderSizePixel = 0
    page.Visible = false

    local layout = Instance.new("UIListLayout", page)
    layout.Padding = UDim.new(0, 8)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end)

    table.insert(tabButtons, {btn = btn, indicator = indicator})
    table.insert(tabPages, page)
    local idx = #tabButtons

    btn.MouseEnter:Connect(function()
        if currentTabIdx ~= idx then
            TweenService:Create(btn, TWEEN_INFO, {TextColor3 = UI_TEXT}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if currentTabIdx ~= idx then
            TweenService:Create(btn, TWEEN_INFO, {TextColor3 = UI_TEXT_MUTED}):Play()
        end
    end)

    btn.MouseButton1Click:Connect(function() selectTab(idx) end)

    return page
end

local function addToggle(page, labelText, stateKey)
    local row = Instance.new("TextButton", page)
    row.Size = UDim2.new(1, -6, 0, 30)
    row.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    row.BackgroundTransparency = 1
    row.BorderSizePixel = 0
    row.Text = ""
    row.AutoButtonColor = false
    
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -44, 1, 0)
    lbl.Position = UDim2.new(0, 2, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = STATE[stateKey] and UI_TEXT or UI_TEXT_MUTED
    lbl.Font = FONT_REG
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local box = Instance.new("Frame", row)
    box.Size = UDim2.new(0, 18, 0, 18)
    box.Position = UDim2.new(1, -24, 0.5, -9)
    box.BackgroundColor3 = UI_BG
    box.BorderSizePixel = 0
    
    local boxStroke = Instance.new("UIStroke", box)
    boxStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    boxStroke.Color = STATE[stateKey] and UI_ACCENT or UI_STROKE
    boxStroke.Thickness = 1
    
    local fillDot = Instance.new("Frame", box)
    fillDot.Size = UDim2.new(0, 10, 0, 10)
    fillDot.Position = UDim2.new(0.5, -5, 0.5, -5)
    fillDot.BackgroundColor3 = UI_ACCENT
    fillDot.BorderSizePixel = 0
    fillDot.BackgroundTransparency = STATE[stateKey] and 0 or 1
    
    row.MouseEnter:Connect(function()
        TweenService:Create(row, TWEEN_INFO, {BackgroundTransparency = 0.96}):Play()
    end)
    row.MouseLeave:Connect(function()
        TweenService:Create(row, TWEEN_INFO, {BackgroundTransparency = 1}):Play()
    end)
    
    row.MouseButton1Click:Connect(function()
        STATE[stateKey] = not STATE[stateKey]
        TweenService:Create(boxStroke, TWEEN_INFO, {Color = STATE[stateKey] and UI_ACCENT or UI_STROKE}):Play()
        TweenService:Create(fillDot, TWEEN_INFO, {BackgroundTransparency = STATE[stateKey] and 0 or 1}):Play()
        TweenService:Create(lbl, TWEEN_INFO, {TextColor3 = STATE[stateKey] and UI_TEXT or UI_TEXT_MUTED}):Play()
        saveConfig()
    end)
end

local function addSlider(page, labelText, stateKey, min, max)
    local holder = Instance.new("Frame", page)
    holder.Size = UDim2.new(1, -6, 0, 40)
    holder.BackgroundTransparency = 1
    
    local lbl = Instance.new("TextLabel", holder)
    lbl.Size = UDim2.new(1, -64, 0, 16)
    lbl.Position = UDim2.new(0, 2, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = UI_TEXT
    lbl.Font = FONT_REG
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local valLbl = Instance.new("TextLabel", holder)
    valLbl.Size = UDim2.new(0, 56, 0, 16)
    valLbl.Position = UDim2.new(1, -58, 0, 0)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = tostring(STATE[stateKey])
    valLbl.TextColor3 = UI_ACCENT
    valLbl.Font = FONT_BOLD
    valLbl.TextSize = 13
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local bg = Instance.new("TextButton", holder)
    bg.Size = UDim2.new(1, -4, 0, 8)
    bg.Position = UDim2.new(0, 2, 1, -12)
    bg.BackgroundColor3 = UI_STROKE
    bg.BorderSizePixel = 0
    bg.Text = ""
    bg.AutoButtonColor = false
    
    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new((STATE[stateKey] - min)/(max - min), 0, 1, 0)
    fill.BackgroundColor3 = UI_ACCENT
    fill.BorderSizePixel = 0
    
    local dragging = false
    local function update(input)
        local rel = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        STATE[stateKey] = math.floor(min + (max - min) * rel)
        TweenService:Create(fill, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(rel, 0, 1, 0)}):Play()
        valLbl.Text = tostring(STATE[stateKey])
    end
    
    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if dragging then saveConfig() end
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end)
end

local function addDropdown(page, labelText, stateKey, options, onChanged)
    local holder = Instance.new("Frame", page)
    holder.Size = UDim2.new(1, -6, 0, 30)
    holder.BackgroundTransparency = 1

    local lbl = Instance.new("TextLabel", holder)
    lbl.Size = UDim2.new(0.55, 0, 1, 0)
    lbl.Position = UDim2.new(0, 2, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = UI_TEXT
    lbl.Font = FONT_REG
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local valBtn = Instance.new("TextButton", holder)
    valBtn.Size = UDim2.new(0.42, 0, 0, 22)
    valBtn.Position = UDim2.new(0.57, 0, 0.5, -11)
    valBtn.BackgroundColor3 = UI_SECTION
    valBtn.BorderSizePixel = 0
    valBtn.Text = tostring(STATE[stateKey])
    valBtn.TextColor3 = UI_ACCENT
    valBtn.Font = FONT_BOLD
    valBtn.TextSize = 12
    valBtn.AutoButtonColor = false

    local valStroke = Instance.new("UIStroke", valBtn)
    valStroke.Color = UI_STROKE
    valStroke.Thickness = 1

    local activeList, activeBackdrop = nil, nil

    local function closeList()
        if activeList   then activeList:Destroy();   activeList   = nil end
        if activeBackdrop then activeBackdrop:Destroy(); activeBackdrop = nil end
    end

    valBtn.MouseButton1Click:Connect(function()
        if activeList then closeList() return end

        -- Transparent backdrop catches outside clicks
        activeBackdrop = Instance.new("TextButton", screenGui)
        activeBackdrop.Size = UDim2.new(1, 0, 1, 0)
        activeBackdrop.BackgroundTransparency = 1
        activeBackdrop.Text = ""
        activeBackdrop.ZIndex = 19
        activeBackdrop.MouseButton1Click:Connect(closeList)

        activeList = Instance.new("Frame", screenGui)
        activeList.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
        activeList.BorderSizePixel = 0
        activeList.ZIndex = 20
        activeList.ClipsDescendants = true

        local listStroke = Instance.new("UIStroke", activeList)
        listStroke.Color = UI_STROKE
        listStroke.Thickness = 1
        listStroke.ZIndex = 20

        local scroll = Instance.new("ScrollingFrame", activeList)
        scroll.Size = UDim2.new(1, 0, 1, 0)
        scroll.BackgroundTransparency = 1
        scroll.ScrollBarThickness = 3
        scroll.ScrollBarImageColor3 = UI_STROKE
        scroll.BorderSizePixel = 0
        scroll.ZIndex = 20

        local layout = Instance.new("UIListLayout", scroll)
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Padding = UDim.new(0, 0)

        local ITEM_H = 30
        for i, opt in ipairs(options) do
            local isCurrent = (opt == STATE[stateKey])
            local optBtn = Instance.new("TextButton", scroll)
            optBtn.Size = UDim2.new(1, 0, 0, ITEM_H)
            optBtn.BackgroundColor3 = isCurrent and UI_SECTION or Color3.fromRGB(18, 18, 22)
            optBtn.BackgroundTransparency = 0
            optBtn.BorderSizePixel = 0
            optBtn.Text = "   " .. opt
            optBtn.TextColor3 = isCurrent and UI_ACCENT or UI_TEXT_MUTED
            optBtn.Font = FONT_REG
            optBtn.TextSize = 13
            optBtn.TextXAlignment = Enum.TextXAlignment.Left
            optBtn.AutoButtonColor = false
            optBtn.ZIndex = 20
            optBtn.LayoutOrder = i

            optBtn.MouseEnter:Connect(function()
                if opt ~= STATE[stateKey] then
                    optBtn.BackgroundColor3 = UI_SECTION
                    optBtn.TextColor3 = UI_TEXT
                end
            end)
            optBtn.MouseLeave:Connect(function()
                if opt ~= STATE[stateKey] then
                    optBtn.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
                    optBtn.TextColor3 = UI_TEXT_MUTED
                end
            end)
            optBtn.MouseButton1Click:Connect(function()
                STATE[stateKey] = opt
                valBtn.Text = opt
                if onChanged then onChanged(opt) end
                saveConfig()
                closeList()
            end)
        end

        -- Position the list on the next frame once AbsolutePosition is valid
        task.defer(function()
            if not activeList or not activeList.Parent then return end
            local abs     = valBtn.AbsolutePosition
            local absSize = valBtn.AbsoluteSize
            local listH   = math.min(#options * ITEM_H, 210)
            local listW   = math.max(absSize.X, 110)
            scroll.CanvasSize = UDim2.new(0, 0, 0, #options * ITEM_H)
            activeList.Size = UDim2.new(0, listW, 0, listH)
            if abs.Y + absSize.Y + listH > Camera.ViewportSize.Y - 20 then
                activeList.Position = UDim2.new(0, abs.X, 0, abs.Y - listH)
            else
                activeList.Position = UDim2.new(0, abs.X, 0, abs.Y + absSize.Y + 2)
            end
        end)
    end)
end

