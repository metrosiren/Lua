    mabStroke.Thickness = 2

    local mabLabel = Instance.new("TextLabel", mobileAimBtn)
    mabLabel.Size = UDim2.new(1, 0, 1, 0)
    mabLabel.BackgroundTransparency = 1
    mabLabel.Text = "AIM"
    mabLabel.TextColor3 = Color3.new(1, 1, 1)
    mabLabel.Font = FONT_BOLD
    mabLabel.TextSize = 16
    mabLabel.ZIndex = 5

    -- Invisible hit-test button layered over the frame
    local mabBtn = Instance.new("TextButton", mobileAimBtn)
    mabBtn.Size = UDim2.new(1, 0, 1, 0)
    mabBtn.BackgroundTransparency = 1
    mabBtn.Text = ""
    mabBtn.ZIndex = 6
    mabBtn.AutoButtonColor = false

    local mbDragStart, mbStartPos, mbDragDist, mbAimOn = nil, nil, 0, false
    local DRAG_THRESH = 8

    mabBtn.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.Touch
           and input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        mbDragStart = input.Position
        mbStartPos  = mobileAimBtn.Position
        mbDragDist  = 0
        if STATE.AimMode == "Hold" then
            STATE.AimActive = true
            mbAimOn = true
            TweenService:Create(mobileAimBtn, TWEEN_INFO, {BackgroundTransparency = 0}):Play()
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not mbDragStart then return end
        if input.UserInputType ~= Enum.UserInputType.Touch
           and input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local delta = input.Position - mbDragStart
        mbDragDist = delta.Magnitude
        if mbDragDist > DRAG_THRESH then
            if mbAimOn then
                STATE.AimActive = false
                mbAimOn = false
                TweenService:Create(mobileAimBtn, TWEEN_INFO, {BackgroundTransparency = 0.25}):Play()
            end
            mobileAimBtn.Position = UDim2.new(
                mbStartPos.X.Scale, mbStartPos.X.Offset + delta.X,
                mbStartPos.Y.Scale, mbStartPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if not mbDragStart then return end
        if input.UserInputType ~= Enum.UserInputType.Touch
           and input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if mbDragDist <= DRAG_THRESH then
            -- Tap: toggle or release hold
            if STATE.AimMode == "Toggle" then
                STATE.AimActive = not STATE.AimActive
                TweenService:Create(mobileAimBtn, TWEEN_INFO, {
                    BackgroundTransparency = STATE.AimActive and 0 or 0.25
                }):Play()
            else
                STATE.AimActive = false
                TweenService:Create(mobileAimBtn, TWEEN_INFO, {BackgroundTransparency = 0.25}):Play()
            end
        else
            -- Drag released: ensure aim is off
            STATE.AimActive = false
            TweenService:Create(mobileAimBtn, TWEEN_INFO, {BackgroundTransparency = 0.25}):Play()
        end
        mbDragStart = nil
        mbDragDist  = 0
        mbAimOn     = false
    end)
end

