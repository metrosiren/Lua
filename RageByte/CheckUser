local tracking_data = {}
local tracking_file = "ragebyte.txt"

local function load_tracking()
    if readfile then
        local success, content = pcall(readfile, tracking_file)
        if success and content and content ~= "" then
            local decode_success, decoded = pcall(game:GetService("HttpService").JSONDecode, game:GetService("HttpService"), content)
            if decode_success and decoded then
                tracking_data = decoded
                return true
            end
        end
    end
    return false
end

local function save_tracking()
    if writefile then
        local encoded = game:GetService("HttpService"):JSONEncode(tracking_data)
        pcall(writefile, tracking_file, encoded)
    end
end

local function check_ban_status(current_user, current_id, current_hwid, current_ip)
