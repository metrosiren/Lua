    local success, content = pcall(function()
        return game:HttpGet(github_url, true)
    end)

    if not success then
        warn("Failed to fetch blacklist")
        return false
    end

    content = tostring(content or "")
    content = content:gsub("^\239\187\191", "") -- Remove UTF-8 BOM

