-- Patch functions to unlock cosmetics
local function patchCosmeticLibrary()
    if not CosmeticLibrary then return end
    
    local isCosmeticType = function(cosmetic)
        if not cosmetic then return false end
        for _, typeName in ipairs(COSMETIC_TYPES) do
            if cosmetic.Type == typeName then return true end
        end
        return false
    end
    
    local originalOwns = CosmeticLibrary.OwnsCosmetic
    
    CosmeticLibrary.OwnsCosmeticNormally = function(self, inventory, name, weapon)
        local cosmetic = CosmeticLibrary.Cosmetics[name]
        if cosmetic and (cosmetic.Type == "Skin" or cosmetic.Type == "Finisher" or cosmetic.Type == "Execution") then 
            return true 
        end
        return false
    end
    
    CosmeticLibrary.OwnsCosmeticUniversally = function(self, inventory, name, weapon)
        local cosmetic = CosmeticLibrary.Cosmetics[name]
        if cosmetic and (cosmetic.Type == "Skin" or cosmetic.Type == "Finisher" or cosmetic.Type == "Execution") then 
            return true 
        end
        return false
    end
    
    CosmeticLibrary.OwnsCosmeticForWeapon = function(self, inventory, name, weapon)
        local cosmetic = CosmeticLibrary.Cosmetics[name]
        if cosmetic and (cosmetic.Type == "Skin" or cosmetic.Type == "Finisher" or cosmetic.Type == "Execution") then 
            return true 
        end
        return false
    end
    
    CosmeticLibrary.OwnsCosmetic = function(self, inventory, name, weapon)
        if name:find("MISSING_") or name == "Bubble Gun" then
            return originalOwns(self, inventory, name, weapon)
        end
        local cosmetic = CosmeticLibrary.Cosmetics[name]
        if cosmetic and isCosmeticType(cosmetic) then
            return true
        end
        return originalOwns(self, inventory, name, weapon)
    end
end

-- Patch PlayerDataController
local function patchPlayerDataController()
    if not PlayerDataController then return end
    
    local originalGet = PlayerDataController.Get
    
    PlayerDataController.Get = function(self, key)
        local value = originalGet(self, key)
        
        if key == "CosmeticInventory" then
            local proxy = {}
            if value then
                for k, v in pairs(value) do
                    local cosmetic = CosmeticLibrary.Cosmetics[k]
                    if cosmetic and isCosmeticType(cosmetic) then
                        proxy[k] = v
                    end
                end
            end
            return setmetatable(proxy, {
                __index = function(t, k)
                    local cosmetic = CosmeticLibrary.Cosmetics[k]
                    if cosmetic and isCosmeticType(cosmetic) then
                        return true
                    end
                    return nil
                end
            })
        end
        
        if key == "FavoritedCosmetics" then
            local result = value and table.clone(value) or {}
            for weapon, favorites in pairs(favoritedCosmetics) do
                result[weapon] = result[weapon] or {}
                for name, isFavorited in pairs(favorites) do
                    local cosmetic = CosmeticLibrary.Cosmetics[name]
                    if cosmetic and isCosmeticType(cosmetic) then
                        result[weapon][name] = isFavorited
                    end
                end
            end
            return result
        end
        
        return value
    end
    
    local originalGetWeapon = PlayerDataController.GetWeaponData
    
    PlayerDataController.GetWeaponData = function(self, weaponName)
        local data = originalGetWeapon(self, weaponName)
        if not data then return nil end
        
        local merged = {}
        for k, v in pairs(data) do
            merged[k] = v
        end
        merged.Name = weaponName
        
        if equippedCosmetics[weaponName] then
            for cosType, cosmetic in pairs(equippedCosmetics[weaponName]) do
                merged[cosType] = cosmetic
            end
        end
        
        return merged
    end
end

-- Patch remote events
local function patchRemotes()
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not remotes then return end
    
    local dataRemote = remotes:FindFirstChild("Data")
    local equipRemote = dataRemote and dataRemote:FindFirstChild("EquipCosmetic")
    local favoriteRemote = dataRemote and dataRemote:FindFirstChild("FavoriteCosmetic")
    local replicationRemote = remotes:FindFirstChild("Replication")
    local fighterRemote = replicationRemote and replicationRemote:FindFirstChild("Fighter")
    local useItemRemote = fighterRemote and fighterRemote:FindFirstChild("UseItem")
    local finisherRemote = dataRemote and dataRemote:FindFirstChild("EquipFinisher")
    
    if not equipRemote then return end
    
    local originalMethod
    originalMethod = hookmetamethod(game, "__namecall", function(self, ...)
        if getnamecallmethod() ~= "FireServer" then
            return originalMethod(self, ...)
        end
        
        local args = {...}
        
        -- Handle UseItem
        if useItemRemote and self == useItemRemote then
            local objectId = args[1]
            if FighterController and LocalPlayer then
                pcall(function()
                    local fighter = FighterController:GetFighter(LocalPlayer)
                    if fighter and fighter.Items then
                        for _, item in pairs(fighter.Items) do
                            if item:Get("ObjectID") == objectId then
                                currentWeapon = item.Name
                                break
                            end
                        end
                    end
                end)
            end
        end
        
        -- Handle EquipCosmetic
        if self == equipRemote then
            local weaponName = args[1]
            local cosType = args[2]
            local cosName = args[3]
            local options = args[4] or {}
            
            -- Special handling for finishers
            if cosType == "Finisher" or cosType == "Execution" then
                if cosName and cosName ~= "None" and cosName ~= "" then
                    equippedCosmetics[weaponName] = equippedCosmetics[weaponName] or {}
                    local cloned = createCosmetic(cosName, cosType, {
                        inverted = options.IsInverted,
                        favoritesOnly = options.OnlyUseFavorites
                    })
                    if cloned then
                        equippedCosmetics[weaponName][cosType] = cloned
                        selectedFinisher = cosName
                        print("[SkinChanger] Finisher equipped:", cosName, "for", weaponName)
                        -- Force inject immediately
                        forceFinisherDetection()
                    end
                else
                    if equippedCosmetics[weaponName] then
                        equippedCosmetics[weaponName][cosType] = nil
                        if not next(equippedCosmetics[weaponName]) then
                            equippedCosmetics[weaponName] = nil
                        end
                    end
                end
                saveConfig()
                return
            end
            
            if cosName and cosName ~= "None" and cosName ~= "" then
                local inventory = PlayerDataController:Get("CosmeticInventory")
                if inventory and rawget(inventory, cosName) then
                    return originalMethod(self, ...)
                end
            end
            
            equippedCosmetics[weaponName] = equippedCosmetics[weaponName] or {}
            
            if not cosName or cosName == "None" or cosName == "" then
                equippedCosmetics[weaponName][cosType] = nil
                if not next(equippedCosmetics[weaponName]) then
                    equippedCosmetics[weaponName] = nil
                end
            else
                local cloned = createCosmetic(cosName, cosType, {
                    inverted = options.IsInverted,
                    favoritesOnly = options.OnlyUseFavorites
                })
                if cloned then
                    equippedCosmetics[weaponName][cosType] = cloned
                end
            end
            
            task.defer(function()
                pcall(function()
                    if PlayerDataController and PlayerDataController.CurrentData then
                        PlayerDataController.CurrentData:Replicate("WeaponInventory")
                    end
                end)
            end)
            
            saveConfig()
            return
        end
        
        -- Handle separate finisher remote
        if finisherRemote and self == finisherRemote then
            local weaponName = args[1]
            local finisherName = args[2]
            
            if finisherName and finisherName ~= "None" and finisherName ~= "" then
                equippedCosmetics[weaponName] = equippedCosmetics[weaponName] or {}
                local cloned = createCosmetic(finisherName, "Finisher", {})
                if cloned then
                    equippedCosmetics[weaponName].Finisher = cloned
                    selectedFinisher = finisherName
                    print("[SkinChanger] Finisher equipped via remote:", finisherName)
                    forceFinisherDetection()
                end
            else
                if equippedCosmetics[weaponName] then
                    equippedCosmetics[weaponName].Finisher = nil
                end
            end
            saveConfig()
            return
        end
        
        -- Handle FavoriteCosmetic
        if self == favoriteRemote then
            local cosmetic = CosmeticLibrary.Cosmetics[args[2]]
            if cosmetic then
                favoritedCosmetics[args[1]] = favoritedCosmetics[args[1]] or {}
                favoritedCosmetics[args[1]][args[2]] = args[3] or nil
                
                task.spawn(function()
                    pcall(function()
                        if PlayerDataController and PlayerDataController.CurrentData then
                            PlayerDataController.CurrentData:Replicate("FavoritedCosmetics")
                        end
                    end)
                end)
                
                saveConfig()
            end
            return
        end
        
        return originalMethod(self, ...)
    end)
end

-- Patch view model creation
local function patchViewModel()
    local clientItemModule = LocalPlayer.PlayerScripts:FindFirstChild("Modules")
        and LocalPlayer.PlayerScripts.Modules:FindFirstChild("ClientReplicatedClasses")
        and LocalPlayer.PlayerScripts.Modules.ClientReplicatedClasses:FindFirstChild("ClientFighter")
        and LocalPlayer.PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter:FindFirstChild("ClientItem")
    
    if not clientItemModule then return end
    
    local ClientItem = require(clientItemModule)
    
    if ClientItem and ClientItem._CreateViewModel then
        local originalCreateViewModel = ClientItem._CreateViewModel
        
        ClientItem._CreateViewModel = function(self, viewModelRef)
            local weaponName = self.Name
            local weaponPlayer = self.ClientFighter and self.ClientFighter.Player
            buildingWeapon = (weaponPlayer == LocalPlayer) and weaponName or nil
            
            if weaponPlayer == LocalPlayer and equippedCosmetics[weaponName] then
                local dataKey = self:ToEnum("Data")
                if viewModelRef[dataKey] then
                    if equippedCosmetics[weaponName].Skin then
                        viewModelRef[dataKey][self:ToEnum("Skin")] = equippedCosmetics[weaponName].Skin
                        viewModelRef[dataKey][self:ToEnum("Name")] = equippedCosmetics[weaponName].Skin.Name
                    end
                    if equippedCosmetics[weaponName].Charm then
                        viewModelRef[dataKey][self:ToEnum("Charm")] = equippedCosmetics[weaponName].Charm
                    end
                    if equippedCosmetics[weaponName].Wrap then
                        viewModelRef[dataKey][self:ToEnum("Wrap")] = equippedCosmetics[weaponName].Wrap
                    end
                elseif viewModelRef.Data then
                    if equippedCosmetics[weaponName].Skin then
                        viewModelRef.Data.Skin = equippedCosmetics[weaponName].Skin
                        viewModelRef.Data.Name = equippedCosmetics[weaponName].Skin.Name
                    end
                    if equippedCosmetics[weaponName].Charm then
                        viewModelRef.Data.Charm = equippedCosmetics[weaponName].Charm
                    end
                    if equippedCosmetics[weaponName].Wrap then
                        viewModelRef.Data.Wrap = equippedCosmetics[weaponName].Wrap
                    end
                end
            end
            
            local result = originalCreateViewModel(self, viewModelRef)
            buildingWeapon = nil
            return result
        end
    end
    
    -- Patch ClientViewModel
    local viewModelModule = clientItemModule:FindFirstChild("ClientViewModel")
    if viewModelModule then
        local ClientViewModel = require(viewModelModule)
        local originalNew = ClientViewModel.new
        
        ClientViewModel.new = function(repData, clientItem)
            local weaponPlayer = clientItem.ClientFighter and clientItem.ClientFighter.Player
            local weaponName = buildingWeapon or clientItem.Name
            
            if weaponPlayer == LocalPlayer and equippedCosmetics[weaponName] then
                local ReplicatedClass = require(ReplicatedStorage.Modules.ReplicatedClass)
                local dataKey = ReplicatedClass:ToEnum("Data")
                repData[dataKey] = repData[dataKey] or {}
                
                local cosmetics = equippedCosmetics[weaponName]
                if cosmetics.Skin then
                    repData[dataKey][ReplicatedClass:ToEnum("Skin")] = cosmetics.Skin
                end
                if cosmetics.Charm then
                    repData[dataKey][ReplicatedClass:ToEnum("Charm")] = cosmetics.Charm
                end
                if cosmetics.Wrap then
                    repData[dataKey][ReplicatedClass:ToEnum("Wrap")] = cosmetics.Wrap
                end
            end
            
            return originalNew(repData, clientItem)
        end
    end
end

-- Helper function to check cosmetic type
local function isCosmeticType(cosmetic)
    if not cosmetic then return false end
    for _, typeName in ipairs(COSMETIC_TYPES) do
        if cosmetic.Type == typeName then return true end
    end
    return false
end

-- Main initialization
local function initialize()
    if initialized then return end
    
    -- Wait for required services
    repeat
        task.wait()
    until ReplicatedStorage:FindFirstChild("Modules") and LocalPlayer.PlayerScripts:FindFirstChild("Controllers")
    
    if not initializeModules() then
        warn("Failed to initialize modules, retrying...")
        task.wait(1)
        return initialize()
    end
    
    -- Load configuration
    loadConfig()
    
    -- Apply patches
    patchCosmeticLibrary()
    patchPlayerDataController()
    patchRemotes()
    patchViewModel()
    
    -- Force finisher detection
    task.wait(2) -- Wait for game to fully load
    forceFinisherDetection()
    startFinisherMonitor()
    
    initialized = true
    print("[SkinChanger] ========================================")
    print("[SkinChanger] Initialized successfully!")
    print("[SkinChanger] Finisher detection forced!")
    print("[SkinChanger] ========================================")
    
    -- Show current finisher status
    task.wait(1)
    local weapon = currentWeapon or "Global"
    local finisher = equippedCosmetics[weapon] and equippedCosmetics[weapon].Finisher
    if finisher then
        print("[SkinChanger] Currently equipped finisher:", finisher.Name)
    else
        local globalFinisher = equippedCosmetics["Global"] and equippedCosmetics["Global"].Finisher
        if globalFinisher then
            print("[SkinChanger] Global finisher equipped:", globalFinisher.Name)
        else
            print("[SkinChanger] No finisher equipped. Equip one from the menu!")
        end
    end
    
    -- Setup hotkeys
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        -- RightShift to save config
        if input.KeyCode == Enum.KeyCode.RightShift then
            print("[SkinChanger] Config saved!")
            saveConfig()
        end
        
        -- F to show current finisher status
        if input.KeyCode == Enum.KeyCode.F then
            local weapon = currentWeapon or "Global"
            local finisher = equippedCosmetics[weapon] and equippedCosmetics[weapon].Finisher
            if finisher then
                print("[SkinChanger] Current finisher for", weapon, ":", finisher.Name)
                -- Force inject again
                forceFinisherDetection()
                print("[SkinChanger] Finisher re-injected!")
            else
                print("[SkinChanger] No finisher equipped for", weapon)
                -- Check global
                local globalFinisher = equippedCosmetics["Global"] and equippedCosmetics["Global"].Finisher
                if globalFinisher then
                    print("[SkinChanger] Global finisher:", globalFinisher.Name)
                end
            end
        end
        
        -- G to force apply finisher to current weapon
        if input.KeyCode == Enum.KeyCode.G then
            print("[SkinChanger] Force applying finisher...")
            forceFinisherDetection()
            print("[SkinChanger] Done!")
        end
    end)
end

-- Start the script
task.spawn(initialize)

-- Return API
return {
    getEquipped = function() return equippedCosmetics end,
    getFavorites = function() return favoritedCosmetics end,
    saveConfig = saveConfig,
    loadConfig = loadConfig,
    setCosmetic = function(weapon, cosType, cosName, options)
        equippedCosmetics[weapon] = equippedCosmetics[weapon] or {}
        local cloned = createCosmetic(cosName, cosType, options)
        if cloned then
            equippedCosmetics[weapon][cosType] = cloned
            saveConfig()
            if cosType == "Finisher" or cosType == "Execution" then
                forceFinisherDetection()
            end
            return true
        end
        return false
    end,
    removeCosmetic = function(weapon, cosType)
        if equippedCosmetics[weapon] then
            equippedCosmetics[weapon][cosType] = nil
            if not next(equippedCosmetics[weapon]) then
                equippedCosmetics[weapon] = nil
            end
            saveConfig()
            return true
        end
        return false
    end,
    setFinisher = function(weapon, finisherName)
        local result = setCosmetic(weapon, "Finisher", finisherName)
        if result then
            forceFinisherDetection()
        end
        return result
    end,
    forceFinisher = forceFinisherDetection
}
