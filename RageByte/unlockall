-- Initialize modules with proper error handling
local function initializeModules()
    local success, err = pcall(function()
        if Modules then
            EnumLibrary = require(Modules:WaitForChild("EnumLibrary", 5))
            CosmeticLibrary = require(Modules:WaitForChild("CosmeticLibrary", 5))
            ItemLibrary = require(Modules:WaitForChild("ItemLibrary", 5))
        end
        
        if Controllers then
            PlayerDataController = require(Controllers:WaitForChild("PlayerDataController", 5))
            FighterController = require(Controllers:FindFirstChild("FighterController") or Controllers:WaitForChild("FighterController", 5))
        end
        
        if EnumLibrary and EnumLibrary.WaitForEnumBuilder then
            EnumLibrary:WaitForEnumBuilder()
        end
    end)
    
    if not success then
        warn("Failed to initialize modules:", err)
        return false
    end
    return true
end

-- Cosmetic creation helper
local function createCosmetic(name, cosmeticType, options)
    if not CosmeticLibrary or not CosmeticLibrary.Cosmetics then
        return nil
    end
    
    local base = CosmeticLibrary.Cosmetics[name]
    if not base then return nil end
    
    local cosmetic = {}
    for k, v in pairs(base) do
        cosmetic[k] = v
    end
    
    cosmetic.Name = name
    cosmetic.Type = cosmetic.Type or cosmeticType
    cosmetic.Seed = cosmetic.Seed or math.random(1, 1000000)
    
    if EnumLibrary and EnumLibrary.ToEnum then
        local success, enumId = pcall(EnumLibrary.ToEnum, EnumLibrary, name)
        if success and enumId then
            cosmetic.Enum = enumId
            cosmetic.ObjectID = cosmetic.ObjectID or enumId
        end
    end
    
    if options then
        if options.inverted ~= nil then cosmetic.Inverted = options.inverted end
        if options.favoritesOnly ~= nil then cosmetic.OnlyUseFavorites = options.favoritesOnly end
    end
    
    return cosmetic
end

-- Configuration management
local function stripForSave()
    local data = {
        equipped = {},
        favorites = {}
    }
    
    for weaponName, cosmetics in pairs(equippedCosmetics) do
        data.equipped[weaponName] = {}
        for cosType, cosmetic in pairs(cosmetics) do
            if cosmetic and cosmetic.Name then
                data.equipped[weaponName][cosType] = {
                    Name = cosmetic.Name,
                    Inverted = cosmetic.Inverted,
                    OnlyUseFavorites = cosmetic.OnlyUseFavorites
                }
            end
        end
    end
    
    data.favorites = favoritedCosmetics
    return data
end

local function loadConfig()
    if not isfile or not readfile then return end
    
    local success, exists = pcall(isfile, CONFIG_FILE)
    if not success or not exists then return end
    
    local success, raw = pcall(readfile, CONFIG_FILE)
    if not success or not raw or raw == "" then return end
    
    local success, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
    if not success or not decoded then return end
    
    if decoded.favorites then
        favoritedCosmetics = decoded.favorites
    end
    
    if decoded.equipped then
        equippedCosmetics = {}
        for weaponName, cosmetics in pairs(decoded.equipped) do
            equippedCosmetics[weaponName] = {}
            for cosType, saveData in pairs(cosmetics) do
                if saveData and saveData.Name then
                    if CosmeticLibrary.Cosmetics[saveData.Name] then
                        local cloned = createCosmetic(saveData.Name, cosType, {
                            inverted = saveData.Inverted,
                            favoritesOnly = saveData.OnlyUseFavorites
                        })
                        if cloned then
                            equippedCosmetics[weaponName][cosType] = cloned
                        end
                    end
                end
            end
            if not next(equippedCosmetics[weaponName]) then
                equippedCosmetics[weaponName] = nil
            end
        end
    end
end

local function saveConfig()
    if not writefile or saveLock then return end
    saveLock = true
    
    task.spawn(function()
        task.wait(SAVE_DELAY)
        local data = stripForSave()
        local success, encoded = pcall(HttpService.JSONEncode, HttpService, data)
        if success then
            pcall(writefile, CONFIG_FILE, encoded)
        end
        saveLock = false
    end)
end

-- CRITICAL: Force finisher detection
local function forceFinisherDetection()
    -- Get the current finisher for the weapon
    local function getCurrentFinisher(weaponName)
        weaponName = weaponName or "Global"
        -- Check specific weapon
        if equippedCosmetics[weaponName] and equippedCosmetics[weaponName].Finisher then
            return equippedCosmetics[weaponName].Finisher
        end
        -- Check global finisher
        if equippedCosmetics["Global"] and equippedCosmetics["Global"].Finisher then
            return equippedCosmetics["Global"].Finisher
        end
        -- Check any weapon with finisher
        for _, cos in pairs(equippedCosmetics) do
            if cos.Finisher then
                return cos.Finisher
            end
        end
        return nil
    end
    
    -- Get the fighter object
    local function getFighter()
        local success, fighter = pcall(FighterController.GetFighter, FighterController, LocalPlayer)
        if success and fighter then
            return fighter
        end
        return nil
    end
    
    -- METHOD 1: Directly set finisher on all possible locations
    local function directFinisherInjection()
        local fighter = getFighter()
        if not fighter then return false end
        
        local finisher = getCurrentFinisher()
        if not finisher then return false end
        
        print("[SkinChanger] Directly injecting finisher:", finisher.Name)
        
        -- Try every possible property name
        local propertyNames = {
            "Finisher", "EquippedFinisher", "CurrentFinisher", "SelectedFinisher",
            "Execution", "EquippedExecution", "FinisherCosmetic", "ExecutionCosmetic"
        }
        
        local injected = false
        for _, propName in ipairs(propertyNames) do
            if fighter[propName] ~= nil then
                fighter[propName] = finisher
                injected = true
            end
        end
        
        -- Also try setting on fighter's Data
        if fighter.Data then
            fighter.Data.Finisher = finisher
            fighter.Data.EquippedFinisher = finisher
        end
        
        -- Try setting on fighter's CurrentWeapon
        if fighter.CurrentWeapon then
            fighter.CurrentWeapon.Finisher = finisher
        end
        
        return injected
    end
    
    -- METHOD 2: Hook the GetFinisher function
    local function hookGetFinisher()
        local fighter = getFighter()
        if not fighter then return false end
        
        -- Hook GetFinisher method
        if fighter.GetFinisher then
            local original = fighter.GetFinisher
            fighter.GetFinisher = function(self)
                local weapon = currentWeapon or "Global"
                local finisher = getCurrentFinisher(weapon)
                if finisher then
                    return finisher
                end
                return original(self)
            end
            print("[SkinChanger] Hooked GetFinisher method")
            return true
        end
        return false
    end
    
    -- METHOD 3: Hook __index to intercept finisher requests
    local function hookIndex()
        local fighter = getFighter()
        if not fighter then return false end
        
        local mt = getmetatable(fighter)
        if not mt then return false end
        
        local originalIndex = mt.__index
        mt.__index = function(table, key)
            if key == "Finisher" or key == "EquippedFinisher" or key == "CurrentFinisher" then
                local weapon = currentWeapon or "Global"
                local finisher = getCurrentFinisher(weapon)
                if finisher then
                    return finisher
                end
            end
            if originalIndex then
                return originalIndex(table, key)
            end
            return nil
        end
        print("[SkinChanger] Hooked fighter __index")
        return true
    end
    
    -- METHOD 4: Scan and patch all finisher-related functions
    local function scanAndPatch()
        local fighter = getFighter()
        if not fighter then return false end
        
        local patched = false
        for key, value in pairs(fighter) do
            if type(value) == "function" then
                local keyLower = key:lower()
                if keyLower:find("finish") or keyLower:find("execut") or keyLower:find("elimin") then
                    print("[SkinChanger] Found finisher function:", key)
                    local original = value
                    fighter[key] = function(self, ...)
                        local weapon = currentWeapon or "Global"
                        local finisher = getCurrentFinisher(weapon)
                        if finisher then
                            self.Finisher = finisher
                            self.EquippedFinisher = finisher
                        end
                        return original(self, ...)
                    end
                    patched = true
                end
            end
        end
        return patched
    end
    
    -- METHOD 5: Monitor execution requests from remotes
    local function monitorExecutionRemotes()
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if not remotes then return false end
        
        local replication = remotes:FindFirstChild("Replication")
        if not replication then return false end
        
        local fighterRemote = replication:FindFirstChild("Fighter")
        if not fighterRemote then return false end
        
        local patched = false
        for _, child in ipairs(fighterRemote:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                local name = child.Name:lower()
                if name:find("finish") or name:find("execut") or name:find("elimin") or name:find("kill") then
                    print("[SkinChanger] Found execution remote:", child.Name)
                    
                    if child:IsA("RemoteEvent") then
                        local originalFire = child.FireServer
                        child.FireServer = function(self, ...)
                            local args = {...}
                            local weapon = currentWeapon or "Global"
                            local finisher = getCurrentFinisher(weapon)
                            
                            if finisher then
                                print("[SkinChanger] Intercepted execution remote, injecting finisher:", finisher.Name)
                                -- Try to inject finisher into args
                                if #args > 0 and type(args[1]) == "table" then
                                    args[1].Finisher = finisher
                                    args[1].EquippedFinisher = finisher
                                end
                                -- Also try to set as separate argument
                                table.insert(args, finisher)
                            end
                            
                            return originalFire(self, table.unpack(args))
                        end
                        patched = true
                    elseif child:IsA("RemoteFunction") then
                        local originalInvoke = child.InvokeServer
                        child.InvokeServer = function(self, ...)
                            local args = {...}
                            local weapon = currentWeapon or "Global"
                            local finisher = getCurrentFinisher(weapon)
                            
                            if finisher then
                                print("[SkinChanger] Intercepted execution remote function, injecting finisher:", finisher.Name)
                                if #args > 0 and type(args[1]) == "table" then
                                    args[1].Finisher = finisher
                                    args[1].EquippedFinisher = finisher
                                end
                                table.insert(args, finisher)
                            end
                            
                            return originalInvoke(self, table.unpack(args))
                        end
                        patched = true
                    end
                end
            end
        end
        return patched
    end
    
    -- Run all methods
    local methods = {
        directFinisherInjection,
        hookGetFinisher,
        hookIndex,
        scanAndPatch,
        monitorExecutionRemotes
    }
    
    local success = false
    for _, method in ipairs(methods) do
        local result = method()
        if result then
            success = true
        end
    end
    
    return success
end

