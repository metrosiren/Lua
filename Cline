        Btn.BackgroundColor3 = T.SurfaceAlt
        Btn.BorderSizePixel  = 0
        Btn.Text             = ""
        Btn.ZIndex           = 4
        Btn.Parent           = TabBtnHolder
        U.Corner(Btn, 8)

        local BtnLbl = Instance.new("TextLabel")
        BtnLbl.Size                  = UDim2.new(1,0,1,0)
        BtnLbl.BackgroundTransparency = 1
        BtnLbl.Text                  = tc.Icon ~= "" and tc.Icon or tc.Title:sub(1,2)
        BtnLbl.TextColor3            = T.TextSub
        BtnLbl.TextSize              = tc.Icon ~= "" and 17 or 11
        BtnLbl.Font                  = Enum.Font.GothamBold
        BtnLbl.ZIndex                = 5
        BtnLbl.Parent                = Btn

        -- tooltip
        local Tip = Instance.new("Frame")
