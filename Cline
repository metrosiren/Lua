local ClineUI = {}
ClineUI.__index = ClineUI
ClineUI.Flags   = {}    -- global flag store
ClineUI.Themes  = Themes

-- Destroy all windows (call before re-executing)
function ClineUI:Destroy()
    for _, g in ipairs(CoreGui:GetChildren()) do
        if g.Name:sub(1, 8) == "ClineUI_" then g:Destroy() end
    end
    self.Flags = {}
end

