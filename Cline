local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

-- [ CONFIGURATION & KEY VARIABLES ] --
local Cline = {
    Themes = {
        Dark = {
            Background = Color3.fromRGB(24, 24, 26),
            Sidebar = Color3.fromRGB(32, 32, 35),
            CardBG = Color3.fromRGB(30, 30, 33),
            Element = Color3.fromRGB(24, 24, 26),
            Accent = Color3.fromRGB(95, 172, 255),
            Text = Color3.fromRGB(245, 245, 245),
            SubText = Color3.fromRGB(140, 140, 140),
            Border = Color3.fromRGB(45, 45, 48),
            SearchBG = Color3.fromRGB(35, 35, 38),
            Success = Color3.fromRGB(46, 204, 113),
            Error = Color3.fromRGB(231, 76, 60)
        }
    },
    CurrentTheme = "Dark",
    ConfigFolder = "Cline_Configs",
    CurrentConfig = "default.json",
    SavedStates = {},
    Registry = {},
    Toggled = true,
    ToggleKey = Enum.KeyCode.RightShift,
    NotificationsContainer = nil
}

local Theme = Cline.Themes[Cline.CurrentTheme]

-- [ INTERIOR UTILITIES ] --
local function Create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties) do inst[k] = v end
    return inst
end

local function Tween(instance, properties, duration)
    local tween = TweenService:Create(instance, TweenInfo.new(duration or 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), properties)
    tween:Play()
    return tween
end

local function MakeDraggable(dragHandle, object)
    local dragging, dragInput, dragStart, startPos
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = object.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Tween(object, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.08)
        end
    end)
end

-- [ CONFIGURATION STORAGE ENGINE ] --
local function SaveConfig()
    if writefile then
        pcall(function()
            if not isfolder(Cline.ConfigFolder) then makefolder(Cline.ConfigFolder) end
            writefile(Cline.ConfigFolder .. "/" .. Cline.CurrentConfig, HttpService:JSONEncode(Cline.SavedStates))
        end)
    end
end

local function LoadConfig(callbackMap)
    if readfile then
        pcall(function()
            local path = Cline.ConfigFolder .. "/" .. Cline.CurrentConfig
            if isfile(path) then
                local data = HttpService:JSONDecode(readfile(path))
                for k, v in pairs(data) do
                    Cline.SavedStates[k] = v
                    if callbackMap[k] then task.spawn(callbackMap[k], v) end
                end
            end
        end)
    end
end

-- [ MAIN ENGINE INITIALIZATION ] --
function Cline:CreateWindow(options)
    options = options or {}
    
    if CoreGui:FindFirstChild("ClineExactUI") then CoreGui.ClineExactUI:Destroy() end

    local ScreenGui = Create("ScreenGui", { Name = "ClineExactUI", Parent = CoreGui, ResetOnSpawn = false })
    
    local MainFrame = Create("CanvasGroup", {
        Name = "Main", Parent = ScreenGui, BackgroundColor3 = Theme.Background,
        Position = UDim2.new(0.5, -400, 0.5, -275), Size = UDim2.new(0, 800, 0, 550), 
        ClipsDescendants = true, GroupTransparency = 0
    })
    Create("UICorner", { Parent = MainFrame, CornerRadius = UDim.new(0, 12) })
    Create("UIStroke", { Parent = MainFrame, Color = Theme.Border, Thickness = 1 })

    local Sidebar = Create("Frame", {
        Name = "Sidebar", Parent = MainFrame, BackgroundColor3 = Theme.Sidebar, Size = UDim2.new(0, 75, 1, 0), BorderSizePixel = 0
    })
    
    local TabContainer = Create("Frame", {
        Parent = Sidebar, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, -160), Position = UDim2.new(0, 0, 0, 40)
    })
    Create("UIListLayout", { Parent = TabContainer, HorizontalAlignment = Enum.HorizontalAlignment.Center, Padding = UDim.new(0, 12) })

    local ContentArea = Create("Frame", {
        Parent = MainFrame, BackgroundTransparency = 1, Position = UDim2.new(0, 75, 0, 0), Size = UDim2.new(1, -75, 1, 0)
    })

    MakeDraggable(Sidebar, MainFrame)

    function Cline:SetVisible(state)
        Cline.Toggled = state
        Tween(MainFrame, { GroupTransparency = state and 0 or 1 }, 0.2)
        MainFrame.BlocksDescendantsButtonClicks = not state
    end

    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Cline.ToggleKey then
            Cline:SetVisible(not Cline.Toggled)
        end
    end)

    local WindowInstance = { CallbackRegistry = {} }

    function WindowInstance:CreateTab(tabName, iconAsset)
        iconAsset = iconAsset or "rbxassetid://6026568198"
        
        local TabBtn = Create("TextButton", {
            Parent = TabContainer, BackgroundTransparency = 1, Size = UDim2.new(0, 42, 0, 42), Text = "", AutoButtonColor = false
        })
        Create("UICorner", { Parent = TabBtn, CornerRadius = UDim.new(1, 0) })
        local TabIcon = Create("ImageLabel", {
            Parent = TabBtn, BackgroundTransparency = 1, Size = UDim2.new(0, 20, 0, 20), Position = UDim2.new(0.5, -10, 0.5, -10),
            Image = iconAsset, ImageColor3 = Theme.SubText
        })

        local TabPage = Create("Frame", {
            Parent = ContentArea, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Visible = false
        })

        local Header = Create("Frame", { Parent = TabPage, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 75) })
        Create("TextLabel", {
            Parent = Header, BackgroundTransparency = 1, Position = UDim2.new(0, 30, 0, 30), Size = UDim2.new(0, 200, 0, 30),
            Font = Enum.Font.GothamBold, Text = tabName, TextColor3 = Theme.Text, TextSize = 22, TextXAlignment = Enum.TextXAlignment.Left
        })

        local MainScroll = Create("ScrollingFrame", {
            Parent = TabPage, BackgroundTransparency = 1, Position = UDim2.new(0, 30, 0, 75), Size = UDim2.new(1, -60, 1, -95),
            ScrollBarThickness = 0, CanvasSize = UDim2.new(0, 0, 0, 0)
        })
        local GridPairs = Create("UIListLayout", { Parent = MainScroll, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 15) })
        
        GridPairs:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            MainScroll.CanvasSize = UDim2.new(0, 0, 0, GridPairs.AbsoluteContentSize.Y + 20)
        end)

        TabBtn.MouseButton1Click:Connect(function()
            for _, page in pairs(ContentArea:GetChildren()) do if page:IsA("Frame") then page.Visible = false end end
            for _, btn in pairs(TabContainer:GetChildren()) do
                if btn:IsA("TextButton") then
                    Tween(btn, { BackgroundColor3 = Theme.Sidebar })
                    Tween(btn.ImageLabel, { ImageColor3 = Theme.SubText })
                end
            end
            TabPage.Visible = true
            Tween(TabBtn, { BackgroundColor3 = Theme.Accent })
            Tween(TabIcon, { ImageColor3 = Color3.fromRGB(255, 255, 255) })
        end)

        if not WindowInstance.ActiveTab then
            TabPage.Visible = true
            TabBtn.BackgroundColor3 = Theme.Accent
            TabIcon.ImageColor3 = Color3.fromRGB(255, 255, 255)
            WindowInstance.ActiveTab = tabName
        end

        local SectionEngine = {}

        function SectionEngine:CreateSection(sectionTitle)
            local CardFrame = Create("Frame", {
                Parent = MainScroll, BackgroundColor3 = Theme.CardBG, Size = UDim2.new(1, 0, 0, 45)
            })
            Create("UICorner", { Parent = CardFrame, CornerRadius = UDim.new(0, 8) })
            local CardStroke = Create("UIStroke", { Parent = CardFrame, Color = Theme.Border, Thickness = 1 })
            
            local ItemsContainer = Create("Frame", {
                Parent = CardFrame, BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 35), Size = UDim2.new(1, 0, 1, -35)
            })
            local ItemsLayout = Create("UIListLayout", { Parent = ItemsContainer, SortOrder = Enum.SortOrder.LayoutOrder })

            Create("TextLabel", {
                Parent = CardFrame, BackgroundTransparency = 1, Position = UDim2.new(0, 16, 0, 10), Size = UDim2.new(1, -32, 0, 20),
                Font = Enum.Font.GothamBold, Text = string.upper(sectionTitle), TextColor3 = Theme.Accent, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left
            })

            ItemsLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                CardFrame.Size = UDim2.new(1, 0, 0, ItemsLayout.AbsoluteContentSize.Y + 45)
            end)

            local Interactives = {}

            function Interactives:CreateToggle(toggleName, default, callback)
                local state = default or false
                local Row = Create("Frame", { Parent = ItemsContainer, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 45) })

                local Title = Create("TextLabel", {
                    Parent = Row, BackgroundTransparency = 1, Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(1, -80, 1, 0),
                    Font = Enum.Font.GothamMedium, Text = toggleName, TextColor3 = Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
                })

                local Switch = Create("TextButton", {
                    Parent = Row, BackgroundColor3 = state and Theme.Accent or Theme.Element, Position = UDim2.new(1, -56, 0.5, -10),
                    Size = UDim2.new(0, 40, 0, 20), Text = "", AutoButtonColor = false
                })
                Create("UICorner", { Parent = Switch, CornerRadius = UDim.new(1, 0) })
                Create("UIStroke", { Parent = Switch, Color = Theme.Border, Thickness = 1 })
                
                local InnerNode = Create("Frame", {
                    Parent = Switch, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
                    Size = UDim2.new(0, 16, 0, 16)
                })
                Create("UICorner", { Parent = InnerNode, CornerRadius = UDim.new(1, 0) })

                Switch.MouseButton1Click:Connect(function()
                    state = not state
                    Tween(Switch, { BackgroundColor3 = state and Theme.Accent or Theme.Element })
                    Tween(InnerNode, { Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8) })
                    callback(state)
                    SaveConfig()
                end)
            end

            return Interactives
        end

        return SectionEngine
    end

    WindowInstance.LoadSavedConfig = function() LoadConfig(WindowInstance.CallbackRegistry) end

    return WindowInstance


return Cline
