local Theme = Cline.Themes[Cline.CurrentTheme]

-- [ Utility ] --
local function Create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties) do inst[k] = v end
    return inst
end

local function Tween(instance, properties, duration)
    local tween = TweenService:Create(instance, TweenInfo.new(duration or 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), properties)
    tween:Play()
    return tween
end

local function MakeDraggable(dragHandle, object)
    local dragging, dragInput, dragStart, startPos
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = object.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Tween(object, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.08)
        end
    end)
end

-- [ Core UI Generation ] --
function Cline:CreateWindow(options)
    options = options or {}
    
    if CoreGui:FindFirstChild("ClineExactUI") then
        CoreGui.ClineExactUI:Destroy()
    end

    local ScreenGui = Create("ScreenGui", { Name = "ClineExactUI", Parent = CoreGui, ResetOnSpawn = false })

    -- Main Container
    local MainFrame = Create("Frame", {
        Name = "MainFrame", Parent = ScreenGui, BackgroundColor3 = Theme.Background,
        Position = UDim2.new(0.5, -400, 0.5, -275), Size = UDim2.new(0, 800, 0, 550), ClipsDescendants = true
    })
    Create("UICorner", { Parent = MainFrame, CornerRadius = UDim.new(0, 10) })
    
    -- Subtle Drop Shadow Outline (Simulated)
    Create("UIStroke", { Parent = MainFrame, Color = Theme.Border, Thickness = 1, Transparency = 0.5 })

    -- Sidebar (Icon Based like Image 1)
    local Sidebar = Create("Frame", {
        Name = "Sidebar", Parent = MainFrame, BackgroundColor3 = Theme.Sidebar,
        Size = UDim2.new(0, 70, 1, 0), BorderSizePixel = 0
    })
    
    -- Sidebar Separator
    Create("Frame", {
        Parent = Sidebar, BackgroundColor3 = Theme.Border, Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(1, 0, 0, 0), BorderSizePixel = 0
    })

    local TabContainer = Create("Frame", {
        Parent = Sidebar, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, -100), Position = UDim2.new(0, 0, 0, 80)
    })
    Create("UIListLayout", { Parent = TabContainer, HorizontalAlignment = Enum.HorizontalAlignment.Center, Padding = UDim.new(0, 15) })

    local ContentArea = Create("Frame", {
        Parent = MainFrame, BackgroundTransparency = 1, Position = UDim2.new(0, 70, 0, 0), Size = UDim2.new(1, -70, 1, 0)
    })

    MakeDraggable(Sidebar, MainFrame)
    MakeDraggable(ContentArea, MainFrame)

    local Window = { CurrentTab = nil, Tabs = {} }

    -- [ Tab System ] --
    function Window:CreateTab(options)
        local Title = options.Name or "Tab"
        local IconAsset = options.Icon or "rbxassetid://6026568198" -- Default Eye Icon

        local TabBtn = Create("TextButton", {
            Parent = TabContainer, BackgroundTransparency = 1, Size = UDim2.new(0, 44, 0, 44), Text = "", AutoButtonColor = false
        })
        local BtnCorner = Create("UICorner", { Parent = TabBtn, CornerRadius = UDim.new(1, 0) }) -- Perfect Circle
        
        local Icon = Create("ImageLabel", {
            Parent = TabBtn, BackgroundTransparency = 1, Size = UDim2.new(0, 22, 0, 22),
            Position = UDim2.new(0.5, -11, 0.5, -11), Image = IconAsset, ImageColor3 = Theme.SubText
        })

        local TabContent = Create("Frame", {
            Parent = ContentArea, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Visible = false
        })

        -- Top Header (Title + Search)
        local Header = Create("Frame", {
            Parent = TabContent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 80)
        })
        
        local TabIcon = Create("ImageLabel", {
            Parent = Header, BackgroundTransparency = 1, Size = UDim2.new(0, 24, 0, 24),
            Position = UDim2.new(0, 30, 0, 35), Image = IconAsset, ImageColor3 = Theme.Text
        })

        Create("TextLabel", {
            Parent = Header, BackgroundTransparency = 1, Size = UDim2.new(0, 200, 0, 24), Position = UDim2.new(0, 65, 0, 35),
            Font = Enum.Font.GothamBold, Text = Title, TextColor3 = Theme.Text, TextSize = 22, TextXAlignment = Enum.TextXAlignment.Left
        })

        -- Search Bar (Image 1 Style)
        local SearchFrame = Create("Frame", {
            Parent = Header, BackgroundColor3 = Theme.SearchBG, Size = UDim2.new(0, 200, 0, 36), Position = UDim2.new(0.5, -50, 0, 29)
        })
        Create("UICorner", { Parent = SearchFrame, CornerRadius = UDim.new(0, 18) })
        Create("ImageLabel", {
            Parent = SearchFrame, BackgroundTransparency = 1, Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(0, 12, 0.5, -8),
            Image = "rbxassetid://6031154871", ImageColor3 = Theme.SubText
        })
        Create("TextBox", {
            Parent = SearchFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 1, 0), Position = UDim2.new(0, 35, 0, 0),
            Font = Enum.Font.Gotham, PlaceholderText = "Search", Text = "", TextColor3 = Theme.Text, PlaceholderColor3 = Theme.SubText,
            TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
        })

        -- Content Scroll
        local Scroll = Create("ScrollingFrame", {
            Parent = TabContent, BackgroundTransparency = 1, Size = UDim2.new(1, -60, 1, -90), Position = UDim2.new(0, 30, 0, 90),
            ScrollBarThickness = 2, ScrollBarImageColor3 = Theme.Border
        })
        local ListLayout = Create("UIListLayout", { Parent = Scroll, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2) })

        ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Scroll.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 20)
        end)

        TabBtn.MouseButton1Click:Connect(function()
            for _, child in pairs(ContentArea:GetChildren()) do child.Visible = false end
            for _, btn in pairs(TabContainer:GetChildren()) do
                if btn:IsA("TextButton") then
                    Tween(btn, {BackgroundColor3 = Theme.Sidebar})
                    Tween(btn.ImageLabel, {ImageColor3 = Theme.SubText})
                end
            end
            TabContent.Visible = true
            Tween(TabBtn, {BackgroundColor3 = Theme.Accent})
            Tween(Icon, {ImageColor3 = Color3.fromRGB(255,255,255)})
        end)

        local Elements = {}

        -- Sub-divider utility
        local function AddDivider()
            local div = Create("Frame", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 15) })
            Create("Frame", { Parent = div, BackgroundColor3 = Theme.Border, Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 0.5, 0), BorderSizePixel = 0 })
        end

        -- [ 1. Checkbox / Toggle (Image 1 Style) ]
        function Elements:CreateToggle(name, options, callback)
            local state = options.Default or false
            local HasColor = options.ColorPicker ~= nil

            local Container = Create("Frame", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 50) })
            AddDivider()

            -- Checkbox Square
            local CheckBox = Create("TextButton", {
                Parent = Container, BackgroundColor3 = state and Theme.Accent or Theme.Element,
                Size = UDim2.new(0, 20, 0, 20), Position = UDim2.new(0, 0, 0.5, -10), Text = "", AutoButtonColor = false
            })
            Create("UICorner", { Parent = CheckBox, CornerRadius = UDim.new(0, 6) })
            local CheckStroke = Create("UIStroke", { Parent = CheckBox, Color = state and Theme.Accent or Theme.Border, Thickness = 1 })
            
            local CheckMark = Create("ImageLabel", {
                Parent = CheckBox, BackgroundTransparency = 1, Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(0.5, -6, 0.5, -6),
                Image = "rbxassetid://6031094667", ImageColor3 = Color3.fromRGB(255,255,255), ImageTransparency = state and 0 or 1
            })

            Create("TextLabel", {
                Parent = Container, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 1, 0), Position = UDim2.new(0, 35, 0, 0),
                Font = Enum.Font.GothamMedium, Text = name, TextColor3 = Theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left
            })

            -- Color Picker Display (If requested)
            if HasColor then
                local colorHex = string.format("%02X%02X%02X", options.ColorPicker.R*255, options.ColorPicker.G*255, options.ColorPicker.B*255)
                local ColorDisplay = Create("Frame", {
                    Parent = Container, BackgroundTransparency = 1, Size = UDim2.new(0, 100, 1, 0), Position = UDim2.new(1, -120, 0, 0)
                })
                
                local ColorCircle = Create("Frame", {
                    Parent = ColorDisplay, BackgroundColor3 = options.ColorPicker, Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(0, 0, 0.5, -8)
                })
                Create("UICorner", { Parent = ColorCircle, CornerRadius = UDim.new(1, 0) })

                Create("ImageLabel", {
                    Parent = ColorDisplay, BackgroundTransparency = 1, Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(0, 25, 0.5, -7),
                    Image = "rbxassetid://6031232230", ImageColor3 = Theme.SubText -- Eyedropper icon approximation
                })

                Create("TextLabel", {
                    Parent = ColorDisplay, BackgroundTransparency = 1, Size = UDim2.new(0, 60, 1, 0), Position = UDim2.new(0, 45, 0, 0),
                    Font = Enum.Font.Gotham, Text = colorHex .. " 100%", TextColor3 = Theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left
                })
            end

            CheckBox.MouseButton1Click:Connect(function()
                state = not state
                Tween(CheckBox, {BackgroundColor3 = state and Theme.Accent or Theme.Element}, 0.15)
                Tween(CheckStroke, {Color = state and Theme.Accent or Theme.Border}, 0.15)
                Tween(CheckMark, {ImageTransparency = state and 0 or 1}, 0.15)
                callback(state)
            end)
        end

        -- [ 2. Slider (Image 1 Style) ]
        function Elements:CreateSlider(name, min, max, default, unit, callback)
            local val = default or min
            local Container = Create("Frame", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 50) })
            AddDivider()

            Create("TextLabel", {
                Parent = Container, BackgroundTransparency = 1, Size = UDim2.new(0, 150, 1, 0), Position = UDim2.new(0, 35, 0, 0),
                Font = Enum.Font.GothamMedium, Text = name, TextColor3 = Theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left
            })

            local ValueLabel = Create("TextLabel", {
                Parent = Container, BackgroundTransparency = 1, Size = UDim2.new(0, 80, 1, 0), Position = UDim2.new(1, -260, 0, 0),
                Font = Enum.Font.Gotham, Text = tostring(val) .. (unit or ""), TextColor3 = Theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right
            })

            local SliderTrack = Create("Frame", {
                Parent = Container, BackgroundColor3 = Theme.Border, Size = UDim2.new(0, 160, 0, 4), Position = UDim2.new(1, -160, 0.5, -2)
            })
            Create("UICorner", { Parent = SliderTrack, CornerRadius = UDim.new(1, 0) })

            local SliderFill = Create("Frame", {
                Parent = SliderTrack, BackgroundColor3 = Theme.Accent, Size = UDim2.new((val-min)/(max-min), 0, 1, 0)
            })
            Create("UICorner", { Parent = SliderFill, CornerRadius = UDim.new(1, 0) })

            -- Pill handle like image 1
            local SliderHandle = Create("Frame", {
                Parent = SliderFill, BackgroundColor3 = Theme.Accent, Size = UDim2.new(0, 160, 0, 12), Position = UDim2.new(1, -160, 0.5, -6)
            })
            Create("UICorner", { Parent = SliderHandle, CornerRadius = UDim.new(1, 0) })
            local HandleDot = Create("Frame", {
                Parent = SliderHandle, BackgroundColor3 = Theme.Background, Size = UDim2.new(0, 4, 0, 4), Position = UDim2.new(1, -8, 0.5, -2)
            })
            Create("UICorner", { Parent = HandleDot, CornerRadius = UDim.new(1, 0) })


            local Dragging = false
            SliderHandle.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local mousePos = UserInputService:GetMouseLocation().X
                    local relative = math.clamp((mousePos - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
                    val = math.floor(min + (max - min) * relative)
                    ValueLabel.Text = tostring(val) .. (unit or "")
                    
                    Tween(SliderFill, {Size = UDim2.new(relative, 0, 1, 0)}, 0.05)
                    Tween(SliderHandle, {Size = UDim2.new(0, math.max(16, relative * 160), 0, 12), Position = UDim2.new(1, -math.max(16, relative * 160), 0.5, -6)}, 0.05)
                    callback(val)
                end
            end)
        end

        return Elements
    end

    -- Initial Tab Setup
    if #Window.Tabs > 0 then
        -- Handle first tab auto-click if desired
    end

    return Window
end

return Cline
