            Background = Color3.fromRGB(24, 24, 26),      -- Main Body
            Sidebar = Color3.fromRGB(32, 32, 35),         -- Left Panel
            Topbar = Color3.fromRGB(24, 24, 26),          -- Top Header
            Element = Color3.fromRGB(24, 24, 26),         -- Transparent backgrounds
            Accent = Color3.fromRGB(95, 172, 255),        -- Bright Blue (Image 1)
            Text = Color3.fromRGB(245, 245, 245),
            SubText = Color3.fromRGB(140, 140, 140),
