            Main.Visible = true
            U.Tween(Main, {GroupTransparency = 0}, TW_MED)
        else
            local tw = TweenService:Create(Main, TW_MED, {GroupTransparency = 1})
            tw.Completed:Connect(function()
                if not Window._visible then Main.Visible = false end
            end)
            tw:Play()
        end
    end

