-- [ INTERIOR UTILITIES ] --
local function Create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties) do inst[k] = v end
    return inst
end

local function Tween(instance, properties, duration)
    local tween = TweenService:Create(instance, TweenInfo.new(duration or 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), properties)
    tween:Play()
    return tween
end

local function MakeDraggable(dragHandle, object)
    local dragging, dragInput, dragStart, startPos
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = object.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Tween(object, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.08)
        end
    end)
end

-- [ CONFIGURATION STORAGE ENGINE ] --
local function SaveConfig()
    if writefile then
        local success, err = pcall(function()
            if not isfolder(Cline.ConfigFolder) then makefolder(Cline.ConfigFolder) end
            writefile(Cline.ConfigFolder .. "/" .. Cline.CurrentConfig, HttpService:JSONEncode(Cline.SavedStates))
        end)
    end
end

local function LoadConfig(callbackMap)
    if readfile then
        pcall(function()
            local path = Cline.ConfigFolder .. "/" .. Cline.CurrentConfig
            if有用 and isfile(path) then
                local data = HttpService:JSONDecode(readfile(path))
                for k, v in pairs(data) do
                    Cline.SavedStates[k] = v
                    if callbackMap[k] then task.spawn(callbackMap[k], v) end
                end
            end
        end)
    end
end

