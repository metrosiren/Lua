                U.Tween(BtnLbl, {TextColor3=T.TextPrimary},       TW_FAST)
            end
        end)
        Btn.MouseLeave:Connect(function()
            Tip.Visible = false
            if Window._activeTab ~= Tab then
                U.Tween(Btn,    {BackgroundColor3=T.SurfaceAlt}, TW_FAST)
                U.Tween(BtnLbl, {TextColor3=T.TextSub},          TW_FAST)
            end
