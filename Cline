--[[
    ClineUI — Lightweight, minimalist Luau UI Library
    ─────────────────────────────────────────────────
    USAGE:
        local ClineUI = loadstring(...)()

        local Window = ClineUI:CreateWindow({
            Title       = "My Script",
            Theme       = "Dark",          -- "Dark" | "Light" | "Midnight" | custom
            Keybind     = Enum.KeyCode.RightShift,
            ConfigName  = "MyScript",
            ShowUserInfo = true,
            ShowAvatar   = true,
            ShowExecutor = true,
        })

        local Tab     = Window:CreateTab({ Title = "Aimbot", Icon = "🎯" })
        local Section = Tab:CreateSection({ Title = "General" })

        Section:AddToggle({
            Title = "Enable", Flag = "Enabled", Default = false,
            Callback = function(v) end,
        })
        Section:AddSlider({
            Title = "FOV", Flag = "FOV", Min = 1, Max = 360, Default = 90,
            Suffix = "°", Callback = function(v) end,
