        Btn.MouseButton1Click:Connect(function() Window:_SelectTab(Tab) end)

        table.insert(Window._tabs, Tab)
        if #Window._tabs == 1 then Window:_SelectTab(Tab) end

        -- ════════════════════════════════════════════════════
        -- CREATE SECTION
        -- ════════════════════════════════════════════════════
        function Tab:CreateSection(secCfg)
            secCfg = secCfg or {}
            local sc2 = { Title = secCfg.Title or "" }

            local SecFrame = Instance.new("Frame")
            SecFrame.Name             = "Section"
            SecFrame.Size             = UDim2.new(1,0,0,0)
            SecFrame.AutomaticSize    = Enum.AutomaticSize.Y
            SecFrame.BackgroundColor3 = T.Surface
            SecFrame.BorderSizePixel  = 0
            SecFrame.ZIndex           = 4
            SecFrame.Parent           = Scroll
            U.Corner(SecFrame, 10)
            U.Stroke(SecFrame, T.Border, 1)

            -- title row inside section
            local contentTopPad = SECTION_PAD
            if sc2.Title ~= "" then
                contentTopPad = 36

                local SecTitle = Instance.new("TextLabel")
                SecTitle.Size              = UDim2.new(1,-24,0,14)
                SecTitle.Position          = UDim2.new(0,12,0,12)
                SecTitle.BackgroundTransparency = 1
                SecTitle.Text              = sc2.Title:upper()
                SecTitle.TextColor3        = T.TextSub
                SecTitle.TextSize          = 10
                SecTitle.Font              = Enum.Font.GothamBold
                SecTitle.TextXAlignment    = Enum.TextXAlignment.Left
                SecTitle.ZIndex            = 5
                SecTitle.Parent            = SecFrame

                local TitleLine = Instance.new("Frame")
                TitleLine.Size             = UDim2.new(1,-24,0,1)
                TitleLine.Position         = UDim2.new(0,12,0,30)
                TitleLine.BackgroundColor3 = T.Border
                TitleLine.BorderSizePixel  = 0
                TitleLine.ZIndex           = 5
                TitleLine.Parent           = SecFrame
            end

            -- inner content holder (auto Y)
            local Inner = Instance.new("Frame")
            Inner.Name           = "Inner"
            Inner.Size           = UDim2.new(1,0,0,0)
            Inner.Position       = UDim2.new(0,0,0,contentTopPad)
            Inner.AutomaticSize  = Enum.AutomaticSize.Y
            Inner.BackgroundTransparency = 1
            Inner.ZIndex         = 5
            Inner.Parent         = SecFrame
            U.VList(Inner, 0)
            U.Pad(Inner, 0, 12, SECTION_PAD, 12)

            local Section = {
                _frame    = SecFrame,
                _inner    = Inner,
                _elements = {},
            }
            table.insert(Tab._sections, Section)

            -- ── shared row builder ───────────────────────────
            local function MakeRow(elCfg, height)
                height = height or ROW_H

                -- divider
                if #Section._elements > 0 then
                    local Div = Instance.new("Frame")
                    Div.Size             = UDim2.new(1,0,0,ELEM_DIV_H)
                    Div.BackgroundColor3 = T.Border
                    Div.BackgroundTransparency = 0.5
                    Div.BorderSizePixel  = 0
                    Div.ZIndex           = 5
                    Div.Parent           = Inner
                end

                local Row = Instance.new("Frame")
                Row.Name              = "Row"
                Row.Size              = UDim2.new(1,0,0,height)
                Row.BackgroundTransparency = 1
                Row.ZIndex            = 6
                Row.Parent            = Inner

                -- left: title + description
                local Left = Instance.new("Frame")
                Left.Size                  = UDim2.new(0.54,0,1,0)
                Left.BackgroundTransparency = 1
                Left.ZIndex                = 7
                Left.Parent                = Row

                local hasDesc = elCfg.Description and elCfg.Description ~= ""

                local TitleL = Instance.new("TextLabel")
                TitleL.Size              = UDim2.new(1,0,0,16)
                TitleL.Position          = UDim2.new(0,0,0.5, hasDesc and -15 or -8)
                TitleL.BackgroundTransparency = 1
                TitleL.Text              = elCfg.Title or ""
                TitleL.TextColor3        = T.TextPrimary
                TitleL.TextSize          = 13
                TitleL.Font              = Enum.Font.Gotham
                TitleL.TextXAlignment    = Enum.TextXAlignment.Left
                TitleL.ZIndex            = 8
                TitleL.Parent            = Left

                if hasDesc then
                    local DescL = Instance.new("TextLabel")
                    DescL.Size              = UDim2.new(1,0,0,12)
                    DescL.Position          = UDim2.new(0,0,0.5,2)
                    DescL.BackgroundTransparency = 1
                    DescL.Text              = elCfg.Description
                    DescL.TextColor3        = T.TextSub
                    DescL.TextSize          = 10
                    DescL.Font              = Enum.Font.Gotham
                    DescL.TextXAlignment    = Enum.TextXAlignment.Left
                    DescL.ZIndex            = 8
                    DescL.Parent            = Left
                end

                -- right: control goes here
                local Right = Instance.new("Frame")
                Right.Name                 = "Right"
                Right.Size                 = UDim2.new(0.44,0,1,0)
                Right.Position             = UDim2.new(0.56,0,0,0)
                Right.BackgroundTransparency = 1
                Right.ZIndex               = 7
                Right.Parent               = Row

                return Row, Right
            end

            -- ═══════════════════════════════════════════════
            -- TOGGLE
            -- ═══════════════════════════════════════════════
            function Section:AddToggle(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title    = elCfg.Title    or "Toggle",
                    Desc     = elCfg.Description or "",
                    Default  = elCfg.Default  or false,
                    Flag     = elCfg.Flag     or elCfg.Title,
                    Callback = elCfg.Callback or function() end,
                }

                local Row, Right = MakeRow({ Title=ec.Title, Description=ec.Desc })

                local Bg = Instance.new("Frame")
                Bg.Size             = UDim2.new(0,38,0,22)
                Bg.Position         = UDim2.new(1,-38,0.5,-11)
                Bg.BackgroundColor3 = ec.Default and T.ToggleOn or T.ToggleOff
                Bg.BorderSizePixel  = 0
                Bg.ZIndex           = 8
                Bg.Parent           = Right
                U.Corner(Bg, 11)

                local Thumb = Instance.new("Frame")
                Thumb.Size             = UDim2.new(0,16,0,16)
                Thumb.Position         = ec.Default
                    and UDim2.new(1,-19,0.5,-8)
                    or  UDim2.new(0,3,0.5,-8)
                Thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
                Thumb.BorderSizePixel  = 0
                Thumb.ZIndex           = 9
                Thumb.Parent           = Bg
                U.Corner(Thumb, 8)

                local val = ec.Default
                ClineUI.Flags[ec.Flag] = val

                local El = { _row=Row, _title=ec.Title, _desc=ec.Desc, _flag=ec.Flag, Value=val }

                local function Set(new, silent)
                    val = new; El.Value = val; ClineUI.Flags[ec.Flag] = val
                    U.Tween(Bg,    {BackgroundColor3 = val and T.ToggleOn or T.ToggleOff}, TW_FAST)
                    U.Tween(Thumb, {Position = val
                        and UDim2.new(1,-19,0.5,-8)
                        or  UDim2.new(0,3,0.5,-8)},  TW_FAST)
                    if not silent then ec.Callback(val); Window:SaveConfig() end
                end

                El.Set = Set
                Window._flagCbs[ec.Flag] = function(v) Set(v, true) end

                local function Toggle(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1
                        or inp.UserInputType == Enum.UserInputType.Touch then
                        Set(not val)
                    end
                end
                Bg.InputBegan:Connect(Toggle)
                Row.InputBegan:Connect(Toggle)

                table.insert(Section._elements, El)
                return El
            end

            -- ═══════════════════════════════════════════════
            -- BUTTON
            -- ═══════════════════════════════════════════════
            function Section:AddButton(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title    = elCfg.Title    or "Button",
                    Desc     = elCfg.Description or "",
                    Text     = elCfg.Text     or "Execute",
                    Callback = elCfg.Callback or function() end,
                }

                local Row, Right = MakeRow({ Title=ec.Title, Description=ec.Desc })

                local Btn = Instance.new("TextButton")
                Btn.Size             = UDim2.new(0,88,0,28)
                Btn.Position         = UDim2.new(1,-88,0.5,-14)
                Btn.BackgroundColor3 = T.Accent
                Btn.BorderSizePixel  = 0
                Btn.Text             = ec.Text
                Btn.TextColor3       = Color3.fromRGB(255,255,255)
                Btn.TextSize         = 12
                Btn.Font             = Enum.Font.GothamBold
                Btn.ZIndex           = 8
                Btn.Parent           = Right
                U.Corner(Btn, 8)

                Btn.MouseEnter:Connect(function()   U.Tween(Btn,{BackgroundColor3=T.AccentHover}, TW_FAST) end)
                Btn.MouseLeave:Connect(function()   U.Tween(Btn,{BackgroundColor3=T.Accent},      TW_FAST) end)
                Btn.MouseButton1Down:Connect(function()
                    U.Tween(Btn,{BackgroundColor3=T.AccentActive, Size=UDim2.new(0,84,0,26)}, TW_FAST)
                end)
                Btn.MouseButton1Up:Connect(function()
                    U.Tween(Btn,{BackgroundColor3=T.AccentHover,  Size=UDim2.new(0,88,0,28)}, TW_FAST)
                end)
                Btn.MouseButton1Click:Connect(function() ec.Callback() end)

                local El = { _row=Row, _title=ec.Title, _desc=ec.Desc, _btn=Btn }
