            local active = t == tab
            t._scroll.Visible = active
            U.Tween(t._btn, {
                BackgroundColor3 = active and T.Accent or T.SurfaceAlt
            }, TW_FAST)
            local il = t._btn:FindFirstChildWhichIsA("TextLabel")
            if il then
                U.Tween(il, {
                    TextColor3 = active and Color3.fromRGB(255,255,255) or T.TextSub
                }, TW_FAST)
            end
        end
        self._activeTab = tab
    end

    -- ══════════════════════════════════════════════════════════
    -- CREATE TAB
    -- ══════════════════════════════════════════════════════════
    function Window:CreateTab(tabCfg)
        tabCfg = tabCfg or {}
        local tc = {
            Title = tabCfg.Title or "Tab",
