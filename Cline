        Tip.ZIndex           = 15
        Tip.Visible          = false
        Tip.AutomaticSize    = Enum.AutomaticSize.X
        Tip.Parent           = Btn
        U.Corner(Tip, 6)
        U.Stroke(Tip, T.Border, 1)
        U.Pad(Tip, 0, 8, 0, 8)

        local TipLbl = Instance.new("TextLabel")
