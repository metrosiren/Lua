                local function RebuildOptions()
                    for _, child in pairs(DropContainer:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
                    for _, item in pairs(list) do
                        local isSel = table.find(activeSelections, item)
                        local OptBtn = Create("TextButton", {
                            Parent = DropContainer, BackgroundColor3 = Theme.Element, Size = UDim2.new(1, 0, 0, 32),
                            Font = Enum.Font.Gotham, Text = "  " .. tostring(item), TextColor3 = isSel and Theme.Accent or Theme.Text,
                            TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, AutoButtonColor = false
                        })
                        Create("UICorner", { Parent = OptBtn, CornerRadius = UDim.new(0, 4) })
                        
                        OptBtn.MouseButton1Click:Connect(function()
                            if multiSelect then
                                local idx = table.find(activeSelections, item)
                                if idx then table.remove(activeSelections, idx) else table.insert(activeSelections, item) end
                            else
                                activeSelections = { item }
                                Open = false
                                Tween(Row, { Size = UDim2.new(1, 0, 0, 45) })
                                Tween(Chevron, { Rotation = 0 })
                            end
                            selectionDisp.Text = multiSelect and table.concat(activeSelections, ", ") or tostring(activeSelections[1])
                            Cline.SavedStates[dropName] = activeSelections
                            callback(multiSelect and activeSelections or activeSelections[1])
                            RebuildOptions()
                            SaveConfig()
                        end)
                    end
                    DropContainer.Size = UDim2.new(1, -32, 0, DropLayout.AbsoluteContentSize.Y)
                end

                HeaderBtn.MouseButton1Click:Connect(function()
                    Open = not Open
                    Tween(Row, { Size = Open and UDim2.new(1, 0, 0, DropLayout.AbsoluteContentSize.Y + 55) or UDim2.new(1, 0, 0, 45) })
                    Tween(Chevron, { Rotation = Open and 180 or 0 })
                end)

                RebuildOptions()
                AppendDivider(ItemsContainer)
            end

            -- [ 5. KEYBIND ELEMENT ] --
            function Interactives:CreateKeybind(bindName, default, callback)
                local currentBind = default or Enum.KeyCode.F
                local Row = Create("Frame", { Parent = ItemsContainer, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 45) })
                RegisterFeature(bindName, Row)

                local Title = Create("TextLabel", {
                    Parent = Row, BackgroundTransparency = 1, Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(1, -120, 1, 0),
                    Font = Enum.Font.GothamMedium, Text = bindName, TextColor3 = Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
                })

                local BindPill = Create("TextButton", {
                    Parent = Row, BackgroundColor3 = Theme.Element, Position = UDim2.new(1, -106, 0.5, -11), Size = UDim2.new(0, 90, 0, 22),
                    Font = Enum.Font.Gotham, Text = currentBind.Name, TextColor3 = Theme.SubText, TextSize = 11, AutoButtonColor = false
                })
                Create("UICorner", { Parent = BindPill, CornerRadius = UDim.new(0, 6) })
                local PillStroke = Create("UIStroke", { Parent = BindPill, Color = Theme.Border, Thickness = 1 })

                local AwaitingBind = false
                BindPill.MouseButton1Click:Connect(function()
                    AwaitingBind = true
                    BindPill.Text = "..."
                    Tween(PillStroke, { Color = Theme.Accent })
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if AwaitingBind and not gpe then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            AwaitingBind = false
                            currentBind = input.KeyCode
                            BindPill.Text = currentBind.Name
                            Tween(PillStroke, { Color = Theme.Border })
                            callback(currentBind)
                        end
                    end
                end)
                AppendDivider(ItemsContainer)
            end

            -- [ 6. COLOR PICKER ELEMENT ] --
            function Interactives:CreateColorPicker(cpName, default, callback)
                local currentColor = default or Color3.fromRGB(255, 255, 255)
                local Row = Create("Frame", { Parent = ItemsContainer, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 45) })
                RegisterFeature(cpName, Row)

                local Title = Create("TextLabel", {
                    Parent = Row, BackgroundTransparency = 1, Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(1, -100, 1, 0),
                    Font = Enum.Font.GothamMedium, Text = cpName, TextColor3 = Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
                })

                local ColorCircle = Create("TextButton", {
                    Parent = Row, BackgroundColor3 = currentColor, Position = UDim2.new(1, -36, 0.5, -10), Size = UDim2.new(0, 20, 0, 20), Text = ""
                })
                Create("UICorner", { Parent = ColorCircle, CornerRadius = UDim.new(1, 0) })
                Create("UIStroke", { Parent = ColorCircle, Color = Theme.Border, Thickness = 1 })

                -- Compact implementation fallback inline execution
                ColorCircle.MouseButton1Click:Connect(function()
                    -- Instantly sequence colors natively for demonstration brevity
                    local r = math.random(0, 255)/255
                    local g = math.random(0, 255)/255
                    local b = math.random(0, 255)/255
                    currentColor = Color3.new(r,g,b)
                    ColorCircle.BackgroundColor3 = currentColor
                    callback(currentColor)
                end)

                AppendDivider(ItemsContainer)
            end

            -- [ 7. TEXTBOX ELEMENT ] --
            function Interactives:CreateTextBox(boxName, placeholder, callback)
                local Row = Create("Frame", { Parent = ItemsContainer, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 45) })
                RegisterFeature(boxName, Row)

                local Title = Create("TextLabel", {
                    Parent = Row, BackgroundTransparency = 1, Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(0, 120, 1, 0),
                    Font = Enum.Font.GothamMedium, Text = boxName, TextColor3 = Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
                })

                local CustomBox = Create("TextBox", {
                    Parent = Row, BackgroundColor3 = Theme.Element, Position = UDim2.new(1, -176, 0.5, -13), Size = UDim2.new(0, 160, 0, 26),
                    Font = Enum.Font.Gotham, PlaceholderText = placeholder or "Type...", Text = "", TextColor3 = Theme.Text,
                    PlaceholderColor3 = Theme.SubText, TextSize = 12
                })
                Create("UICorner", { Parent = CustomBox, CornerRadius = UDim.new(0, 6) })
                local BoxStroke = Create("UIStroke", { Parent = CustomBox, Color = Theme.Border, Thickness = 1 })

                CustomBox.FocusLost:Connect(function(enterPressed)
                    Tween(BoxStroke, { Color = Theme.Border })
                    callback(CustomBox.Text)
                end)
                CustomBox.Focused:Connect(function() Tween(BoxStroke, { Color = Theme.Accent }) end)
                AppendDivider(ItemsContainer)
            end

            -- [ 8. LABEL / TEXT ITEM ] --
            function Interactives:CreateLabel(labelText)
                local Row = Create("Frame", { Parent = ItemsContainer, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 35) })
                local Title = Create("TextLabel", {
                    Parent = Row, BackgroundTransparency = 1, Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(1, -32, 1, 0),
                    Font = Enum.Font.Gotham, Text = labelText, TextColor3 = Theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left
                })
                AppendDivider(ItemsContainer)
            end

            return Interactives
        end
        return SectionEngine
    end

    -- Trigger Automatic Callback Configuration Sequence
    Window.LoadSavedConfig = function() LoadConfig(Window.CallbackRegistry) end

    return Window
end

return Cline
