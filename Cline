            end

            -- ═══════════════════════════════════════════════
            -- SLIDER
            -- ═══════════════════════════════════════════════
            function Section:AddSlider(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title    = elCfg.Title    or "Slider",
                    Desc     = elCfg.Description or "",
                    Min      = elCfg.Min      or 0,
                    Max      = elCfg.Max      or 100,
                    Default  = elCfg.Default  or elCfg.Min or 0,
                    Decimals = elCfg.Decimals or 0,
                    Suffix   = elCfg.Suffix   or "",
                    Flag     = elCfg.Flag     or elCfg.Title,
                    Callback = elCfg.Callback or function() end,
                }

                local Row, Right = MakeRow({ Title=ec.Title, Description=ec.Desc }, 50)

                -- value readout
                local ValLbl = Instance.new("TextLabel")
                ValLbl.Size              = UDim2.new(1,0,0,16)
                ValLbl.Position          = UDim2.new(0,0,0,5)
                ValLbl.BackgroundTransparency = 1
                ValLbl.Text              = tostring(ec.Default) .. ec.Suffix
                ValLbl.TextColor3        = T.TextSub
                ValLbl.TextSize          = 11
                ValLbl.Font              = Enum.Font.GothamBold
                ValLbl.TextXAlignment    = Enum.TextXAlignment.Right
                ValLbl.ZIndex            = 8
                ValLbl.Parent            = Right

                -- track
                local Track = Instance.new("Frame")
                Track.Size             = UDim2.new(1,0,0,4)
                Track.Position         = UDim2.new(0,0,1,-12)
                Track.BackgroundColor3 = T.SliderTrack
                Track.BorderSizePixel  = 0
                Track.ZIndex           = 8
                Track.Parent           = Right
                U.Corner(Track, 2)

                local Fill = Instance.new("Frame")
                Fill.Size             = UDim2.new((ec.Default-ec.Min)/(ec.Max-ec.Min),0,1,0)
                Fill.BackgroundColor3 = T.SliderFill
                Fill.BorderSizePixel  = 0
                Fill.ZIndex           = 9
                Fill.Parent           = Track
                U.Corner(Fill, 2)

                local Knob = Instance.new("Frame")
                Knob.Size             = UDim2.new(0,14,0,14)
                Knob.Position         = UDim2.new((ec.Default-ec.Min)/(ec.Max-ec.Min),-7,0.5,-7)
                Knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
                Knob.BorderSizePixel  = 0
                Knob.ZIndex           = 10
                Knob.Parent           = Track
                U.Corner(Knob, 7)

                ClineUI.Flags[ec.Flag] = ec.Default
                local El = { _row=Row, _title=ec.Title, _desc=ec.Desc, _flag=ec.Flag, Value=ec.Default }

                local function Set(new, silent)
                    new = U.Clamp(U.Round(new, ec.Decimals), ec.Min, ec.Max)
                    El.Value = new; ClineUI.Flags[ec.Flag] = new
                    local pct = (new - ec.Min) / (ec.Max - ec.Min)
                    U.Tween(Fill, {Size     = UDim2.new(pct,0,1,0)},         TW_FAST)
                    U.Tween(Knob, {Position = UDim2.new(pct,-7,0.5,-7)},     TW_FAST)
                    ValLbl.Text = tostring(new) .. ec.Suffix
                    if not silent then ec.Callback(new); Window:SaveConfig() end
                end

                El.Set = Set
                Window._flagCbs[ec.Flag] = function(v) Set(v, true) end

                local drag = false
                local function Calc(inp)
                    local ap = Track.AbsolutePosition
                    local as = Track.AbsoluteSize
                    local rx = U.Clamp(inp.Position.X - ap.X, 0, as.X)
                    Set(ec.Min + (ec.Max - ec.Min) * (rx / as.X))
                end

                Track.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1
                        or inp.UserInputType == Enum.UserInputType.Touch then
                        drag = true; Calc(inp)
                    end
                end)
                Knob.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1
                        or inp.UserInputType == Enum.UserInputType.Touch then
                        drag = true
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if drag and (inp.UserInputType == Enum.UserInputType.MouseMovement
                        or inp.UserInputType == Enum.UserInputType.Touch) then Calc(inp) end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1
                        or inp.UserInputType == Enum.UserInputType.Touch then drag = false end
                end)

                table.insert(Section._elements, El)
                return El
            end

            -- ═══════════════════════════════════════════════
            -- DROPDOWN  (single & multi)
            -- ═══════════════════════════════════════════════
            function Section:AddDropdown(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title    = elCfg.Title    or "Dropdown",
                    Desc     = elCfg.Description or "",
                    Options  = elCfg.Options  or {},
                    Default  = elCfg.Default,
                    Multi    = elCfg.Multi    or false,
                    Flag     = elCfg.Flag     or elCfg.Title,
                    Callback = elCfg.Callback or function() end,
                }

                local Row, Right = MakeRow({ Title=ec.Title, Description=ec.Desc })

                local DropBtn = Instance.new("TextButton")
                DropBtn.Size             = UDim2.new(1,0,0,28)
                DropBtn.Position         = UDim2.new(0,0,0.5,-14)
                DropBtn.BackgroundColor3 = T.SurfaceAlt
                DropBtn.BorderSizePixel  = 0
                DropBtn.Text             = ""
                DropBtn.ZIndex           = 8
                DropBtn.Parent           = Right
                U.Corner(DropBtn, 8)
                U.Stroke(DropBtn, T.Border, 1)

                local SelLbl = Instance.new("TextLabel")
                SelLbl.Size              = UDim2.new(1,-26,1,0)
                SelLbl.Position          = UDim2.new(0,8,0,0)
                SelLbl.BackgroundTransparency = 1
                SelLbl.TextColor3        = T.TextPrimary
                SelLbl.TextSize          = 11
                SelLbl.Font              = Enum.Font.Gotham
                SelLbl.TextXAlignment    = Enum.TextXAlignment.Left
                SelLbl.TextTruncate      = Enum.TextTruncate.AtEnd
                SelLbl.ZIndex            = 9
                SelLbl.Parent            = DropBtn

                local Chev = Instance.new("TextLabel")
                Chev.Size                  = UDim2.new(0,18,1,0)
                Chev.Position              = UDim2.new(1,-20,0,0)
                Chev.BackgroundTransparency = 1
                Chev.Text                  = "▾"
                Chev.TextColor3            = T.TextSub
                Chev.TextSize              = 11
                Chev.Font                  = Enum.Font.Gotham
                Chev.ZIndex                = 9
                Chev.Parent                = DropBtn

                -- state
                local sel
                if ec.Multi then
                    sel = {}
                    if type(ec.Default) == "table" then
                        for _, v in ipairs(ec.Default) do sel[v] = true end
                    end
                else
                    sel = ec.Default or ec.Options[1]
                end

                local function RefreshLabel()
                    if ec.Multi then
                        local parts = {}
                        for _, o in ipairs(ec.Options) do if sel[o] then parts[#parts+1]=o end end
                        SelLbl.Text = #parts > 0 and table.concat(parts,", ") or "None"
                    else
                        SelLbl.Text = tostring(sel or "Select...")
                    end
                end
                RefreshLabel()
                ClineUI.Flags[ec.Flag] = sel

                -- floating list (parented to gui for z ordering)
                local List = Instance.new("Frame")
                List.BackgroundColor3 = T.DropBg
                List.BorderSizePixel  = 0
                List.ZIndex           = 30
                List.Visible          = false
                List.Size             = UDim2.new(0,1,0,1)
                List.Parent           = Gui
                U.Corner(List, 8)
                U.Stroke(List, T.Border, 1)

                local ListScroll = Instance.new("ScrollingFrame")
                ListScroll.Size                  = UDim2.new(1,0,1,0)
                ListScroll.BackgroundTransparency = 1
                ListScroll.BorderSizePixel        = 0
                ListScroll.ScrollBarThickness     = 2
                ListScroll.ScrollBarImageColor3   = T.ScrollBar
                ListScroll.CanvasSize             = UDim2.new(0,0,0,0)
                ListScroll.AutomaticCanvasSize    = Enum.AutomaticSize.Y
                ListScroll.ZIndex                 = 31
                ListScroll.Parent                 = List
                U.VList(ListScroll, 0)
                U.Pad(ListScroll, 4, 0, 4, 0)

                local open = false

                local function BuildList()
                    ListScroll:ClearAllChildren()
                    U.VList(ListScroll, 0)
                    U.Pad(ListScroll, 4, 0, 4, 0)

                    for _, opt in ipairs(ec.Options) do
                        local OBtn = Instance.new("TextButton")
                        OBtn.Size             = UDim2.new(1,0,0,30)
                        OBtn.BackgroundColor3 = T.DropBg
                        OBtn.BorderSizePixel  = 0
                        OBtn.Text             = ""
                        OBtn.ZIndex           = 32
                        OBtn.Parent           = ListScroll

                        local OLbl = Instance.new("TextLabel")
                        OLbl.Size              = UDim2.new(1,-34,1,0)
                        OLbl.Position          = UDim2.new(0,10,0,0)
                        OLbl.BackgroundTransparency = 1
                        OLbl.Text              = tostring(opt)
                        OLbl.TextColor3        = T.TextPrimary
                        OLbl.TextSize          = 12
                        OLbl.Font              = Enum.Font.Gotham
                        OLbl.TextXAlignment    = Enum.TextXAlignment.Left
                        OLbl.ZIndex            = 33
                        OLbl.Parent            = OBtn

                        local Check = Instance.new("TextLabel")
                        Check.Size              = UDim2.new(0,20,1,0)
                        Check.Position          = UDim2.new(1,-22,0,0)
                        Check.BackgroundTransparency = 1
                        Check.Text              = "✓"
                        Check.TextColor3        = T.Accent
                        Check.TextSize          = 12
                        Check.Font              = Enum.Font.GothamBold
                        Check.ZIndex            = 33
                        Check.Parent            = OBtn

                        local function Refresh()
                            local active = ec.Multi and sel[opt] or (sel == opt)
                            Check.Visible   = active
                            OLbl.TextColor3 = active and T.Accent or T.TextPrimary
                        end
                        Refresh()

                        OBtn.MouseEnter:Connect(function()
                            U.Tween(OBtn,{BackgroundColor3=T.SurfaceAlt},TW_FAST)
                        end)
                        OBtn.MouseLeave:Connect(function()
                            U.Tween(OBtn,{BackgroundColor3=T.DropBg},TW_FAST)
                        end)
                        OBtn.MouseButton1Click:Connect(function()
                            if ec.Multi then
                                sel[opt] = not sel[opt]
                                Refresh()
                            else
                                sel = opt
                                Refresh()
                                open = false
                                List.Visible = false
                                U.Tween(Chev,{Rotation=0},TW_FAST)
                            end
                            RefreshLabel()
                            ClineUI.Flags[ec.Flag] = sel
                            ec.Callback(sel)
                            Window:SaveConfig()
                        end)
                    end
                end

                DropBtn.MouseButton1Click:Connect(function()
                    open = not open
                    if open then
                        BuildList()
                        local ap = DropBtn.AbsolutePosition
                        local as = DropBtn.AbsoluteSize
                        local h  = math.min(#ec.Options * 30 + 8, 180)
                        List.Size     = UDim2.new(0, as.X, 0, h)
                        List.Position = UDim2.new(0, ap.X, 0, ap.Y + as.Y + 4)
                        List.Visible  = true
                        U.Tween(Chev,{Rotation=180},TW_FAST)
                    else
                        List.Visible = false
                        U.Tween(Chev,{Rotation=0},TW_FAST)
                    end
                end)

                UserInputService.InputBegan:Connect(function(inp)
                    if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                    if not open then return end
                    local mp = UserInputService:GetMouseLocation()
                    local lp = List.AbsolutePosition
                    local ls = List.AbsoluteSize
                    local inside = mp.X>=lp.X and mp.X<=lp.X+ls.X
                                and mp.Y>=lp.Y and mp.Y<=lp.Y+ls.Y
                    if not inside then
                        open = false
                        List.Visible = false
                        U.Tween(Chev,{Rotation=0},TW_FAST)
                    end
                end)

                local El = { _row=Row, _title=ec.Title, _desc=ec.Desc, _flag=ec.Flag, Value=sel }

                function El:Set(v)
                    sel = v; RefreshLabel()
                    ClineUI.Flags[ec.Flag] = sel; El.Value = sel
                end
                function El:SetOptions(opts)
                    ec.Options = opts; RefreshLabel()
                end

                Window._flagCbs[ec.Flag] = function(v) El:Set(v) end

                table.insert(Section._elements, El)
                return El
            end

            -- ═══════════════════════════════════════════════
            -- COLOR PICKER
            -- ═══════════════════════════════════════════════
            function Section:AddColorPicker(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title    = elCfg.Title    or "Color",
                    Desc     = elCfg.Description or "",
                    Default  = elCfg.Default  or Color3.fromRGB(91,141,239),
                    Flag     = elCfg.Flag     or elCfg.Title,
                    Callback = elCfg.Callback or function() end,
                }

                local Row, Right = MakeRow({ Title=ec.Title, Description=ec.Desc })

                -- hex + opacity text
                local HexLbl = Instance.new("TextLabel")
                HexLbl.Size              = UDim2.new(0,54,1,0)
                HexLbl.Position          = UDim2.new(1,-88,0,0)
                HexLbl.BackgroundTransparency = 1
                HexLbl.Text              = U.Color3toHex(ec.Default)
                HexLbl.TextColor3        = T.TextSub
                HexLbl.TextSize          = 11
                HexLbl.Font              = Enum.Font.GothamBold
                HexLbl.TextXAlignment    = Enum.TextXAlignment.Right
                HexLbl.ZIndex            = 8
                HexLbl.Parent            = Right

                local AlphaLbl = Instance.new("TextLabel")
                AlphaLbl.Size              = UDim2.new(0,28,1,0)
                AlphaLbl.Position          = UDim2.new(1,-120,0,0)
                AlphaLbl.BackgroundTransparency = 1
                AlphaLbl.Text              = "100%"
                AlphaLbl.TextColor3        = T.TextSub
                AlphaLbl.TextSize          = 10
                AlphaLbl.Font              = Enum.Font.Gotham
                AlphaLbl.TextXAlignment    = Enum.TextXAlignment.Right
                AlphaLbl.ZIndex            = 8
                AlphaLbl.Parent            = Right

                -- swatch
                local Swatch = Instance.new("TextButton")
                Swatch.Size             = UDim2.new(0,28,0,22)
                Swatch.Position         = UDim2.new(1,-28,0.5,-11)
                Swatch.BackgroundColor3 = ec.Default
                Swatch.BorderSizePixel  = 0
                Swatch.Text             = ""
                Swatch.ZIndex           = 8
                Swatch.Parent           = Right
                U.Corner(Swatch, 6)
                U.Stroke(Swatch, T.Border, 1)

                -- ── picker popup ──────────────────────────
                local Popup = Instance.new("Frame")
                Popup.Name             = "ColorPopup"
                Popup.Size             = UDim2.new(0,210,0,195)
                Popup.BackgroundColor3 = T.Surface
                Popup.BorderSizePixel  = 0
                Popup.ZIndex           = 40
                Popup.Visible          = false
                Popup.Parent           = Gui
                U.Corner(Popup, 10)
                U.Stroke(Popup, T.Border, 1)
                U.Pad(Popup, 10, 10, 10, 10)

                -- SV field: two layered frames act as gradient
                local SVOuter = Instance.new("Frame")
                SVOuter.Size             = UDim2.new(1,0,0,118)
                SVOuter.BorderSizePixel  = 0
                SVOuter.ZIndex           = 41
                SVOuter.Parent           = Popup
                U.Corner(SVOuter, 6)

                -- base = pure hue color
                local SVBase = Instance.new("Frame")
                SVBase.Size             = UDim2.new(1,0,1,0)
                SVBase.BackgroundColor3 = Color3.fromHSV(Color3.toHSV(ec.Default))
                SVBase.BorderSizePixel  = 0
                SVBase.ZIndex           = 42
                SVBase.Parent           = SVOuter
                U.Corner(SVBase, 6)

                -- white → transparent overlay (left=white, right=transparent)
                local SVWhite = Instance.new("Frame")
                SVWhite.Size             = UDim2.new(1,0,1,0)
                SVWhite.BackgroundTransparency = 0
                SVWhite.BackgroundColor3 = Color3.fromRGB(255,255,255)
                SVWhite.BorderSizePixel  = 0
                SVWhite.ZIndex           = 43
                SVWhite.Parent           = SVOuter
                U.Corner(SVWhite, 6)

                local SVWhiteGrad = Instance.new("UIGradient")
                SVWhiteGrad.Color     = ColorSequence.new(Color3.fromRGB(255,255,255), Color3.fromRGB(255,255,255))
                SVWhiteGrad.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1),
                })
                SVWhiteGrad.Rotation  = 0
                SVWhiteGrad.Parent    = SVWhite

                -- black → transparent overlay (top=transparent, bottom=black)
                local SVBlack = Instance.new("Frame")
                SVBlack.Size             = UDim2.new(1,0,1,0)
                SVBlack.BackgroundColor3 = Color3.fromRGB(0,0,0)
                SVBlack.BorderSizePixel  = 0
                SVBlack.ZIndex           = 44
                SVBlack.Parent           = SVOuter
                U.Corner(SVBlack, 6)

                local SVBlackGrad = Instance.new("UIGradient")
                SVBlackGrad.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0),
                })
                SVBlackGrad.Rotation  = 90
                SVBlackGrad.Parent    = SVBlack

                -- SV cursor
                local SVCursor = Instance.new("Frame")
                SVCursor.Size             = UDim2.new(0,12,0,12)
                SVCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
                SVCursor.BorderSizePixel  = 0
                SVCursor.ZIndex           = 45
                SVCursor.Parent           = SVOuter
                U.Corner(SVCursor, 6)
                U.Stroke(SVCursor, Color3.fromRGB(0,0,0), 1.5)

                -- hue bar
                local HueBar = Instance.new("Frame")
                HueBar.Size             = UDim2.new(1,0,0,10)
                HueBar.Position         = UDim2.new(0,0,0,126)
                HueBar.BorderSizePixel  = 0
                HueBar.ZIndex           = 41
                HueBar.Parent           = Popup
                U.Corner(HueBar, 5)

                local HueGrad = Instance.new("UIGradient")
                HueGrad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,     Color3.fromHSV(0,    1,1)),
                    ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167,1,1)),
                    ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333,1,1)),
                    ColorSequenceKeypoint.new(0.5,   Color3.fromHSV(0.5,  1,1)),
                    ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667,1,1)),
                    ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833,1,1)),
                    ColorSequenceKeypoint.new(1,     Color3.fromHSV(1,    1,1)),
                })
                HueGrad.Parent = HueBar

                local HueCursor = Instance.new("Frame")
                HueCursor.Size             = UDim2.new(0,6,1,0)
                HueCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
                HueCursor.BorderSizePixel  = 0
                HueCursor.ZIndex           = 42
                HueCursor.Parent           = HueBar
                U.Corner(HueCursor, 3)
                U.Stroke(HueCursor, Color3.fromRGB(180,180,180), 1)

                -- alpha bar
                local AlphaBar = Instance.new("Frame")
                AlphaBar.Size             = UDim2.new(1,0,0,10)
                AlphaBar.Position         = UDim2.new(0,0,0,145)
                AlphaBar.BackgroundColor3 = Color3.fromRGB(200,200,200)
                AlphaBar.BorderSizePixel  = 0
                AlphaBar.ZIndex           = 41
                AlphaBar.Parent           = Popup
                U.Corner(AlphaBar, 5)

                local AlphaGrad = Instance.new("UIGradient")
                AlphaGrad.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0),
                })
                AlphaGrad.Color = ColorSequence.new(ec.Default, ec.Default)
                AlphaGrad.Parent = AlphaBar

                local AlphaCursor = Instance.new("Frame")
                AlphaCursor.Size             = UDim2.new(0,6,1,0)
                AlphaCursor.Position         = UDim2.new(1,-6,0,0)
                AlphaCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
                AlphaCursor.BorderSizePixel  = 0
                AlphaCursor.ZIndex           = 42
                AlphaCursor.Parent           = AlphaBar
                U.Corner(AlphaCursor, 3)
                U.Stroke(AlphaCursor, Color3.fromRGB(180,180,180), 1)

                -- hex input
                local HexBox = Instance.new("TextBox")
                HexBox.Size              = UDim2.new(1,0,0,24)
                HexBox.Position          = UDim2.new(0,0,0,163)
                HexBox.BackgroundColor3  = T.SurfaceAlt
                HexBox.BorderSizePixel   = 0
                HexBox.Text              = U.Color3toHex(ec.Default)
                HexBox.TextColor3        = T.TextPrimary
                HexBox.PlaceholderText   = "RRGGBB"
                HexBox.PlaceholderColor3 = T.TextSub
                HexBox.TextSize          = 11
                HexBox.Font              = Enum.Font.GothamBold
                HexBox.TextXAlignment    = Enum.TextXAlignment.Center
                HexBox.ClearTextOnFocus  = false
                HexBox.ZIndex            = 42
                HexBox.Parent            = Popup
                U.Corner(HexBox, 6)
                U.Stroke(HexBox, T.Border, 1)

                -- ── state ─────────────────────────────────
                local cH, cS, cV = Color3.toHSV(ec.Default)
                local cA = 1
                ClineUI.Flags[ec.Flag] = { Color = U.Color3toHex(ec.Default), Alpha = 0 }

                local function Apply(silent)
                    local col = Color3.fromHSV(cH, cS, cV)
                    Swatch.BackgroundColor3 = col
                    HexLbl.Text  = U.Color3toHex(col)
                    AlphaLbl.Text = math.floor(cA*100) .. "%"
                    HexBox.Text  = U.Color3toHex(col)
                    SVBase.BackgroundColor3 = Color3.fromHSV(cH,1,1)
                    AlphaGrad.Color = ColorSequence.new(col, col)
                    ClineUI.Flags[ec.Flag] = { Color = U.Color3toHex(col), Alpha = 1-cA }
                    if not silent then ec.Callback(col, 1-cA); Window:SaveConfig() end
                end

                -- set initial cursor positions
                local function RefreshCursors()
                    SVCursor.Position  = UDim2.new(cS,-6, 1-cV,-6)
                    HueCursor.Position = UDim2.new(cH,-3, 0, 0)
                    AlphaCursor.Position = UDim2.new(cA,-3, 0, 0)
                end
                RefreshCursors()

                -- SV drag
                local svDrag = false
                SVOuter.InputBegan:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                        or inp.UserInputType==Enum.UserInputType.Touch then
                        svDrag = true
                        local ap = SVOuter.AbsolutePosition
                        local as = SVOuter.AbsoluteSize
                        cS = U.Clamp((inp.Position.X-ap.X)/as.X,0,1)
                        cV = 1-U.Clamp((inp.Position.Y-ap.Y)/as.Y,0,1)
                        RefreshCursors(); Apply()
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if svDrag and (inp.UserInputType==Enum.UserInputType.MouseMovement
                        or inp.UserInputType==Enum.UserInputType.Touch) then
                        local ap = SVOuter.AbsolutePosition
                        local as = SVOuter.AbsoluteSize
                        cS = U.Clamp((inp.Position.X-ap.X)/as.X,0,1)
                        cV = 1-U.Clamp((inp.Position.Y-ap.Y)/as.Y,0,1)
                        RefreshCursors(); Apply()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                        or inp.UserInputType==Enum.UserInputType.Touch then
                        svDrag = false
                    end
                end)

                -- hue drag
                local hueDrag = false
                HueBar.InputBegan:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                        or inp.UserInputType==Enum.UserInputType.Touch then
                        hueDrag = true
                        cH = U.Clamp((inp.Position.X-HueBar.AbsolutePosition.X)/HueBar.AbsoluteSize.X,0,1)
                        RefreshCursors(); Apply()
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if hueDrag and (inp.UserInputType==Enum.UserInputType.MouseMovement
                        or inp.UserInputType==Enum.UserInputType.Touch) then
                        cH = U.Clamp((inp.Position.X-HueBar.AbsolutePosition.X)/HueBar.AbsoluteSize.X,0,1)
                        RefreshCursors(); Apply()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                        or inp.UserInputType==Enum.UserInputType.Touch then
                        hueDrag = false
                    end
                end)

                -- alpha drag
                local aDrag = false
                AlphaBar.InputBegan:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                        or inp.UserInputType==Enum.UserInputType.Touch then
                        aDrag = true
                        cA = U.Clamp((inp.Position.X-AlphaBar.AbsolutePosition.X)/AlphaBar.AbsoluteSize.X,0,1)
                        RefreshCursors(); Apply()
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if aDrag and (inp.UserInputType==Enum.UserInputType.MouseMovement
                        or inp.UserInputType==Enum.UserInputType.Touch) then
                        cA = U.Clamp((inp.Position.X-AlphaBar.AbsolutePosition.X)/AlphaBar.AbsoluteSize.X,0,1)
                        RefreshCursors(); Apply()
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                        or inp.UserInputType==Enum.UserInputType.Touch then
                        aDrag = false
                    end
                end)

                -- hex input
                HexBox.FocusLost:Connect(function()
                    local hex = HexBox.Text:gsub("#","")
                    if #hex == 6 then
                        local ok, col = pcall(U.HextoColor3, hex)
                        if ok then
                            cH, cS, cV = Color3.toHSV(col)
                            RefreshCursors(); Apply()
                        end
                    end
                end)

                -- toggle popup
                local popupOpen = false
                Swatch.MouseButton1Click:Connect(function()
                    popupOpen = not popupOpen
                    if popupOpen then
                        local ap = Swatch.AbsolutePosition
                        local as = Swatch.AbsoluteSize
                        local sc2 = U.Screen()
                        local px = ap.X - 210 + as.X
                        local py = ap.Y + as.Y + 6
                        if py + 195 > sc2.Y then py = ap.Y - 195 - 6 end
                        if px < 0 then px = 0 end
                        Popup.Position = UDim2.new(0, px, 0, py)
                        Popup.Visible  = true
                    else
                        Popup.Visible = false
                    end
                end)

                UserInputService.InputBegan:Connect(function(inp)
                    if inp.UserInputType~=Enum.UserInputType.MouseButton1 then return end
                    if not popupOpen then return end
                    local mp = UserInputService:GetMouseLocation()
                    local pp = Popup.AbsolutePosition
                    local ps = Popup.AbsoluteSize
                    local sp = Swatch.AbsolutePosition
                    local ss = Swatch.AbsoluteSize
                    local inPopup  = mp.X>=pp.X and mp.X<=pp.X+ps.X and mp.Y>=pp.Y and mp.Y<=pp.Y+ps.Y
                    local inSwatch = mp.X>=sp.X and mp.X<=sp.X+ss.X and mp.Y>=sp.Y and mp.Y<=sp.Y+ss.Y
                    if not inPopup and not inSwatch then
                        popupOpen = false; Popup.Visible = false
                    end
                end)

                local El = { _row=Row, _title=ec.Title, _desc=ec.Desc, _flag=ec.Flag,
                             Value=ec.Default }

                function El:Set(color, alpha)
                    cH,cS,cV = Color3.toHSV(color)
                    cA = 1 - (alpha or 0)
                    RefreshCursors(); Apply(true)
                    El.Value = color
                end

                Window._flagCbs[ec.Flag] = function(v)
                    if type(v)=="table" and v.Color then
                        local ok, col = pcall(U.HextoColor3, v.Color)
                        if ok then El:Set(col, v.Alpha or 0) end
                    end
                end

                Apply(true)
                table.insert(Section._elements, El)
                return El
            end

            -- ═══════════════════════════════════════════════
            -- KEYBIND
            -- ═══════════════════════════════════════════════
            function Section:AddKeybind(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title    = elCfg.Title    or "Keybind",
                    Desc     = elCfg.Description or "",
                    Default  = elCfg.Default  or Enum.KeyCode.Unknown,
                    Flag     = elCfg.Flag     or elCfg.Title,
                    Callback = elCfg.Callback or function() end,
                }

                local Row, Right = MakeRow({ Title=ec.Title, Description=ec.Desc })

                local KBtn = Instance.new("TextButton")
                KBtn.Size             = UDim2.new(0,88,0,26)
                KBtn.Position         = UDim2.new(1,-88,0.5,-13)
                KBtn.BackgroundColor3 = T.SurfaceAlt
                KBtn.BorderSizePixel  = 0
                KBtn.TextColor3       = T.TextPrimary
                KBtn.TextSize         = 11
                KBtn.Font             = Enum.Font.GothamBold
                KBtn.ZIndex           = 8
                KBtn.Parent           = Right
                U.Corner(KBtn, 6)
                U.Stroke(KBtn, T.Border, 1)

                local cur = ec.Default
                ClineUI.Flags[ec.Flag] = cur

                local function KeyName(k)
                    return tostring(k):gsub("Enum%.KeyCode%.",""):gsub("Enum%.UserInputType%.","")
                end

                KBtn.Text = KeyName(cur)

                local listening = false
                KBtn.MouseButton1Click:Connect(function()
                    listening = true
                    KBtn.Text = "[ ... ]"
                    U.Tween(KBtn,{BackgroundColor3=T.Accent},TW_FAST)
                end)

                UserInputService.InputBegan:Connect(function(inp)
                    if not listening then return end
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then return end
                    listening = false
                    if inp.KeyCode ~= Enum.KeyCode.Escape then
                        cur = inp.KeyCode
                        ClineUI.Flags[ec.Flag] = cur
                        ec.Callback(cur)
                        Window:SaveConfig()
                    end
                    KBtn.Text = KeyName(cur)
                    U.Tween(KBtn,{BackgroundColor3=T.SurfaceAlt},TW_FAST)
                end)

                local El = { _row=Row, _title=ec.Title, _desc=ec.Desc, _flag=ec.Flag, Value=cur }
                Window._flagCbs[ec.Flag] = function(v)
                    cur = v; KBtn.Text = KeyName(v); El.Value = v
                end

                table.insert(Section._elements, El)
                return El
            end

            -- ═══════════════════════════════════════════════
            -- LABEL
            -- ═══════════════════════════════════════════════
            function Section:AddLabel(elCfg)
                elCfg = elCfg or {}
                local text = elCfg.Text or elCfg.Title or ""

                if #Section._elements > 0 then
                    local Div = Instance.new("Frame")
                    Div.Size             = UDim2.new(1,0,0,ELEM_DIV_H)
                    Div.BackgroundColor3 = T.Border
                    Div.BackgroundTransparency = 0.5
                    Div.BorderSizePixel  = 0
                    Div.ZIndex           = 5
                    Div.Parent           = Inner
                end

                local Row = Instance.new("Frame")
                Row.Size              = UDim2.new(1,0,0,30)
                Row.BackgroundTransparency = 1
                Row.ZIndex            = 6
                Row.Parent            = Inner

                local Lbl = Instance.new("TextLabel")
                Lbl.Size              = UDim2.new(1,0,1,0)
                Lbl.BackgroundTransparency = 1
                Lbl.Text              = text
                Lbl.TextColor3        = T.TextSub
                Lbl.TextSize          = 12
                Lbl.Font              = Enum.Font.Gotham
                Lbl.TextXAlignment    = Enum.TextXAlignment.Left
                Lbl.TextWrapped       = true
                Lbl.ZIndex            = 7
                Lbl.Parent            = Row

                local El = { _row=Row, _title=text, _desc="", _lbl=Lbl }
                function El:SetText(t) Lbl.Text = t end

                table.insert(Section._elements, El)
                return El
            end

            return Section
        end -- CreateSection

        return Tab
    end -- CreateTab

    -- ── Theme changer ────────────────────────────────────────────
    function Window:SetTheme(name)
        local newT = Themes[name] or WCfg.CustomThemes and WCfg.CustomThemes[name]
        if not newT then return end
        T = newT
        Main.BackgroundColor3  = T.Background
        Header.BackgroundColor3 = T.Surface
        Sidebar.BackgroundColor3 = T.Surface
        mainStroke.Color       = T.Border
    end

    function Window:AddTheme(name, colors)
        Themes[name] = colors
    end

    -- Load config after all elements are registered (next frame)
    task.defer(function() Window:LoadConfig() end)

    return Window
end -- CreateWindow

return ClineUI
