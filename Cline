    end)

    local Window = {
        CurrentTab = nil,
        Tabs = {}
    }

    function Window:CreateTab(options)
        local tabName = options.Name or "New Tab"
        local TabButton = Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 35),
            BackgroundColor3 = Library.Theme.Element,
            BackgroundTransparency = 1,
            Text = "  " .. tabName,
            Font = Enum.Font.GothamSemibold,
            TextSize = 13,
            TextColor3 = Library.Theme.TextMuted,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false
        }, { Create("UICorner", {CornerRadius = UDim.new(0, 6)}) })
        TabButton.Parent = TabList

        local TabPage = Create("ScrollingFrame", {
            Size = UDim2.new(1, -20, 1, -20),
            Position = UDim2.new(0, 10, 0, 10),
            BackgroundTransparency = 1,
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = Library.Theme.Border,
            Visible = false
        }, {
            Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10)})
        })
        TabPage.Parent = TabContainer

        TabButton.MouseButton1Click:Connect(function()
            for _, t in pairs(Window.Tabs) do
                t.Page.Visible = false
                Tween(t.Button, {TextColor3 = Library.Theme.TextMuted, BackgroundTransparency = 1}, 0.2)
            end
            TabPage.Visible = true
            Tween(TabButton, {TextColor3 = Library.Theme.Text, BackgroundTransparency = 0}, 0.2)
        end)

        if not Window.CurrentTab then
            Window.CurrentTab = TabPage
            TabPage.Visible = true
            TabButton.TextColor3 = Library.Theme.Text
            TabButton.BackgroundTransparency = 0
        end

        local Tab = {Page = TabPage, Button = TabButton}
        table.insert(Window.Tabs, Tab)

        function Tab:CreateSection(options)
            local sectionName = options.Name or "Section"
            local Section = Create("Frame", {
                Size = UDim2.new(1, -10, 0, 40),
                BackgroundColor3 = Library.Theme.Element,
                ClipsDescendants = true
            }, {
                Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
                Create("UIStroke", {Color = Library.Theme.Border, Thickness = 1}),
                Create("TextLabel", {
                    Size = UDim2.new(1, -20, 0, 30),
                    Position = UDim2.new(0, 10, 0, 5),
                    BackgroundTransparency = 1,
                    Text = sectionName,
                    Font = Enum.Font.GothamBold,
                    TextSize = 12,
                    TextColor3 = Library.Theme.Accent,
                    TextXAlignment = Enum.TextXAlignment.Left
                }),
                Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5)}),
                Create("UIPadding", {PaddingTop = UDim.new(0, 35), PaddingBottom = UDim.new(0, 10)})
            })
            Section.Parent = TabPage

            local function UpdateSectionSize()
                local height = 45 -- Base + Padding
                for _, child in ipairs(Section:GetChildren()) do
                    if child:IsA("GuiObject") and child.Name ~= "UIStroke" then
                        height = height + child.AbsoluteSize.Y + 5
                    end
                end
                Section.Size = UDim2.new(1, -10, 0, height)
                TabPage.CanvasSize = UDim2.new(0, 0, 0, TabPage.UIListLayout.AbsoluteContentSize.Y + 20)
            end

            local SectionObj = {}

            function SectionObj:AddToggle(options)
                local name = options.Name or "Toggle"
                local flag = options.Flag or name
                local callback = options.Callback or function() end
                
                Library.Flags[flag] = options.Default or false

                local ToggleFrame = Create("Frame", {
                    Size = UDim2.new(1, -20, 0, 30),
                    Position = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1
                }, {
                    Create("TextLabel", {
                        Size = UDim2.new(1, -50, 1, 0),
                        BackgroundTransparency = 1,
                        Text = name,
                        Font = Enum.Font.Gotham,
                        TextSize = 13,
                        TextColor3 = Library.Theme.Text,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                })

                local ToggleOuter = Create("Frame", {
                    Size = UDim2.new(0, 36, 0, 18),
                    Position = UDim2.new(1, -36, 0.5, -9),
                    BackgroundColor3 = Library.Flags[flag] and Library.Theme.Accent or Library.Theme.Border
                }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })
                
                local ToggleInner = Create("Frame", {
                    Size = UDim2.new(0, 14, 0, 14),
                    Position = Library.Flags[flag] and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })

                ToggleOuter.Parent = ToggleFrame
                ToggleInner.Parent = ToggleOuter
                ToggleFrame.Parent = Section

                local Button = Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "" })
                Button.Parent = ToggleFrame

                Button.MouseButton1Click:Connect(function()
                    Library.Flags[flag] = not Library.Flags[flag]
                    local state = Library.Flags[flag]
                    Tween(ToggleOuter, {BackgroundColor3 = state and Library.Theme.Accent or Library.Theme.Border}, 0.2)
                    Tween(ToggleInner, {Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}, 0.2)
                    callback(state)
                end)

                UpdateSectionSize()
            end

            function SectionObj:AddSlider(options)
                local name = options.Name or "Slider"
                local min, max = options.Min or 0, options.Max or 100
                local flag = options.Flag or name
                local callback = options.Callback or function() end
                
                Library.Flags[flag] = options.Default or min

                local SliderFrame = Create("Frame", {
                    Size = UDim2.new(1, -20, 0, 45),
                    Position = UDim2.new(0, 10, 0, 0),
                    BackgroundTransparency = 1
                })
                
                local Label = Create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Text = name,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    TextColor3 = Library.Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                Label.Parent = SliderFrame

                local ValueLabel = Create("TextLabel", {
                    Size = UDim2.new(0, 50, 0, 20),
                    Position = UDim2.new(1, -50, 0, 0),
                    BackgroundTransparency = 1,
                    Text = tostring(Library.Flags[flag]),
                    Font = Enum.Font.GothamBold,
                    TextSize = 12,
                    TextColor3 = Library.Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Right
                })
                ValueLabel.Parent = SliderFrame

                local SliderBG = Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 6),
                    Position = UDim2.new(0, 0, 0, 25),
                    BackgroundColor3 = Library.Theme.Border
                }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })
                
                local SliderFill = Create("Frame", {
                    Size = UDim2.new(0, 0, 1, 0), -- Updated below
                    BackgroundColor3 = Library.Theme.Accent
                }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })

                SliderFill.Parent = SliderBG
                SliderBG.Parent = SliderFrame
                SliderFrame.Parent = Section

                local function UpdateSlider(input)
                    local percent = math.clamp((input.Position.X - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
                    local val = math.floor(min + (max - min) * percent)
                    Library.Flags[flag] = val
                    ValueLabel.Text = tostring(val)
                    Tween(SliderFill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.05)
                    callback(val)
                end

                -- Init size
                SliderFill.Size = UDim2.new((Library.Flags[flag] - min) / (max - min), 0, 1, 0)

                local dragging = false
                SliderBG.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        UpdateSlider(input)
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        UpdateSlider(input)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)

                UpdateSectionSize()
            end

            return SectionObj
        end
        return Tab
    end
    return Window
end

-- Configuration Saving & Loading logic wrappers
function Library:SaveConfig(name)
    if not writefile then return end
    local success, json = pcall(function() return HttpService:JSONEncode(Library.Flags) end)
    if success then
        if not isfolder(Library.Folder) then makefolder(Library.Folder) end
        writefile(Library.Folder .. "/" .. name .. ".json", json)
    end
end

return Library
