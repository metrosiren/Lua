        Section:AddDropdown({
            Title = "Hitbox", Flag = "Hitbox",
            Options = {"Head","Body","Legs"}, Default = "Head",
            Callback = function(v) end,
        })
        Section:AddColorPicker({
            Title = "Color", Flag = "Color", Default = Color3.fromRGB(91,141,239),
            Callback = function(color, transparency) end,
        })
]]

