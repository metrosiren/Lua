    function Window:LoadConfig()
        local data = U.LoadCfg(WCfg.ConfigName)
        for flag, val in pairs(data) do
            ClineUI.Flags[flag] = val
            if Window._flagCbs[flag] then
                Window._flagCbs[flag](val)
            end
        end
    end

