                table.insert(Section._elements, El)
                return El
            end

            -- ════════════════════════════════════════════════
            -- SLIDER
            -- ════════════════════════════════════════════════
            function Section:AddSlider(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title=elCfg.Title or "Slider", Description=elCfg.Description or "",
                    Min=elCfg.Min or 0, Max=elCfg.Max or 100,
                    Default=elCfg.Default or elCfg.Min or 0,
                    Decimals=elCfg.Decimals or 0, Suffix=elCfg.Suffix or "",
                    Flag=elCfg.Flag or elCfg.Title,
                    Callback=elCfg.Callback or function()end,
                }
                -- slider gets its own row height
                local hasDesc = ec.Description ~= ""
                local h = hasDesc and 54 or 46

                if #Section._elements > 0 then
                    U.New("Frame",{
                        Size=UDim2.new(1,0,0,1), BackgroundColor3=T.Border,
                        BackgroundTransparency=0.55, BorderSizePixel=0, ZIndex=5, Parent=Inner,
                    })
                end

                local Row = U.New("Frame",{
                    Size=UDim2.new(1,0,0,h), BackgroundTransparency=1, ZIndex=6, Parent=Inner,
                })

                -- title
                if hasDesc then
                    U.Label(Row,{
                        Size=UDim2.new(0.55,0,0,15), Position=UDim2.new(0,0,0,6),
                        Text=ec.Title, TextColor3=T.TextPrim, TextSize=12, ZIndex=8,
                    })
                    U.Label(Row,{
                        Size=UDim2.new(0.55,0,0,11), Position=UDim2.new(0,0,0,21),
                        Text=ec.Description, TextColor3=T.TextSub, TextSize=10, ZIndex=8,
                    })
                else
                    U.Label(Row,{
                        Size=UDim2.new(0.55,0,0,15), Position=UDim2.new(0,0,0,8),
                        Text=ec.Title, TextColor3=T.TextPrim, TextSize=12, ZIndex=8,
                    })
                end

                -- value label (top-right)
                local ValLbl = U.Label(Row,{
                    Size=UDim2.new(0.43,0,0,15), Position=UDim2.new(0.57,0,0, hasDesc and 6 or 8),
                    Text=tostring(ec.Default)..ec.Suffix, TextColor3=T.TextSub, TextSize=10, Bold=true,
                    Align=Enum.TextXAlignment.Right, ZIndex=8,
                })

                -- track (bottom of row, full width)
                local trackY = hasDesc and 40 or 32
                local Track = U.New("Frame",{
                    Size=UDim2.new(1,0,0,3), Position=UDim2.new(0,0,0,trackY),
                    BackgroundColor3=T.TrackBg, BorderSizePixel=0, ZIndex=8, Parent=Row,
                })
                U.Corner(Track, 2)

                local pct0 = (ec.Default-ec.Min)/(ec.Max-ec.Min)
                local Fill = U.New("Frame",{
                    Size=UDim2.new(pct0,0,1,0), BackgroundColor3=T.TrackFill,
                    BorderSizePixel=0, ZIndex=9, Parent=Track,
                })
                U.Corner(Fill, 2)

                local Knob = U.New("Frame",{
                    Size=UDim2.new(0,12,0,12), Position=UDim2.new(pct0,-6,0.5,-6),
                    BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0, ZIndex=10, Parent=Track,
                })
                U.Corner(Knob, 6)
                U.Stroke(Knob, T.Border, 1)

                ClineUI.Flags[ec.Flag] = ec.Default
                local El = {_row=Row,_title=ec.Title,_desc=ec.Description,_flag=ec.Flag,Value=ec.Default}

                local function Set(new, silent)
                    new = U.Clamp(U.Round(new,ec.Decimals), ec.Min, ec.Max)
                    El.Value=new; ClineUI.Flags[ec.Flag]=new
                    local p = (new-ec.Min)/(ec.Max-ec.Min)
                    U.Tween(Fill, {Size=UDim2.new(p,0,1,0)}, TI_FAST)
                    U.Tween(Knob, {Position=UDim2.new(p,-6,0.5,-6)}, TI_FAST)
                    ValLbl.Text = tostring(new)..ec.Suffix
                    if not silent then ec.Callback(new); Window:SaveConfig() end
                end
                El.Set = Set
                Window._flagCbs[ec.Flag] = function(v) Set(v,true) end

                local drag = false
                local function Calc(i)
                    local ap=Track.AbsolutePosition; local as=Track.AbsoluteSize
                    Set(ec.Min+(ec.Max-ec.Min)*U.Clamp((i.Position.X-ap.X)/as.X,0,1))
                end
                Track.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        drag=true; Calc(i)
                    end
                end)
                Knob.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then drag=true end
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if drag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then Calc(i) end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then drag=false end
                end)

                table.insert(Section._elements, El)
                return El
            end

            -- ════════════════════════════════════════════════
            -- DROPDOWN
            -- ════════════════════════════════════════════════
            function Section:AddDropdown(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title=elCfg.Title or "Dropdown", Description=elCfg.Description or "",
                    Options=elCfg.Options or {}, Default=elCfg.Default,
                    Multi=elCfg.Multi or false,
                    Flag=elCfg.Flag or elCfg.Title,
                    Callback=elCfg.Callback or function()end,
                }
                local Row, Right = MakeRow(ec)

                local DropBtn = U.New("TextButton",{
                    Size=UDim2.new(1,0,0,26), Position=UDim2.new(0,0,0.5,-13),
                    BackgroundColor3=T.SurfaceAlt, BorderSizePixel=0, Text="", ZIndex=8, Parent=Right,
                })
                U.Corner(DropBtn, 6)
                U.Stroke(DropBtn, T.Border, 1)

                local SelLbl = U.Label(DropBtn,{
                    Size=UDim2.new(1,-22,1,0), Position=UDim2.new(0,8,0,0),
                    Text="", TextColor3=T.TextPrim, TextSize=11, ZIndex=9,
                })
                local Chev = U.Label(DropBtn,{
                    Size=UDim2.new(0,16,1,0), Position=UDim2.new(1,-18,0,0),
                    Text="⌄", TextColor3=T.TextSub, TextSize=12, Bold=true,
                    Align=Enum.TextXAlignment.Center, ZIndex=9,
                })

                local sel
                if ec.Multi then
                    sel={}
                    if type(ec.Default)=="table" then for _,v in ipairs(ec.Default) do sel[v]=true end end
                else sel=ec.Default or ec.Options[1] end

                local function RefLabel()
                    if ec.Multi then
                        local p={}; for _,o in ipairs(ec.Options) do if sel[o] then p[#p+1]=o end end
                        SelLbl.Text = #p>0 and table.concat(p,", ") or "None"
                    else SelLbl.Text = tostring(sel or "Select...") end
                end
                RefLabel()
                ClineUI.Flags[ec.Flag] = sel

                -- floating list
                local List = U.New("Frame",{
                    BackgroundColor3=T.DropBg, BorderSizePixel=0,
                    ZIndex=50, Visible=false, Size=UDim2.new(0,1,0,1), Parent=Gui,
                })
                U.Corner(List, 7)
                U.Stroke(List, T.Border, 1)

                local ListSF = U.New("ScrollingFrame",{
                    Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
                    BorderSizePixel=0, ScrollBarThickness=2,
                    ScrollBarImageColor3=T.Scrollbar,
                    CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
                    ZIndex=51, Parent=List,
                })
                U.VList(ListSF, 0)
                U.Pad(ListSF, 4,0,4,0)

                local open = false

                local function BuildList()
                    ListSF:ClearAllChildren(); U.VList(ListSF,0); U.Pad(ListSF,4,0,4,0)
                    for _,opt in ipairs(ec.Options) do
                        local OB = U.New("TextButton",{
                            Size=UDim2.new(1,0,0,28), BackgroundColor3=T.DropBg,
                            BorderSizePixel=0, Text="", ZIndex=52, Parent=ListSF,
                        })
                        local OL = U.Label(OB,{
                            Size=UDim2.new(1,-28,1,0), Position=UDim2.new(0,10,0,0),
                            Text=tostring(opt), TextColor3=T.TextPrim, TextSize=11, ZIndex=53,
                        })
                        local OC = U.Label(OB,{
                            Size=UDim2.new(0,20,1,0), Position=UDim2.new(1,-22,0,0),
                            Text="✓", TextColor3=T.Accent, TextSize=11, Bold=true,
                            Align=Enum.TextXAlignment.Center, ZIndex=53,
                        })
                        local function RefOpt()
                            local active = ec.Multi and sel[opt] or (sel==opt)
                            OC.Visible=active; OL.TextColor3=active and T.Accent or T.TextPrim
                        end
                        RefOpt()
                        OB.MouseEnter:Connect(function() U.Tween(OB,{BackgroundColor3=T.SurfaceHov},TI_FAST) end)
                        OB.MouseLeave:Connect(function() U.Tween(OB,{BackgroundColor3=T.DropBg},TI_FAST) end)
                        OB.MouseButton1Click:Connect(function()
                            if ec.Multi then sel[opt]=not sel[opt]; RefOpt()
                            else sel=opt; RefOpt(); open=false; List.Visible=false; U.Tween(Chev,{Rotation=0},TI_FAST) end
                            RefLabel(); ClineUI.Flags[ec.Flag]=sel; ec.Callback(sel); Window:SaveConfig()
                        end)
                    end
                end

                DropBtn.MouseButton1Click:Connect(function()
                    open=not open
                    if open then
                        BuildList()
                        local ap=DropBtn.AbsolutePosition; local as=DropBtn.AbsoluteSize
                        local h=math.min(#ec.Options*28+8,180)
                        List.Size=UDim2.new(0,as.X,0,h)
                        List.Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+3)
                        List.Visible=true; U.Tween(Chev,{Rotation=180},TI_FAST)
                    else List.Visible=false; U.Tween(Chev,{Rotation=0},TI_FAST) end
                end)
                UserInputService.InputBegan:Connect(function(i)
                    if i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
                    if not open then return end
                    if not U.InBounds(UserInputService:GetMouseLocation(),List.AbsolutePosition,List.AbsoluteSize) then
                        open=false; List.Visible=false; U.Tween(Chev,{Rotation=0},TI_FAST)
                    end
                end)

                local El = {_row=Row,_title=ec.Title,_desc=ec.Description,_flag=ec.Flag,Value=sel}
                function El:Set(v) sel=v; RefLabel(); ClineUI.Flags[ec.Flag]=sel; El.Value=sel end
                function El:SetOptions(opts) ec.Options=opts; RefLabel() end
                Window._flagCbs[ec.Flag]=function(v) El:Set(v) end
                table.insert(Section._elements, El)
                return El
            end

            -- ════════════════════════════════════════════════
            -- COLOR PICKER
            -- ════════════════════════════════════════════════
            function Section:AddColorPicker(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title=elCfg.Title or "Color", Description=elCfg.Description or "",
                    Default=elCfg.Default or Color3.fromRGB(94,106,210),
                    Flag=elCfg.Flag or elCfg.Title,
                    Callback=elCfg.Callback or function()end,
                }
                local Row, Right = MakeRow(ec)

                -- inline: hex label + alpha % + swatch
                local HexLbl = U.Label(Right,{
                    Size=UDim2.new(0,50,1,0), Position=UDim2.new(1,-82,0,0),
                    Text=U.Hex(ec.Default), TextColor3=T.TextSub, TextSize=10, Bold=true,
                    Align=Enum.TextXAlignment.Right, ZIndex=8,
                })
                local AlpLbl = U.Label(Right,{
                    Size=UDim2.new(0,26,1,0), Position=UDim2.new(1,-108,0,0),
                    Text="100%", TextColor3=T.TextSub, TextSize=9,
                    Align=Enum.TextXAlignment.Right, ZIndex=8,
                })
                local Swatch = U.New("TextButton",{
                    Size=UDim2.new(0,24,0,18), Position=UDim2.new(1,-24,0.5,-9),
                    BackgroundColor3=ec.Default, BorderSizePixel=0, Text="", ZIndex=8, Parent=Right,
                })
                U.Corner(Swatch, 5)
                U.Stroke(Swatch, T.Border, 1)

                -- popup
                local PW, PH = 200, 188
                local Pop = U.New("Frame",{
                    Size=UDim2.new(0,PW,0,PH), BackgroundColor3=T.Surface,
                    BorderSizePixel=0, ZIndex=60, Visible=false, Parent=Gui,
                })
                U.Corner(Pop, 8)
                U.Stroke(Pop, T.Border, 1)
                U.Pad(Pop, 10,10,10,10)

                -- SV field (layered gradients)
                local SVH = 112
                local SVWrap = U.New("Frame",{
                    Size=UDim2.new(1,0,0,SVH), BackgroundTransparency=1,
                    BorderSizePixel=0, ZIndex=61, Parent=Pop,
                })
                U.Corner(SVWrap, 6)

                -- hue-colored base
                local SVBase = U.New("Frame",{
                    Size=UDim2.new(1,0,1,0), BorderSizePixel=0, ZIndex=62, Parent=SVWrap,
                })
                U.Corner(SVBase, 6)

                -- white→transparent left→right
                local SVW = U.New("Frame",{
                    Size=UDim2.new(1,0,1,0), BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0, ZIndex=63, Parent=SVWrap,
                })
                U.Corner(SVW, 6)
                U.New("UIGradient",{
                    Transparency=NumberSequence.new({
                        NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1),
                    }), Rotation=0, Parent=SVW,
                })

                -- transparent→black top→bottom
                local SVB = U.New("Frame",{
                    Size=UDim2.new(1,0,1,0), BackgroundColor3=Color3.fromRGB(0,0,0),
                    BorderSizePixel=0, ZIndex=64, Parent=SVWrap,
                })
                U.Corner(SVB, 6)
                U.New("UIGradient",{
                    Transparency=NumberSequence.new({
                        NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0),
                    }), Rotation=90, Parent=SVB,
                })

                local SVCursor = U.New("Frame",{
                    Size=UDim2.new(0,10,0,10), BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0, ZIndex=65, Parent=SVWrap,
                })
                U.Corner(SVCursor, 5)
                U.Stroke(SVCursor, Color3.new(0,0,0), 1.5)

                -- hue bar
                local HueBar = U.New("Frame",{
                    Size=UDim2.new(1,0,0,8), Position=UDim2.new(0,0,0,SVH+8),
                    BorderSizePixel=0, ZIndex=61, Parent=Pop,
                })
                U.Corner(HueBar, 4)
                U.New("UIGradient",{
                    Color=ColorSequence.new({
                        ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,1,1)),
                        ColorSequenceKeypoint.new(0.167,Color3.fromHSV(.167,1,1)),
                        ColorSequenceKeypoint.new(0.333,Color3.fromHSV(.333,1,1)),
                        ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(.5,1,1)),
                        ColorSequenceKeypoint.new(0.667,Color3.fromHSV(.667,1,1)),
                        ColorSequenceKeypoint.new(0.833,Color3.fromHSV(.833,1,1)),
                        ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,1,1)),
                    }), Parent=HueBar,
                })
                local HKnob = U.New("Frame",{
                    Size=UDim2.new(0,4,1,0), BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0, ZIndex=62, Parent=HueBar,
                })
                U.Corner(HKnob, 2)

                -- alpha bar
                local ABar = U.New("Frame",{
                    Size=UDim2.new(1,0,0,8), Position=UDim2.new(0,0,0,SVH+24),
                    BackgroundColor3=Color3.fromRGB(180,180,180),
                    BorderSizePixel=0, ZIndex=61, Parent=Pop,
                })
                U.Corner(ABar, 4)
                local AGrad = U.New("UIGradient",{
                    Transparency=NumberSequence.new({
                        NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0),
                    }), Parent=ABar,
                })
                local AKnob = U.New("Frame",{
                    Size=UDim2.new(0,4,1,0), Position=UDim2.new(1,-4,0,0),
                    BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0, ZIndex=62, Parent=ABar,
                })
                U.Corner(AKnob, 2)

                -- hex input
                local HexBox = U.New("TextBox",{
                    Size=UDim2.new(1,0,0,22), Position=UDim2.new(0,0,0,SVH+40),
                    BackgroundColor3=T.SurfaceAlt, BorderSizePixel=0,
                    Text=U.Hex(ec.Default), TextColor3=T.TextPrim,
                    PlaceholderText="RRGGBB", PlaceholderColor3=T.TextSub,
                    TextSize=11, Font=Enum.Font.GothamBold,
                    TextXAlignment=Enum.TextXAlignment.Center,
                    ClearTextOnFocus=false, ZIndex=62, Parent=Pop,
                })
                U.Corner(HexBox, 5)
                U.Stroke(HexBox, T.Border, 1)

                -- state
                local cH,cS,cV = Color3.toHSV(ec.Default)
                local cA = 1
                ClineUI.Flags[ec.Flag] = {Color=U.Hex(ec.Default), Alpha=0}

                local function Apply(silent)
                    local col = Color3.fromHSV(cH,cS,cV)
                    Swatch.BackgroundColor3 = col
                    HexLbl.Text  = U.Hex(col)
                    AlpLbl.Text  = math.floor(cA*100).."%"
                    HexBox.Text  = U.Hex(col)
                    SVBase.BackgroundColor3 = Color3.fromHSV(cH,1,1)
                    AGrad.Color  = ColorSequence.new(col,col)
                    ClineUI.Flags[ec.Flag] = {Color=U.Hex(col), Alpha=1-cA}
                    if not silent then ec.Callback(col,1-cA); Window:SaveConfig() end
                end

                local function RefCursors()
                    SVCursor.Position = UDim2.new(cS,-5,1-cV,-5)
                    HKnob.Position    = UDim2.new(cH,-2,0,0)
                    AKnob.Position    = UDim2.new(cA,-2,0,0)
                end
                RefCursors()

                -- drag helpers
                local function MakeDrag(region, onMove)
                    local d=false
                    region.InputBegan:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                            d=true; onMove(i)
                        end
                    end)
                    UserInputService.InputChanged:Connect(function(i)
                        if d and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then onMove(i) end
                    end)
                    UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then d=false end
                    end)
                end

                MakeDrag(SVWrap, function(i)
                    local ap=SVWrap.AbsolutePosition; local as=SVWrap.AbsoluteSize
                    cS=U.Clamp((i.Position.X-ap.X)/as.X,0,1)
                    cV=1-U.Clamp((i.Position.Y-ap.Y)/as.Y,0,1)
                    RefCursors(); Apply()
                end)
                MakeDrag(HueBar, function(i)
                    cH=U.Clamp((i.Position.X-HueBar.AbsolutePosition.X)/HueBar.AbsoluteSize.X,0,1)
                    RefCursors(); Apply()
                end)
                MakeDrag(ABar, function(i)
                    cA=U.Clamp((i.Position.X-ABar.AbsolutePosition.X)/ABar.AbsoluteSize.X,0,1)
                    RefCursors(); Apply()
                end)

                HexBox.FocusLost:Connect(function()
                    local h=HexBox.Text:gsub("#","")
                    if #h==6 then
                        local ok,col=pcall(U.FromHex,h)
                        if ok then cH,cS,cV=Color3.toHSV(col); RefCursors(); Apply() end
                    end
                end)

                local popOpen=false
                Swatch.MouseButton1Click:Connect(function()
                    popOpen=not popOpen
                    if popOpen then
                        local ap=Swatch.AbsolutePosition; local as=Swatch.AbsoluteSize
                        local sc2=U.Screen()
                        local px=ap.X-PW+as.X; local py=ap.Y+as.Y+5
                        if py+PH>sc2.Y then py=ap.Y-PH-5 end
                        if px<0 then px=0 end
                        Pop.Position=UDim2.new(0,px,0,py); Pop.Visible=true
                    else Pop.Visible=false end
                end)
                UserInputService.InputBegan:Connect(function(i)
                    if i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
                    if not popOpen then return end
                    local mp=UserInputService:GetMouseLocation()
                    if not U.InBounds(mp,Pop.AbsolutePosition,Pop.AbsoluteSize)
                    and not U.InBounds(mp,Swatch.AbsolutePosition,Swatch.AbsoluteSize) then
                        popOpen=false; Pop.Visible=false
                    end
                end)

                local El={_row=Row,_title=ec.Title,_desc=ec.Description,_flag=ec.Flag,Value=ec.Default}
                function El:Set(col,alpha)
                    cH,cS,cV=Color3.toHSV(col); cA=1-(alpha or 0)
                    RefCursors(); Apply(true); El.Value=col
                end
                Window._flagCbs[ec.Flag]=function(v)
                    if type(v)=="table" and v.Color then
                        local ok,col=pcall(U.FromHex,v.Color)
                        if ok then El:Set(col,v.Alpha or 0) end
                    end
                end
                Apply(true)
                table.insert(Section._elements, El)
                return El
            end

            -- ════════════════════════════════════════════════
            -- KEYBIND
            -- ════════════════════════════════════════════════
            function Section:AddKeybind(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title=elCfg.Title or "Keybind", Description=elCfg.Description or "",
                    Default=elCfg.Default or Enum.KeyCode.Unknown,
                    Flag=elCfg.Flag or elCfg.Title,
                    Callback=elCfg.Callback or function()end,
                }
                local Row, Right = MakeRow(ec)

                local KBtn = U.New("TextButton",{
                    Size=UDim2.new(0,80,0,24), Position=UDim2.new(1,-80,0.5,-12),
                    BackgroundColor3=T.SurfaceAlt, BorderSizePixel=0,
                    TextColor3=T.TextPrim, TextSize=10, Font=Enum.Font.GothamBold,
                    ZIndex=8, Parent=Right,
                })
                U.Corner(KBtn, 5)
                U.Stroke(KBtn, T.Border, 1)

                local cur = ec.Default
                ClineUI.Flags[ec.Flag] = cur
                local function KN(k) return tostring(k):gsub("Enum%.KeyCode%.",""):gsub("Enum%.UserInputType%.","") end
                KBtn.Text = KN(cur)

                local listening=false
                KBtn.MouseButton1Click:Connect(function()
                    listening=true; KBtn.Text="···"
                    U.Tween(KBtn,{BackgroundColor3=T.AccentBg},TI_FAST)
                end)
                UserInputService.InputBegan:Connect(function(i)
                    if not listening then return end
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then return end
                    listening=false
                    if i.KeyCode~=Enum.KeyCode.Escape then
                        cur=i.KeyCode; ClineUI.Flags[ec.Flag]=cur; ec.Callback(cur); Window:SaveConfig()
                    end
                    KBtn.Text=KN(cur); U.Tween(KBtn,{BackgroundColor3=T.SurfaceAlt},TI_FAST)
                end)

                local El={_row=Row,_title=ec.Title,_desc=ec.Description,_flag=ec.Flag,Value=cur}
                Window._flagCbs[ec.Flag]=function(v) cur=v; KBtn.Text=KN(v); El.Value=v end
                table.insert(Section._elements, El)
                return El
            end

            -- ════════════════════════════════════════════════
            -- LABEL
            -- ════════════════════════════════════════════════
            function Section:AddLabel(elCfg)
                elCfg = elCfg or {}
                local text = elCfg.Text or elCfg.Title or ""
                if #Section._elements > 0 then
                    U.New("Frame",{
                        Size=UDim2.new(1,0,0,1), BackgroundColor3=T.Border,
                        BackgroundTransparency=0.55, BorderSizePixel=0, ZIndex=5, Parent=Inner,
                    })
                end
                local Row = U.New("Frame",{
                    Size=UDim2.new(1,0,0,28), BackgroundTransparency=1, ZIndex=6, Parent=Inner,
                })
                local Lbl = U.Label(Row,{
                    Size=UDim2.new(1,0,1,0), Text=text, TextColor3=T.TextSub,
                    TextSize=11, ZIndex=7, TextWrapped=true,
                })
                local El={_row=Row,_title=text,_desc="",_lbl=Lbl}
                function El:SetText(t) Lbl.Text=t end
                table.insert(Section._elements, El)
                return El
            end

            return Section
        end -- CreateSection
        return Tab
    end -- CreateTab

    -- theme switching
    function Window:SetTheme(name)
        local nt = Themes[name]; if not nt then return end
        T=nt
        Main.BackgroundColor3=T.Bg; mainStroke.Color=T.Border
        Sidebar.BackgroundColor3=T.SidebarBg; Header.BackgroundColor3=T.Bg
    end
    function Window:AddTheme(name, colors) Themes[name]=colors end

    task.defer(function() Window:LoadConfig() end)
    return Window
end

return ClineUI
