    Config = {},
    ElementsRegistry = {}, -- For search functionality
    ThemeObjects = {}, -- For dynamic theme changing
    Theme = {
        Background = Color3.fromRGB(15, 15, 17),
        Sidebar = Color3.fromRGB(22, 22, 25),
        Accent = Color3.fromRGB(65, 137, 255),
        Text = Color3.fromRGB(240, 240, 240),
