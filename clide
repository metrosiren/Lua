    -- ── Window Object ───────────────────────────────────────────
    local Window = {
        _gui     = Gui, _main=Main, _tabs={}, _activeTab=nil,
        _visible = true, _flagCbs={}, _cfg=WC,
    }

    -- visibility
    local function SetVisible(v)
        Window._visible = v
        if v then
            Main.Visible = true
            U.Tween(Main,{GroupTransparency=0}, TI_MED)
        else
            local tw = TweenService:Create(Main, TI_MED, {GroupTransparency=1})
            tw.Completed:Connect(function() if not Window._visible then Main.Visible=false end end)
            tw:Play()
        end
    end
    CloseBtn.MouseButton1Click:Connect(function() SetVisible(false) end)
    UserInputService.InputBegan:Connect(function(i,p)
        if not p and i.KeyCode==WC.Keybind then SetVisible(not Window._visible) end
    end)

    -- config
    function Window:SaveConfig()
        local d={}; for k,v in pairs(ClineUI.Flags) do d[k]=v end
        U.SaveCfg(WC.ConfigName, d)
    end
    function Window:LoadConfig()
        for flag,val in pairs(U.LoadCfg(WC.ConfigName)) do
            ClineUI.Flags[flag]=val
            if Window._flagCbs[flag] then Window._flagCbs[flag](val) end
        end
    end

    -- search
    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q=SearchBox.Text:lower()
        for _,tab in ipairs(Window._tabs) do
            for _,sec in ipairs(tab._sections) do
                for _,el in ipairs(sec._elements) do
                    if el._row then
                        local m = q==""
                            or (el._title or ""):lower():find(q,1,true)
                            or (el._desc  or ""):lower():find(q,1,true)
                        el._row.Visible = m~=nil and m~=false
                    end
                end
            end
        end
    end)

    -- tab selection
    function Window:_SelectTab(tab)
        for _,t in ipairs(self._tabs) do
            local active = t==tab
            t._scroll.Visible = active

            -- active: accent-tinted bg + left accent bar visible + accent text
            U.Tween(t._btnBg, {BackgroundColor3 = active and T.AccentBg or T.SidebarBg}, TI_FAST)
            U.Tween(t._btnBar, {BackgroundTransparency = active and 0 or 1}, TI_FAST)
            U.Tween(t._btnLbl, {TextColor3 = active and T.Accent or T.TextSub}, TI_FAST)
        end
        self._activeTab = tab
    end

    -- ── CreateTab ──────────────────────────────────────────────
    function Window:CreateTab(tabCfg)
        tabCfg = tabCfg or {}
        local tc = { Title=tabCfg.Title or "Tab", Icon=tabCfg.Icon or "" }

        -- sidebar tab button
        local BtnWrap = U.New("Frame",{
            Size=UDim2.new(1,0,0,32), BackgroundTransparency=1, ZIndex=3, Parent=TabBtnList,
