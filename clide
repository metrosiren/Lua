-- UTILITIES
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
local U = {}

function U.Tween(obj, props, ti)
    TweenService:Create(obj, ti or TI_MED, props):Play()
end

function U.Screen()
    return workspace.CurrentCamera.ViewportSize
end

function U.IsMobile()
    return UserInputService.TouchEnabled and not UserInputService.MouseEnabled
end

function U.Clamp(v, a, b)
    return math.max(a, math.min(b, v))
end

function U.Round(n, d)
    local f = 10^(d or 0)
    return math.floor(n*f+0.5)/f
end

function U.Hex(c)
    return string.format("%02X%02X%02X",
        math.floor(c.R*255+.5), math.floor(c.G*255+.5), math.floor(c.B*255+.5))
end

function U.FromHex(h)
    h = h:gsub("#","")
    return Color3.fromRGB(tonumber(h:sub(1,2),16), tonumber(h:sub(3,4),16), tonumber(h:sub(5,6),16))
end

function U.New(class, props)
    local obj = Instance.new(class)
    for k,v in pairs(props) do obj[k] = v end
    return obj
end

function U.Corner(p, r)
    return U.New("UICorner",{CornerRadius=UDim.new(0,r or 8),Parent=p})
end

function U.Stroke(p, col, thickness, trans)
    local s = U.New("UIStroke",{
        Color=col, Thickness=thickness or 1,
        Transparency=trans or 0,
        ApplyStrokeMode=Enum.ApplyStrokeMode.Border,
        Parent=p,
    })
    return s
end

function U.Pad(p, t, r, b, l)
    return U.New("UIPadding",{
        PaddingTop=UDim.new(0,t or 8), PaddingRight=UDim.new(0,r or 8),
        PaddingBottom=UDim.new(0,b or 8), PaddingLeft=UDim.new(0,l or 8),
        Parent=p,
    })
end

function U.VList(p, gap)
    return U.New("UIListLayout",{
        Padding=UDim.new(0,gap or 0),
        FillDirection=Enum.FillDirection.Vertical,
        HorizontalAlignment=Enum.HorizontalAlignment.Left,
        VerticalAlignment=Enum.VerticalAlignment.Top,
        SortOrder=Enum.SortOrder.LayoutOrder,
        Parent=p,
    })
end

function U.Label(p, props)
    local lbl = U.New("TextLabel",{
        BackgroundTransparency = 1,
        Font = props.Bold and Enum.Font.GothamBold or Enum.Font.Gotham,
        TextXAlignment = props.Align or Enum.TextXAlignment.Left,
        TextTruncate   = Enum.TextTruncate.AtEnd,
        Parent = p,
    })
    for k,v in pairs(props) do
        if k~="Bold" and k~="Align" then pcall(function() lbl[k]=v end) end
    end
    return lbl
end

function U.InBounds(pos, absPos, absSize)
    return pos.X >= absPos.X and pos.X <= absPos.X+absSize.X
       and pos.Y >= absPos.Y and pos.Y <= absPos.Y+absSize.Y
end

function U.SaveCfg(name, data)
    pcall(function()
        if not isfolder(CONFIG_DIR) then makefolder(CONFIG_DIR) end
        writefile(CONFIG_DIR.."/"..name..CONFIG_EXT, HttpService:JSONEncode(data))
    end)
end

function U.LoadCfg(name)
    local ok, r = pcall(function()
        if isfile(CONFIG_DIR.."/"..name..CONFIG_EXT) then
            return HttpService:JSONDecode(readfile(CONFIG_DIR.."/"..name..CONFIG_EXT))
        end
    end)
    return (ok and r) or {}
end

