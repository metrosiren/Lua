        local BtnBg = U.New("Frame",{
            Size=UDim2.new(1,0,1,0), BackgroundColor3=T.SidebarBg,
            BorderSizePixel=0, ZIndex=3, Parent=BtnWrap,
        })
        U.Corner(BtnBg, 6)

        -- left accent bar (hidden by default)
        local BtnBar = U.New("Frame",{
            Size=UDim2.new(0,2,0,16), Position=UDim2.new(0,0,0.5,-8),
            BackgroundColor3=T.Accent, BorderSizePixel=0,
            BackgroundTransparency=1, ZIndex=5, Parent=BtnWrap,
        })
        U.Corner(BtnBar, 2)

        -- icon + label
        local iconText = tc.Icon ~= "" and (tc.Icon.." ") or ""
        local BtnLbl = U.Label(BtnWrap,{
            Size=UDim2.new(1,-16,1,0), Position=UDim2.new(0,12,0,0),
            Text=iconText..tc.Title, TextColor3=T.TextSub,
            TextSize=12, Bold=false, ZIndex=5,
        })

        -- invisible click region
        local BtnClick = U.New("TextButton",{
            Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
            Text="", ZIndex=6, Parent=BtnWrap,
        })
        BtnClick.MouseEnter:Connect(function()
            if Window._activeTab ~= Tab then
                U.Tween(BtnBg,{BackgroundColor3=T.SurfaceHov},TI_FAST)
                U.Tween(BtnLbl,{TextColor3=T.TextPrim},TI_FAST)
            end
        end)
        BtnClick.MouseLeave:Connect(function()
            if Window._activeTab ~= Tab then
                U.Tween(BtnBg,{BackgroundColor3=T.SidebarBg},TI_FAST)
                U.Tween(BtnLbl,{TextColor3=T.TextSub},TI_FAST)
            end
        end)
        BtnClick.MouseButton1Click:Connect(function() Window:_SelectTab(Tab) end)

        -- scrolling content frame
        local Scroll = U.New("ScrollingFrame",{
            Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
            BorderSizePixel=0, ScrollBarThickness=2,
            ScrollBarImageColor3=T.Scrollbar,
            CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
            ClipsDescendants=true, Visible=false, ZIndex=3, Parent=ContentArea,
        })
        U.VList(Scroll, 8)
        U.Pad(Scroll, CONTENT_PY, CONTENT_PX, CONTENT_PY, CONTENT_PX)

        local Tab = {
            _btn    = BtnClick, _btnBg=BtnBg, _btnBar=BtnBar, _btnLbl=BtnLbl,
            _scroll = Scroll, _sections={}, _title=tc.Title,
        }

        table.insert(Window._tabs, Tab)
        if #Window._tabs == 1 then Window:_SelectTab(Tab) end

        -- ── CreateSection ──────────────────────────────────
        function Tab:CreateSection(secCfg)
            secCfg = secCfg or {}
            local sc = { Title=secCfg.Title or "" }

            -- section card
            local Card = U.New("Frame",{
                Name="Section", Size=UDim2.new(1,0,0,0),
                AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundColor3=T.Surface, BorderSizePixel=0, ZIndex=4, Parent=Scroll,
            })
            U.Corner(Card, 8)
            U.Stroke(Card, T.Border, 1)

            -- optional section title
            local topOffset = SEC_PAD_V
            if sc.Title ~= "" then
                topOffset = 34
                U.Label(Card,{
                    Size=UDim2.new(1,-24,0,12), Position=UDim2.new(0,12,0,12),
                    Text=sc.Title, TextColor3=T.TextSub, TextSize=10, Bold=true, ZIndex=5,
                })
                U.New("Frame",{
                    Size=UDim2.new(1,-24,0,1), Position=UDim2.new(0,12,0,28),
                    BackgroundColor3=T.Border, BorderSizePixel=0, ZIndex=5, Parent=Card,
                })
            end

            -- inner row container
            local Inner = U.New("Frame",{
                Name="Inner", Size=UDim2.new(1,-24,0,0),
                Position=UDim2.new(0,12,0,topOffset),
                AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1, ZIndex=5, Parent=Card,
            })
            U.VList(Inner, 0)

            local Section = { _card=Card, _inner=Inner, _elements={} }
            table.insert(Tab._sections, Section)

            -- ── row builder ─────────────────────────────────
            local function MakeRow(ec)
                local hasDesc = ec.Description and ec.Description ~= ""
                local h = hasDesc and ROW_H_DESC or ROW_H

                -- thin divider before each element (except first)
                if #Section._elements > 0 then
                    U.New("Frame",{
                        Size=UDim2.new(1,0,0,1), BackgroundColor3=T.Border,
                        BackgroundTransparency=0.55, BorderSizePixel=0, ZIndex=5, Parent=Inner,
                    })
                end

                local Row = U.New("Frame",{
                    Size=UDim2.new(1,0,0,h), BackgroundTransparency=1, ZIndex=6, Parent=Inner,
                })

                -- left: title + description
                local Left = U.New("Frame",{
                    Size=UDim2.new(0.55,0,1,0), BackgroundTransparency=1, ZIndex=7, Parent=Row,
                })
                if hasDesc then
                    U.Label(Left,{
                        Size=UDim2.new(1,0,0,15), Position=UDim2.new(0,0,0.5,-17),
                        Text=ec.Title or "", TextColor3=T.TextPrim, TextSize=12, ZIndex=8,
                    })
                    U.Label(Left,{
                        Size=UDim2.new(1,0,0,11), Position=UDim2.new(0,0,0.5,-1),
                        Text=ec.Description, TextColor3=T.TextSub, TextSize=10, ZIndex=8,
                    })
                else
                    U.Label(Left,{
                        Size=UDim2.new(1,0,1,0),
                        Text=ec.Title or "", TextColor3=T.TextPrim, TextSize=12, ZIndex=8,
                    })
                end

                -- right: control area
                local Right = U.New("Frame",{
                    Name="Right", Size=UDim2.new(0.43,0,1,0),
                    Position=UDim2.new(0.57,0,0,0),
                    BackgroundTransparency=1, ZIndex=7, Parent=Row,
                })

                return Row, Right
            end

            -- ════════════════════════════════════════════════
            -- TOGGLE
            -- ════════════════════════════════════════════════
            function Section:AddToggle(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title=elCfg.Title or "Toggle", Description=elCfg.Description or "",
                    Default=elCfg.Default or false, Flag=elCfg.Flag or elCfg.Title,
                    Callback=elCfg.Callback or function()end,
                }
                local Row, Right = MakeRow(ec)

                local Pill = U.New("Frame",{
                    Size=UDim2.new(0,34,0,18), Position=UDim2.new(1,-34,0.5,-9),
                    BackgroundColor3=ec.Default and T.ToggleOn or T.ToggleOff,
                    BorderSizePixel=0, ZIndex=8, Parent=Right,
                })
                U.Corner(Pill, 9)

                local Knob = U.New("Frame",{
                    Size=UDim2.new(0,12,0,12),
                    Position=ec.Default and UDim2.new(1,-15,0.5,-6) or UDim2.new(0,3,0.5,-6),
                    BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0, ZIndex=9, Parent=Pill,
                })
                U.Corner(Knob, 6)

                local val = ec.Default
                ClineUI.Flags[ec.Flag] = val
                local El = {_row=Row,_title=ec.Title,_desc=ec.Description,_flag=ec.Flag,Value=val}

                local function Set(new, silent)
                    val=new; El.Value=val; ClineUI.Flags[ec.Flag]=val
                    U.Tween(Pill, {BackgroundColor3=val and T.ToggleOn or T.ToggleOff}, TI_FAST)
                    U.Tween(Knob, {Position=val and UDim2.new(1,-15,0.5,-6) or UDim2.new(0,3,0.5,-6)}, TI_FAST)
                    if not silent then ec.Callback(val); Window:SaveConfig() end
                end
                El.Set = Set
                Window._flagCbs[ec.Flag] = function(v) Set(v,true) end

                local function onInput(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                        Set(not val)
                    end
                end
                Pill.InputBegan:Connect(onInput)
                Row.InputBegan:Connect(onInput)

                table.insert(Section._elements, El)
                return El
            end

            -- ════════════════════════════════════════════════
            -- BUTTON
            -- ════════════════════════════════════════════════
            function Section:AddButton(elCfg)
                elCfg = elCfg or {}
                local ec = {
                    Title=elCfg.Title or "Button", Description=elCfg.Description or "",
                    Text=elCfg.Text or "Run",
                    Callback=elCfg.Callback or function()end,
                }
                local Row, Right = MakeRow(ec)

                local Btn = U.New("TextButton",{
                    Size=UDim2.new(0,72,0,26), Position=UDim2.new(1,-72,0.5,-13),
                    BackgroundColor3=T.Accent, BorderSizePixel=0,
                    Text=ec.Text, TextColor3=Color3.fromRGB(255,255,255),
                    TextSize=11, Font=Enum.Font.GothamBold, ZIndex=8, Parent=Right,
                })
                U.Corner(Btn, 6)

                Btn.MouseEnter:Connect(function()   U.Tween(Btn,{BackgroundColor3=T.AccentHov},TI_FAST) end)
                Btn.MouseLeave:Connect(function()   U.Tween(Btn,{BackgroundColor3=T.Accent},TI_FAST) end)
                Btn.MouseButton1Down:Connect(function()
                    U.Tween(Btn,{BackgroundColor3=T.AccentPress,Size=UDim2.new(0,68,0,24)},TI_FAST)
                end)
                Btn.MouseButton1Up:Connect(function()
                    U.Tween(Btn,{BackgroundColor3=T.AccentHov,Size=UDim2.new(0,72,0,26)},TI_FAST)
                end)
                Btn.MouseButton1Click:Connect(function() ec.Callback() end)

                local El = {_row=Row,_title=ec.Title,_desc=ec.Description,_btn=Btn}
