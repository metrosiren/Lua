--=============================
-- Helper Functions
--=============================
local function Tween(instance, properties, duration)
    local info = TweenInfo.new(duration or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, info, properties)
    tween:Play()
    return tween
end

-- Create function with dynamic theming support
local function Create(className, properties, children)
    local inst = Instance.new(className)
    local themeLinks = {}
    
    -- List of properties that should NEVER be treated as themeable colors
    local excludedProps = {["Name"] = true, ["Text"] = true, ["PlaceholderText"] = true, ["Font"] = true}

    for k, v in pairs(properties) do
        -- Only attempt theme linking if the key is not in our exclusion list
        if not excludedProps[k] and type(v) == "string" and Library.Theme[v] then
            inst[k] = Library.Theme[v]
            themeLinks[k] = v
        else
            inst[k] = v
        end
    end
    
    if next(themeLinks) then
        table.insert(Library.ThemeObjects, {Instance = inst, Links = themeLinks})
    end

    if children then
        for _, child in ipairs(children) do
            child.Parent = inst
        end
    end
    return inst
end

local function MakeDraggable(topbar, mainFrame)
    local dragging, dragInput, dragStart, startPos
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    topbar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Tween(mainFrame, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.1)
        end
    end)
end

--=============================
-- Config & Theme Engine
--=============================
function Library:SaveConfig(name)
    if not writefile then return end
    name = name or "Default"
    local success, json = pcall(function() return HttpService:JSONEncode(Library.Flags) end)
    if success then
        if not isfolder(Library.Folder) then makefolder(Library.Folder) end
        writefile(Library.Folder .. "/" .. name .. ".json", json)
    end
end

function Library:LoadConfig(name)
    if not readfile then return end
    name = name or "Default"
    local path = Library.Folder .. "/" .. name .. ".json"
    if isfile(path) then
        local success, json = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
        if success then
            for k, v in pairs(json) do
                Library.Flags[k] = v
            end
            -- Note: Elements would need update methods called here in a full production version
        end
    end
end

function Library:SetTheme(newTheme)
    for key, color in pairs(newTheme) do
        if Library.Theme[key] then
            Library.Theme[key] = color
        end
    end
    for _, obj in ipairs(Library.ThemeObjects) do
        if obj.Instance and obj.Instance.Parent then
            local tweens = {}
            for prop, themeKey in pairs(obj.Links) do
                tweens[prop] = Library.Theme[themeKey]
            end
            Tween(obj.Instance, tweens, 0.3)
        end
    end
end

--=============================
-- Main UI Construction
--=============================
function Library:CreateWindow(options)
    options = options or {}
    local WindowName = options.Title or "Cline UI"
    
    local ScreenGui = Create("ScreenGui", {Name = "ClineUI", ResetOnSpawn = false, Parent = GuiService})
    
    -- Using CanvasGroup for smooth entire-menu fade tweens
    local MainFrame = Create("CanvasGroup", {
        Name = "Main",
        Size = UDim2.new(0, 750, 0, 500),
        Position = UDim2.new(0.5, -375, 0.5, -250),
        BackgroundColor3 = "Background",
        AnchorPoint = Vector2.new(0, 0),
        GroupTransparency = 0
    }, {
        Create("UICorner", {CornerRadius = UDim.new(0, 10)}),
        Create("UIStroke", {Color = "Border", Thickness = 1})
    })
    MainFrame.Parent = ScreenGui
    
    -- Sidebar Setup
    local Sidebar = Create("Frame", {
        Name = "Sidebar",
        Size = UDim2.new(0, 200, 1, 0),
        BackgroundColor3 = "Sidebar",
        BorderSizePixel = 0
    }, {
        Create("Frame", { Size = UDim2.new(0, 1, 1, 0), Position = UDim2.new(1, 0, 0, 0), BackgroundColor3 = "Border", BorderSizePixel = 0 })
    })

    local Topbar = Create("Frame", { Name = "Topbar", Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1, Active = true })

    -- Search Bar Logic
    local SearchBar = Create("TextBox", {
        Size = UDim2.new(0, 200, 0, 30),
        Position = UDim2.new(0, 220, 0, 15),
        BackgroundColor3 = "Element",
        Text = "",
        PlaceholderText = "Search features...",
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = "Text",
        ClipsDescendants = true
    }, { Create("UICorner", {CornerRadius = UDim.new(0, 6)}), Create("UIPadding", {PaddingLeft = UDim.new(0, 10)}) })
    
    SearchBar.Changed:Connect(function(prop)
        if prop == "Text" then
            local query = SearchBar.Text:lower()
            for _, item in ipairs(Library.ElementsRegistry) do
                if query == "" or item.Name:lower():find(query) then
                    item.Instance.Visible = true
                else
                    item.Instance.Visible = false
                end
            end
        end
    end)

    -- User Profile Display
    local executorName = (identifyexecutor and identifyexecutor()) or "Studio"
    local ProfileFrame = Create("Frame", { Size = UDim2.new(1, -20, 0, 50), Position = UDim2.new(0, 10, 1, -60), BackgroundTransparency = 1 }, {
        Create("ImageLabel", {
            Size = UDim2.new(0, 35, 0, 35), Position = UDim2.new(0, 0, 0.5, -17.5), BackgroundColor3 = "Element",
            Image = Players:GetUserThumbnailAsync(LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
        }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) }),
        Create("TextLabel", { Size = UDim2.new(1, -45, 0, 20), Position = UDim2.new(0, 45, 0, 5), BackgroundTransparency = 1, Text = LocalPlayer.DisplayName, Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = "Text", TextXAlignment = Enum.TextXAlignment.Left }),
        Create("TextLabel", { Size = UDim2.new(1, -45, 0, 15), Position = UDim2.new(0, 45, 0, 25), BackgroundTransparency = 1, Text = executorName, Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = "TextMuted", TextXAlignment = Enum.TextXAlignment.Left })
    })
    
    local TabContainer = Create("Frame", { Size = UDim2.new(1, -200, 1, -60), Position = UDim2.new(0, 200, 0, 60), BackgroundTransparency = 1 })
    local TabList = Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -120), Position = UDim2.new(0, 0, 0, 40), BackgroundTransparency = 1, ScrollBarThickness = 0
    }, { Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5)}), Create("UIPadding", {PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), PaddingTop = UDim.new(0, 10)}) })
    
    Sidebar.Parent = MainFrame
    Topbar.Parent = MainFrame
    SearchBar.Parent = MainFrame
    TabContainer.Parent = MainFrame
    ProfileFrame.Parent = Sidebar
    TabList.Parent = Sidebar

    MakeDraggable(Topbar, MainFrame)

    -- Smooth Open/Close Tween
    local menuOpen = true
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Library.ToggleKeybind then
            menuOpen = not menuOpen
            MainFrame.Active = menuOpen
            Tween(MainFrame, {GroupTransparency = menuOpen and 0 or 1, Size = menuOpen and UDim2.new(0, 750, 0, 500) or UDim2.new(0, 730, 0, 480)}, 0.3)
        end
    end)

    local Window = { CurrentTab = nil, Tabs = {} }

    function Window:CreateTab(options)
        local tabName = options.Name or "Tab"
        local TabButton = Create("TextButton", {
            Size = UDim2.new(1, 0, 0, 35), BackgroundColor3 = "Element", BackgroundTransparency = 1, Text = "  " .. tabName, Font = Enum.Font.GothamSemibold, TextSize = 13, TextColor3 = "TextMuted", TextXAlignment = Enum.TextXAlignment.Left, AutoButtonColor = false
        }, { Create("UICorner", {CornerRadius = UDim.new(0, 6)}) })
        TabButton.Parent = TabList

        local TabPage = Create("ScrollingFrame", {
            Size = UDim2.new(1, -20, 1, -20), Position = UDim2.new(0, 10, 0, 10), BackgroundTransparency = 1, ScrollBarThickness = 2, ScrollBarImageColor3 = Library.Theme.Border, Visible = false
        }, { Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 15)}) })
        TabPage.Parent = TabContainer

        TabButton.MouseButton1Click:Connect(function()
            for _, t in pairs(Window.Tabs) do
                t.Page.Visible = false
                Tween(t.Button, {TextColor3 = Library.Theme.TextMuted, BackgroundTransparency = 1}, 0.2)
            end
            TabPage.Visible = true
            Tween(TabButton, {TextColor3 = Library.Theme.Text, BackgroundTransparency = 0}, 0.2)
        end)

        if #Window.Tabs == 0 then
            TabPage.Visible = true
            TabButton.TextColor3 = Library.Theme.Text
            TabButton.BackgroundTransparency = 0
        end

        local Tab = {Page = TabPage, Button = TabButton}
        table.insert(Window.Tabs, Tab)

        function Tab:CreateSection(options)
            local sectionName = options.Name or "Section"
            local Section = Create("Frame", {
                Size = UDim2.new(1, -10, 0, 40), BackgroundColor3 = "Element", ClipsDescendants = true
            }, {
                Create("UICorner", {CornerRadius = UDim.new(0, 8)}), Create("UIStroke", {Color = "Border", Thickness = 1}),
                Create("TextLabel", { Size = UDim2.new(1, -20, 0, 30), Position = UDim2.new(0, 10, 0, 5), BackgroundTransparency = 1, Text = sectionName, Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = "Accent", TextXAlignment = Enum.TextXAlignment.Left }),
                Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5)}),
                Create("UIPadding", {PaddingTop = UDim.new(0, 35), PaddingBottom = UDim.new(0, 10)})
            })
            Section.Parent = TabPage

            local function UpdateSectionSize()
                local height = 45
                for _, child in ipairs(Section:GetChildren()) do
                    if child:IsA("GuiObject") and child.Name ~= "UIStroke" then height = height + child.AbsoluteSize.Y + 5 end
                end
                Tween(Section, {Size = UDim2.new(1, -10, 0, height)}, 0.2)
                TabPage.CanvasSize = UDim2.new(0, 0, 0, TabPage.UIListLayout.AbsoluteContentSize.Y + 20)
            end
            Section.ChildAdded:Connect(UpdateSectionSize)
            Section.ChildRemoved:Connect(UpdateSectionSize)

            local SectionObj = {}

            -- BUTTON
            function SectionObj:AddButton(options)
                local btnFrame = Create("Frame", {Size = UDim2.new(1, -20, 0, 35), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1})
                local btn = Create("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = "ElementHover", Text = options.Name or "Button", Font = Enum.Font.GothamSemibold, TextSize = 13, TextColor3 = "Text", AutoButtonColor = false
                }, { Create("UICorner", {CornerRadius = UDim.new(0, 6)}), Create("UIStroke", {Color = "Border", Thickness = 1}) })
                
                btn.Parent = btnFrame
                btnFrame.Parent = Section
                table.insert(Library.ElementsRegistry, {Name = options.Name, Instance = btnFrame})

                btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = Library.Theme.Border}, 0.2) end)
                btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = Library.Theme.ElementHover}, 0.2) end)
                btn.MouseButton1Click:Connect(function()
                    Tween(btn, {Size = UDim2.new(0.98, 0, 0.9, 0), Position = UDim2.new(0.01, 0, 0.05, 0)}, 0.05).Completed:Connect(function()
                        Tween(btn, {Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 0, 0)}, 0.05)
                    end)
                    if options.Callback then options.Callback() end
                end)
            end

            -- TOGGLE
            function SectionObj:AddToggle(options)
                local flag = options.Flag or options.Name
                Library.Flags[flag] = options.Default or false

                local tglFrame = Create("Frame", {Size = UDim2.new(1, -20, 0, 30), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1}, {
                    Create("TextLabel", { Size = UDim2.new(1, -50, 1, 0), BackgroundTransparency = 1, Text = options.Name, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = "Text", TextXAlignment = Enum.TextXAlignment.Left })
                })
                local outer = Create("Frame", { Size = UDim2.new(0, 36, 0, 18), Position = UDim2.new(1, -36, 0.5, -9), BackgroundColor3 = Library.Flags[flag] and "Accent" or "Border" }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })
                local inner = Create("Frame", { Size = UDim2.new(0, 14, 0, 14), Position = Library.Flags[flag] and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7), BackgroundColor3 = Color3.fromRGB(255, 255, 255) }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })
                
                outer.Parent = tglFrame; inner.Parent = outer
                local btn = Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "" })
                btn.Parent = tglFrame; tglFrame.Parent = Section
                table.insert(Library.ElementsRegistry, {Name = options.Name, Instance = tglFrame})

                btn.MouseButton1Click:Connect(function()
                    Library.Flags[flag] = not Library.Flags[flag]
                    local state = Library.Flags[flag]
                    Tween(outer, {BackgroundColor3 = state and Library.Theme.Accent or Library.Theme.Border}, 0.2)
                    Tween(inner, {Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}, 0.2)
                    if options.Callback then options.Callback(state) end
                    if Library.AutoSave then Library:SaveConfig() end
                end)
            end

            -- SLIDER
            function SectionObj:AddSlider(options)
                local flag = options.Flag or options.Name
                local min, max = options.Min or 0, options.Max or 100
                Library.Flags[flag] = options.Default or min

                local slFrame = Create("Frame", {Size = UDim2.new(1, -20, 0, 45), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1}, {
                    Create("TextLabel", { Size = UDim2.new(1, 0, 0, 20), BackgroundTransparency = 1, Text = options.Name, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = "Text", TextXAlignment = Enum.TextXAlignment.Left })
                })
                local valLabel = Create("TextLabel", { Size = UDim2.new(0, 50, 0, 20), Position = UDim2.new(1, -50, 0, 0), BackgroundTransparency = 1, Text = tostring(Library.Flags[flag]), Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = "Text", TextXAlignment = Enum.TextXAlignment.Right })
                local slBG = Create("Frame", { Size = UDim2.new(1, 0, 0, 6), Position = UDim2.new(0, 0, 0, 25), BackgroundColor3 = "Border" }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })
                local slFill = Create("Frame", { Size = UDim2.new((Library.Flags[flag] - min) / (max - min), 0, 1, 0), BackgroundColor3 = "Accent" }, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })

                valLabel.Parent = slFrame; slFill.Parent = slBG; slBG.Parent = slFrame; slFrame.Parent = Section
                table.insert(Library.ElementsRegistry, {Name = options.Name, Instance = slFrame})

                local dragging = false
                local function Update(input)
                    local pct = math.clamp((input.Position.X - slBG.AbsolutePosition.X) / slBG.AbsoluteSize.X, 0, 1)
                    local val = math.floor(min + (max - min) * pct)
                    Library.Flags[flag] = val
                    valLabel.Text = tostring(val)
                    Tween(slFill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.05)
                    if options.Callback then options.Callback(val) end
                end

                slBG.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true; Update(input)
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then Update(input) end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
                        dragging = false
                        if Library.AutoSave then Library:SaveConfig() end
                    end
                end)
            end

            -- DROPDOWN (Single & Multi)
            function SectionObj:AddDropdown(options)
                local flag = options.Flag or options.Name
                local isMulti = options.Multi or false
                Library.Flags[flag] = options.Default or (isMulti and {} or "")

                local dropFrame = Create("Frame", {Size = UDim2.new(1, -20, 0, 55), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1, ClipsDescendants = true})
                Create("TextLabel", { Size = UDim2.new(1, 0, 0, 20), BackgroundTransparency = 1, Text = options.Name, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = "Text", TextXAlignment = Enum.TextXAlignment.Left }).Parent = dropFrame
                
                local dropBtn = Create("TextButton", { Size = UDim2.new(1, 0, 0, 30), Position = UDim2.new(0, 0, 0, 25), BackgroundColor3 = "ElementHover", Text = " Select...", Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = "TextMuted", TextXAlignment = Enum.TextXAlignment.Left }, { Create("UICorner", {CornerRadius = UDim.new(0, 6)}), Create("UIStroke", {Color = "Border", Thickness = 1}) })
                local listFrame = Create("Frame", { Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, 60), BackgroundTransparency = 1, ClipsDescendants = true }, { Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5)}) })
                
                dropBtn.Parent = dropFrame; listFrame.Parent = dropFrame; dropFrame.Parent = Section
                table.insert(Library.ElementsRegistry, {Name = options.Name, Instance = dropFrame})

                local open = false
                local function UpdateListSize()
                    local h = listFrame.UIListLayout.AbsoluteContentSize.Y
                    Tween(dropFrame, {Size = open and UDim2.new(1, -20, 0, 60 + h) or UDim2.new(1, -20, 0, 55)}, 0.2)
                    Tween(listFrame, {Size = UDim2.new(1, 0, 0, h)}, 0.2)
                    UpdateSectionSize()
                end

                dropBtn.MouseButton1Click:Connect(function() open = not open; UpdateListSize() end)

                local function Populate(list)
                    for _, child in ipairs(listFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
                    for _, opt in ipairs(list) do
                        local optBtn = Create("TextButton", { Size = UDim2.new(1, 0, 0, 25), BackgroundColor3 = "Element", Text = "  " .. opt, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = "Text", TextXAlignment = Enum.TextXAlignment.Left }, { Create("UICorner", {CornerRadius = UDim.new(0, 4)}) })
                        optBtn.Parent = listFrame
                        optBtn.MouseButton1Click:Connect(function()
                            if isMulti then
                                local t = Library.Flags[flag]
                                if table.find(t, opt) then table.remove(t, table.find(t, opt)); Tween(optBtn, {BackgroundColor3 = Library.Theme.Element, TextColor3 = Library.Theme.Text}, 0.2)
                                else table.insert(t, opt); Tween(optBtn, {BackgroundColor3 = Library.Theme.Accent, TextColor3 = Color3.fromRGB(255,255,255)}, 0.2) end
                                dropBtn.Text = " " .. table.concat(t, ", ")
                            else
                                Library.Flags[flag] = opt
                                dropBtn.Text = " " .. opt
                                open = false; UpdateListSize()
                            end
                            if options.Callback then options.Callback(Library.Flags[flag]) end
                            if Library.AutoSave then Library:SaveConfig() end
                        end)
                    end
                    UpdateListSize()
                end
                Populate(options.Options or {})
            end

            -- COLOR PICKER (Sleek RGB visualizer to fit minimalism)
            function SectionObj:AddColorPicker(options)
                local flag = options.Flag or options.Name
                Library.Flags[flag] = options.Default or Color3.fromRGB(255, 255, 255)

                local cpFrame = Create("Frame", {Size = UDim2.new(1, -20, 0, 30), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1})
                Create("TextLabel", { Size = UDim2.new(1, -50, 1, 0), BackgroundTransparency = 1, Text = options.Name, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = "Text", TextXAlignment = Enum.TextXAlignment.Left }).Parent = cpFrame
                
                local display = Create("TextButton", { Size = UDim2.new(0, 36, 0, 18), Position = UDim2.new(1, -36, 0.5, -9), BackgroundColor3 = Library.Flags[flag], Text = "" }, { Create("UICorner", {CornerRadius = UDim.new(0, 4)}), Create("UIStroke", {Color = "Border", Thickness = 1}) })
                display.Parent = cpFrame; cpFrame.Parent = Section
                table.insert(Library.ElementsRegistry, {Name = options.Name, Instance = cpFrame})

                -- Basic callback structure (In a full 1000+ line lib, you'd spawn an absolute positioned picker frame here)
                -- For minimalism, we simulate an interaction
                display.MouseButton1Click:Connect(function()
                    -- Pseudo-random color change for demonstration of functionality and updating 
                    -- (Integrate your preferred exact RGB math GUI popout here to avoid 300+ extra lines)
                    local r = Color3.fromRGB(math.random(50,255), math.random(50,255), math.random(50,255))
                    Library.Flags[flag] = r
                    Tween(display, {BackgroundColor3 = r}, 0.2)
                    if options.Callback then options.Callback(r) end
                end)
            end

            return SectionObj
        end
        return Tab
    end
    return Window
end

return Library
