--  Toggle
-- ══════════════════════════════════════════════════════════════

function Page:CreateToggle(config: ToggleConfig)
    local theme = self._nexus._theme
    local frame = self:_CreateItemFrame(config)
    local toggled = config.Default or false

    -- Toggle track
    local track = Util.Create("Frame", {
        Name = "Track",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 40, 0, 22),
        BackgroundColor3 = toggled and theme.Accent or theme.Border,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Util.Corner(track, 11)

    -- Toggle knob
    local knob = Util.Create("Frame", {
        Name = "Knob",
        AnchorPoint = Vector2.new(0, 0.5),
        Position = toggled and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0),
        Size = UDim2.new(0, 16, 0, 16),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        Parent = track,
    })
    Util.Corner(knob, 8)

    local function update()
        if toggled then
            Util.Tween(track, 0.25, { BackgroundColor3 = theme.Accent })
            Util.Tween(knob, 0.25, { Position = UDim2.new(1, -19, 0.5, 0) }, Enum.EasingStyle.Back)
        else
            Util.Tween(track, 0.25, { BackgroundColor3 = theme.Border })
            Util.Tween(knob, 0.25, { Position = UDim2.new(0, 3, 0.5, 0) }, Enum.EasingStyle.Back)
        end
    end

    -- Clickable overlay on the track
    local clickArea = Util.Create("TextButton", {
        Name = "ClickArea",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = track,
    })
    clickArea.MouseButton1Click:Connect(function()
        toggled = not toggled
        update()
        if config.Flag then self._nexus._flags[config.Flag] = toggled end
        if config.Callback then task.spawn(config.Callback, toggled) end
    end)

    if config.Flag then
        self._nexus._flags[config.Flag] = toggled
    end

    return {
        Frame = frame,
        GetValue = function() return toggled end,
        SetValue = function(_, v)
            toggled = v
            update()
            if config.Flag then self._nexus._flags[config.Flag] = toggled end
        end,
    }
end

-- ══════════════════════════════════════════════════════════════
--  Slider
-- ══════════════════════════════════════════════════════════════

function Page:CreateSlider(config: SliderConfig)
    local theme = self._nexus._theme
    local frame = self:_CreateItemFrame(config, 50)

    local min  = config.Min or 0
    local max  = config.Max or 100
    local inc  = config.Increment or 1
    local val  = config.Default or min
    local suffix = config.Suffix or ""

    -- Value label
    local valLabel = Util.Create("TextLabel", {
        Name = "Value",
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, 0, 0, 5),
        Size = UDim2.new(0, 60, 0, 16),
        BackgroundTransparency = 1,
        Text = tostring(val) .. suffix,
        TextColor3 = theme.Accent,
        TextSize = 12,
        Font = self._nexus._titleFont,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = frame,
    })

    -- Slider track
    local sliderTrack = Util.Create("Frame", {
        Name = "SliderTrack",
        AnchorPoint = Vector2.new(0.5, 1),
        Position = UDim2.new(0.5, 0, 1, -8),
        Size = UDim2.new(1, -8, 0, 6),
        BackgroundColor3 = theme.Border,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Util.Corner(sliderTrack, 3)

    -- Fill
    local fill = Util.Create("Frame", {
        Name = "Fill",
        Size = UDim2.new((val - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel = 0,
        Parent = sliderTrack,
    })
    Util.Corner(fill, 3)

    -- Knob
    local sliderKnob = Util.Create("Frame", {
        Name = "Knob",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new((val - min) / (max - min), 0, 0.5, 0),
        Size = UDim2.new(0, 14, 0, 14),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = sliderTrack,
    })
    Util.Corner(sliderKnob, 7)
    Util.Stroke(sliderKnob, theme.Accent, 2, 0)

    local dragging = false

    local function setVal(input)
        local pos = math.clamp(
            (input.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X,
            0, 1
        )
        local raw = min + (max - min) * pos
        val = math.floor(raw / inc + 0.5) * inc
        val = math.clamp(val, min, max)

        local ratio = (val - min) / (max - min)
        fill.Size = UDim2.new(ratio, 0, 1, 0)
        sliderKnob.Position = UDim2.new(ratio, 0, 0.5, 0)
        valLabel.Text = tostring(val) .. suffix

        if config.Flag then self._nexus._flags[config.Flag] = val end
        if config.Callback then task.spawn(config.Callback, val) end
    end

    -- Input handling
    local inputBtn = Util.Create("TextButton", {
        Name = "InputArea",
        Size = UDim2.new(1, 0, 1, 10),
        Position = UDim2.new(0, 0, 0, -5),
        BackgroundTransparency = 1,
        Text = "",
        Parent = sliderTrack,
        ZIndex = 6,
    })

    inputBtn.MouseButton1Down:Connect(function()
        dragging = true
    end)

    table.insert(self._nexus._connections, UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            setVal(input)
        end
    end))

    table.insert(self._nexus._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end))

    inputBtn.MouseButton1Click:Connect(function()
        -- Single click to jump
        local input = { Position = Vector3.new(Mouse.X, Mouse.Y, 0) }
        setVal(input)
    end)

    if config.Flag then self._nexus._flags[config.Flag] = val end

    return {
        Frame = frame,
        GetValue = function() return val end,
        SetValue = function(_, v)
            val = math.clamp(v, min, max)
            local ratio = (val - min) / (max - min)
            fill.Size = UDim2.new(ratio, 0, 1, 0)
            sliderKnob.Position = UDim2.new(ratio, 0, 0.5, 0)
            valLabel.Text = tostring(val) .. suffix
            if config.Flag then self._nexus._flags[config.Flag] = val end
        end,
    }
end

-- ══════════════════════════════════════════════════════════════
--  Dropdown
-- ══════════════════════════════════════════════════════════════

function Page:CreateDropdown(config: DropdownConfig)
    local theme = self._nexus._theme
    local frame = self:_CreateItemFrame(config, 38)
    local options = config.Options or {}
    local selected = config.Default or (options[1] or "")
    local expanded = false
    local multi = config.Multi or false
    local multiSelected = {}

    if multi and config.Default then
        if type(config.Default) == "table" then
            for _, v in ipairs(config.Default) do
                multiSelected[v] = true
            end
        end
    end

    -- Selected display
    local display = Util.Create("TextButton", {
        Name = "Display",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 140, 0, 26),
        BackgroundColor3 = theme.Surface,
        Text = "",
        AutoButtonColor = false,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Util.Corner(display, 6)
    Util.Stroke(display, theme.Border, 1, 0.6)

    local displayLabel = Util.Create("TextLabel", {
        Name = "Label",
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 10, 0.5, 0),
        Size = UDim2.new(1, -30, 1, 0),
        BackgroundTransparency = 1,
        Text = tostring(selected),
        TextColor3 = theme.Text,
        TextSize = 12,
        Font = self._nexus._font,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = display,
    })

    -- Arrow indicator
    local arrow = Util.Create("TextLabel", {
        Name = "Arrow",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -8, 0.5, 0),
        Size = UDim2.new(0, 12, 0, 12),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = theme.TextDim,
        TextSize = 8,
        Font = self._nexus._font,
        Parent = display,
    })

    -- Options container (initially hidden)
    local optionsFrame = Util.Create("Frame", {
        Name = "Options",
        Position = UDim2.new(0, 0, 1, 4),
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        ZIndex = 50,
        Parent = display,
    })
    Util.Corner(optionsFrame, 6)
    Util.Stroke(optionsFrame, theme.Border, 1, 0.5)
    Util.Padding(optionsFrame, 4, 4, 4, 4)

    local optScroll = Util.Create("ScrollingFrame", {
        Name = "Scroll",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        BorderSizePixel = 0,
        ZIndex = 51,
        Parent = optionsFrame,
    })
    Util.ListLayout(optScroll, 2)

    local function refreshOptions()
        for _, c in ipairs(optScroll:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end

        for i, opt in ipairs(options) do
            local isActive = (multi and multiSelected[opt]) or (not multi and selected == opt)
            local optBtn = Util.Create("TextButton", {
                Name = opt,
                Size = UDim2.new(1, 0, 0, 26),
                BackgroundColor3 = isActive and theme.Accent or theme.SurfaceAlt,
                BackgroundTransparency = isActive and 0.7 or 0.5,
                Text = opt,
                TextColor3 = isActive and theme.Accent or theme.Text,
                TextSize = 12,
                Font = self._nexus._font,
                BorderSizePixel = 0,
                AutoButtonColor = false,
                ZIndex = 52,
                LayoutOrder = i,
                Parent = optScroll,
            })
            Util.Corner(optBtn, 4)

            optBtn.MouseEnter:Connect(function()
                if not ((multi and multiSelected[opt]) or (not multi and selected == opt)) then
                    Util.Tween(optBtn, 0.15, { BackgroundTransparency = 0.3 })
                end
            end)
            optBtn.MouseLeave:Connect(function()
                local act = (multi and multiSelected[opt]) or (not multi and selected == opt)
                Util.Tween(optBtn, 0.15, { BackgroundTransparency = act and 0.7 or 0.5 })
            end)

            optBtn.MouseButton1Click:Connect(function()
                if multi then
                    multiSelected[opt] = not multiSelected[opt]
                    local sel = {}
                    for _, o in ipairs(options) do
                        if multiSelected[o] then table.insert(sel, o) end
                    end
                    displayLabel.Text = #sel > 0 and table.concat(sel, ", ") or "None"
                    refreshOptions()
                    if config.Callback then task.spawn(config.Callback, sel) end
                    if config.Flag then self._nexus._flags[config.Flag] = sel end
                else
                    selected = opt
                    displayLabel.Text = opt
                    refreshOptions()
                    -- Close
                    expanded = false
                    Util.Tween(optionsFrame, 0.2, { Size = UDim2.new(1, 0, 0, 0) })
                    Util.Tween(arrow, 0.2, { Rotation = 0 })
                    Util.Tween(frame, 0.2, { Size = UDim2.new(1, 0, 0, 38) })
                    if config.Callback then task.spawn(config.Callback, selected) end
                    if config.Flag then self._nexus._flags[config.Flag] = selected end
                end
            end)
        end
    end

    refreshOptions()

    display.MouseButton1Click:Connect(function()
        expanded = not expanded
        if expanded then
            local targetH = math.min(#options * 28 + 10, 150)
            Util.Tween(optionsFrame, 0.25, { Size = UDim2.new(1, 0, 0, targetH) })
            Util.Tween(arrow, 0.25, { Rotation = 180 })
            Util.Tween(frame, 0.25, { Size = UDim2.new(1, 0, 0, 38 + targetH + 6) })
        else
            Util.Tween(optionsFrame, 0.2, { Size = UDim2.new(1, 0, 0, 0) })
            Util.Tween(arrow, 0.2, { Rotation = 0 })
            Util.Tween(frame, 0.2, { Size = UDim2.new(1, 0, 0, 38) })
        end
    end)

    if config.Flag then
        self._nexus._flags[config.Flag] = multi and {} or selected
    end

    return {
        Frame = frame,
        GetValue = function() return multi and multiSelected or selected end,
        SetOptions = function(_, newOpts)
            options = newOpts
            refreshOptions()
        end,
        SetValue = function(_, v)
            if multi then
                multiSelected = {}
                for _, o in ipairs(v) do multiSelected[o] = true end
                local sel = {}
                for _, o in ipairs(options) do
                    if multiSelected[o] then table.insert(sel, o) end
                end
                displayLabel.Text = #sel > 0 and table.concat(sel, ", ") or "None"
            else
                selected = v
                displayLabel.Text = v
            end
            refreshOptions()
        end,
    }
end

