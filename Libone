--  Button
-- ══════════════════════════════════════════════════════════════

function Page:CreateButton(config: ButtonConfig)
    local theme = self._nexus._theme
    local frame = self:_CreateItemFrame(config)

    local btn = Util.Create("TextButton", {
        Name = "Btn",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 80, 0, 26),
        BackgroundColor3 = theme.Accent,
        Text = "Run",
        TextColor3 = Color3.new(1, 1, 1),
        TextSize = 12,
        Font = self._nexus._titleFont,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Parent = frame,
    })
    Util.Corner(btn, 6)

    btn.MouseEnter:Connect(function()
        if not config.Disabled then
            Util.Tween(btn, 0.2, { BackgroundColor3 = theme.AccentHover, Size = UDim2.new(0, 84, 0, 28) })
        end
    end)
    btn.MouseLeave:Connect(function()
        Util.Tween(btn, 0.2, { BackgroundColor3 = theme.Accent, Size = UDim2.new(0, 80, 0, 26) })
    end)
    btn.MouseButton1Click:Connect(function()
        if config.Disabled then return end
        -- Ripple
        local mx = Mouse.X - btn.AbsolutePosition.X
        local my = Mouse.Y - btn.AbsolutePosition.Y
        Util.Ripple(btn, mx, my, Color3.new(1, 1, 1))
        -- Flash
        Util.Tween(btn, 0.1, { BackgroundColor3 = theme.AccentHover })
        task.delay(0.15, function()
            Util.Tween(btn, 0.2, { BackgroundColor3 = theme.Accent })
        end)
        if config.Callback then
            task.spawn(config.Callback)
        end
    end)

    if config.Disabled then
        btn.BackgroundTransparency = 0.5
        btn.TextTransparency = 0.5
    end

    return {
        Frame = frame,
        Button = btn,
        SetCallback = function(_, cb) config.Callback = cb end,
        SetDisabled = function(_, v)
            config.Disabled = v
            btn.BackgroundTransparency = v and 0.5 or 0
            btn.TextTransparency = v and 0.5 or 0
        end,
    }
end

