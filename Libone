local function getScreenGui(): ScreenGui
    local existing = Player.PlayerGui:FindFirstChild("NexusUI_ScreenGui")
    if existing then return existing :: ScreenGui end

    local screenGui = Util.Create("ScreenGui", {
        Name = "NexusUI_ScreenGui",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
        DisplayOrder = 999,
        Parent = Player.PlayerGui,
    })
    return screenGui :: ScreenGui
end

