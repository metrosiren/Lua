            -- Hue bar
            local hueBar = Util.Create("Frame", {
                Name = "HueBar",
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 0),
                Size = UDim2.new(0, 18, 0, 90),
