function NexusUI:_SetupInputHandlers()
    table.insert(self._connections, UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == self._toggleKey then
            self:Toggle()
        end
    end))
end

-- ══════════════════════════════════════════════════════════════
--  Visibility
-- ══════════════════════════════════════════════════════════════

function NexusUI:Toggle()
    self._visible = not self._visible
    if self._visible then
        self._screenGui.Enabled = true
        Util.Tween(self._container, self._animSpeed, {
            Size = self._windowSize,
        }, Enum.EasingStyle.Back)
        Util.Tween(self._window, self._animSpeed * 0.5, { BackgroundTransparency = 0 })
    else
        Util.Tween(self._container, self._animSpeed * 0.7, {
            Size = UDim2.new(0, 0, 0, 0),
        }, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.delay(self._animSpeed * 0.7, function()
            if not self._visible then
                self._screenGui.Enabled = false
            end
        end)
    end
end

function NexusUI:Show()
    if not self._visible then self:Toggle() end
end

function NexusUI:Hide()
    if self._visible then self:Toggle() end
end

-- ══════════════════════════════════════════════════════════════
--  Theme Management
-- ══════════════════════════════════════════════════════════════

function NexusUI:SetTheme(themeName: string | {[string]: Color3})
    if type(themeName) == "table" then
        self._theme = Util.DeepCopy(themeName)
    else
        self._theme = Util.DeepCopy(Themes[themeName] or Themes.Dark)
    end
    -- Rebuild would be needed for full hot-reload;
    -- For simplicity, users can re-create. Advanced: store references and update.
end

function NexusUI:GetTheme(): {[string]: Color3}
    return self._theme
end

function NexusUI:GetFlag(flag: string): any
    return self._flags[flag]
end

function NexusUI:SetFlag(flag: string, value: any)
    self._flags[flag] = value
end

