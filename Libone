function Page:CreateTextBox(config: TextBoxConfig)
    local theme = self._nexus._theme
    local frame = self:_CreateItemFrame(config)
    local value = config.Default or ""

    local textBox = Util.Create("TextBox", {
        Name = "Input",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 140, 0, 26),
        BackgroundColor3 = theme.Surface,
        Text = value,
        PlaceholderText = config.Placeholder or "Type here...",
        PlaceholderColor3 = theme.TextDim,
        TextColor3 = theme.Text,
        TextSize = 12,
        Font = self._nexus._font,
        ClearTextOnFocus = config.ClearOnFocus or false,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Util.Corner(textBox, 6)
    Util.Stroke(textBox, theme.Border, 1, 0.6)
    Util.Padding(textBox, 0, 0, 8, 8)

    local stroke = textBox:FindFirstChildOfClass("UIStroke")

    textBox.Focused:Connect(function()
        if stroke then
            Util.Tween(stroke, 0.2, { Color = theme.Accent, Transparency = 0 })
        end
    end)

    textBox.FocusLost:Connect(function(enterPressed)
        if stroke then
            Util.Tween(stroke, 0.2, { Color = theme.Border, Transparency = 0.6 })
        end
        value = textBox.Text
        if config.Flag then self._nexus._flags[config.Flag] = value end
        if enterPressed and config.Callback then
            task.spawn(config.Callback, value)
        end
    end)

    if config.Flag then self._nexus._flags[config.Flag] = value end

    return {
        Frame = frame,
        GetValue = function() return textBox.Text end,
        SetValue = function(_, v)
            textBox.Text = v
            value = v
            if config.Flag then self._nexus._flags[config.Flag] = v end
        end,
    }
end

