            local order   = options.LayoutOrder or (#self._elements + 1) * 10
            local parent  = getParentFrame(self)

            local container = Util.Create("Frame", {
                Name = pbName .. "_ProgressBar",
                Size = UDim2.new(1, 0, 0, 42),
                BackgroundColor3 = theme.SecondaryBackground,
                BorderSizePixel = 0,
                LayoutOrder = order,
                Parent = parent,
            })
            Util.Create("UICorner", { CornerRadius = theme.CornerRadius, Parent = container })
            Util.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = container })

            Util.Create("TextLabel", {
                Name = "Text",
                Position = UDim2.fromOffset(12, 2),
                Size = UDim2.new(0.6, 0, 0, 18),
                BackgroundTransparency = 1,
                Text = pbName,
                TextColor3 = theme.Text,
                TextSize = 12,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 3,
                Parent = container,
            })

            local percentLabel = Util.Create("TextLabel", {
                Name = "Percent",
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -12, 0, 2),
                Size = UDim2.new(0.3, 0, 0, 18),
                BackgroundTransparency = 1,
                Text = tostring(math.floor(default * 100)) .. "%",
                TextColor3 = theme.Accent,
                TextSize = 11,
                Font = theme.FontBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 3,
                Parent = container,
            })

            local barBg = Util.Create("Frame", {
                Name = "BarBg",
                Position = UDim2.new(0, 12, 0, 24),
                Size = UDim2.new(1, -24, 0, 8),
                BackgroundColor3 = theme.SliderBackground,
                BorderSizePixel = 0,
                ZIndex = 3,
                Parent = container,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = barBg })

            local barFill = Util.Create("Frame", {
                Name = "Fill",
                Size = UDim2.new(math.clamp(default, 0, 1), 0, 1, 0),
                BackgroundColor3 = theme.Accent,
                BorderSizePixel = 0,
                ZIndex = 4,
                Parent = barBg,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = barFill })

            -- Glow effect on fill
            Util.Create("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, theme.AccentDark),
                    ColorSequenceKeypoint.new(0.5, theme.Accent),
                    ColorSequenceKeypoint.new(1, theme.AccentHover),
                }),
                Parent = barFill,
            })

            local ProgressBarObj = { _instance = container }

            function ProgressBarObj:SetProgress(value: number)
                value = math.clamp(value, 0, 1)
                Util.Tween(barFill, 0.3, { Size = UDim2.new(value, 0, 1, 0) }, Enum.EasingStyle.Quint)
                percentLabel.Text = tostring(math.floor(value * 100)) .. "%"
            end

            function ProgressBarObj:GetProgress(): number
                return barFill.Size.X.Scale
            end

            table.insert(self._elements, ProgressBarObj)
            return ProgressBarObj
        end

