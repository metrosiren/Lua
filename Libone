    ---------------------------------------------------------------------------
    -- Config Save/Load
    ---------------------------------------------------------------------------
    function Window:GetConfig(): {[string]: any}
        local config = {}
        for _, page in ipairs(self._pages) do
            for key, value in pairs(page._configData) do
                config[key] = value
            end
        end
        return config
    end

    function Window:SaveConfig(fileName: string)
        local config = self:GetConfig()
        local success, encoded = pcall(function()
            return HttpService:JSONEncode(config)
        end)
        if success then
            -- Use writefile if available (executor environment)
            if writefile then
                writefile(fileName .. ".json", encoded)
            end
        end
    end

    function Window:LoadConfig(fileName: string)
        -- Use readfile if available (executor environment)
        if readfile and isfile and isfile(fileName .. ".json") then
            local success, data = pcall(function()
                return HttpService:JSONDecode(readfile(fileName .. ".json"))
            end)
            if success then
                return data
            end
        end
        return nil
    end

    -- Opening animation
    mainFrame.BackgroundTransparency = 1
    mainFrame.Size = UDim2.fromOffset(0, 0)
    task.defer(function()
        Util.Tween(mainFrame, 0.4, {
            Size = windowSize,
            BackgroundTransparency = 0,
        }, Enum.EasingStyle.Back)
    end)

    table.insert(NexusUI._windows, Window)
    return Window
end

---------------------------------------------------------------------------
-- Destroy All
---------------------------------------------------------------------------
function NexusUI:DestroyAll()
    for _, window in ipairs(self._windows) do
        window:Destroy()
    end
    self._windows = {}

    local gui = Player.PlayerGui:FindFirstChild("NexusUI_ScreenGui")
    if gui then gui:Destroy() end
end

---------------------------------------------------------------------------
-- Custom Theme Builder
---------------------------------------------------------------------------
function NexusUI:CreateTheme(base: string?, overrides: {[string]: any}?): {[string]: any}
    local baseTheme = self.Themes[base or "Dark"] or self.Themes.Dark
    local newTheme = Util.DeepCopy(baseTheme)
    if overrides then
        for key, value in pairs(overrides) do
            newTheme[key] = value
        end
    end
    return newTheme
end

---------------------------------------------------------------------------
-- Return Library
---------------------------------------------------------------------------
return NexusUI

