        ZIndex = 5,
        Parent = mainFrame,
    })
    -- Bottom left corner radius
    Util.Create("UICorner", { CornerRadius = UDim.new(0, 8), Parent = sidebar })
    Util.Create("Frame", {
        Name = "TopCover",
        Size = UDim2.new(1, 0, 0, 8),
        BackgroundColor3 = theme.Sidebar,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = sidebar,
    })
    Util.Create("Frame", {
        Name = "RightCover",
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(0, 8, 1, 0),
        BackgroundColor3 = theme.Sidebar,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = sidebar,
    })

