            Util.Create("TextLabel", {
                Name = "Text",
                Position = UDim2.fromOffset(12, 0),
                Size = UDim2.new(1, -68, 1, 0),
                BackgroundTransparency = 1,
                Text = toggleName,
                TextColor3 = theme.Text,
                TextSize = 12,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 3,
                Parent = container,
            })

            -- Toggle switch
            local switchBg = Util.Create("Frame", {
                Name = "SwitchBg",
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -10, 0.5, 0),
                Size = UDim2.fromOffset(40, 22),
                BackgroundColor3 = if state then theme.ToggleOn else theme.ToggleOff,
                BorderSizePixel = 0,
                ZIndex = 3,
                Parent = container,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = switchBg })

            local knob = Util.Create("Frame", {
                Name = "Knob",
                AnchorPoint = Vector2.new(0, 0.5),
                Position = if state then UDim2.new(1, -19, 0.5, 0) else UDim2.new(0, 3, 0.5, 0),
                Size = UDim2.fromOffset(16, 16),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0,
                ZIndex = 4,
                Parent = switchBg,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = knob })

            local function updateVisual()
                if state then
                    Util.Tween(switchBg, 0.2, { BackgroundColor3 = theme.ToggleOn })
                    Util.Tween(knob, 0.2, { Position = UDim2.new(1, -19, 0.5, 0) }, Enum.EasingStyle.Back)
                else
                    Util.Tween(switchBg, 0.2, { BackgroundColor3 = theme.ToggleOff })
                    Util.Tween(knob, 0.2, { Position = UDim2.new(0, 3, 0.5, 0) }, Enum.EasingStyle.Back)
                end
            end

            local clickBtn = Util.Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 5,
                Parent = container,
            })

            container.MouseEnter = nil -- we handle hover on container
            clickBtn.MouseEnter:Connect(function()
                Util.Tween(container, 0.15, { BackgroundColor3 = theme.TertiaryBackground })
            end)
            clickBtn.MouseLeave:Connect(function()
                Util.Tween(container, 0.15, { BackgroundColor3 = theme.SecondaryBackground })
            end)

            clickBtn.MouseButton1Click:Connect(function()
                state = not state
                updateVisual()
                if flag then
                    Page._configData[flag] = state
                end
                task.spawn(callback, state)
            end)

            -- Initialize
            if flag then
                Page._configData[flag] = state
            end

            local ToggleObj = { _instance = container, _state = state }

            function ToggleObj:GetState(): boolean
                return state
            end

            function ToggleObj:SetState(newState: boolean)
                state = newState
                updateVisual()
                if flag then
                    Page._configData[flag] = state
                end
                task.spawn(callback, state)
            end

            table.insert(self._elements, ToggleObj)
            return ToggleObj
        end

        -------------------------------------------------------------------
        -- SLIDER
        -------------------------------------------------------------------
        function Page:CreateSlider(options: {[string]: any})
            local sliderName = options.Text or options.Name or "Slider"
            local min        = options.Min or 0
            local max        = options.Max or 100
            local default    = options.Default or min
            local increment  = options.Increment or 1
            local suffix     = options.Suffix or ""
            local callback   = options.Callback or function() end
            local flag       = options.Flag
            local order      = options.LayoutOrder or (#self._elements + 1) * 10
            local parent     = getParentFrame(self)

            local value = math.clamp(default, min, max)

            local container = Util.Create("Frame", {
                Name = sliderName .. "_Slider",
                Size = UDim2.new(1, 0, 0, 50),
                BackgroundColor3 = theme.SecondaryBackground,
                BorderSizePixel = 0,
                LayoutOrder = order,
                Parent = parent,
            })
            Util.Create("UICorner", { CornerRadius = theme.CornerRadius, Parent = container })
            Util.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = container })

            local nameLabel = Util.Create("TextLabel", {
                Name = "Text",
                Position = UDim2.fromOffset(12, 4),
                Size = UDim2.new(0.6, 0, 0, 20),
                BackgroundTransparency = 1,
                Text = sliderName,
                TextColor3 = theme.Text,
                TextSize = 12,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 3,
                Parent = container,
            })

            local valueLabel = Util.Create("TextLabel", {
                Name = "Value",
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -12, 0, 4),
                Size = UDim2.new(0.3, 0, 0, 20),
                BackgroundTransparency = 1,
                Text = tostring(value) .. suffix,
                TextColor3 = theme.Accent,
                TextSize = 12,
                Font = theme.FontBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 3,
                Parent = container,
            })

            -- Slider track
            local track = Util.Create("Frame", {
                Name = "Track",
                Position = UDim2.new(0, 12, 0, 30),
                Size = UDim2.new(1, -24, 0, 6),
                BackgroundColor3 = theme.SliderBackground,
                BorderSizePixel = 0,
                ZIndex = 3,
                Parent = container,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })

            local fillPercent = (value - min) / (max - min)
            local fill = Util.Create("Frame", {
                Name = "Fill",
                Size = UDim2.new(fillPercent, 0, 1, 0),
                BackgroundColor3 = theme.SliderFill,
                BorderSizePixel = 0,
                ZIndex = 4,
                Parent = track,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })

            -- Knob
            local sliderKnob = Util.Create("Frame", {
                Name = "Knob",
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(fillPercent, 0, 0.5, 0),
                Size = UDim2.fromOffset(14, 14),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0,
                ZIndex = 5,
                Parent = track,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = sliderKnob })
            Util.Create("UIStroke", {
                Color = theme.SliderFill,
                Thickness = 2,
                Parent = sliderKnob,
            })

            -- Invisible click area
            local clickArea = Util.Create("TextButton", {
                Name = "ClickArea",
                Position = UDim2.new(0, 0, 0, -8),
                Size = UDim2.new(1, 0, 1, 16),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 6,
                Parent = track,
            })

            local dragging = false

            local function updateSlider(inputX: number)
                local trackAbsPos = track.AbsolutePosition.X
                local trackAbsSize = track.AbsoluteSize.X
                local relX = math.clamp((inputX - trackAbsPos) / trackAbsSize, 0, 1)

                -- Snap to increment
                local rawValue = min + (max - min) * relX
                local stepped = math.floor(rawValue / increment + 0.5) * increment
                value = math.clamp(stepped, min, max)

                local pct = (value - min) / (max - min)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                sliderKnob.Position = UDim2.new(pct, 0, 0.5, 0)
                valueLabel.Text = tostring(value) .. suffix

                if flag then
                    Page._configData[flag] = value
                end
            end

            clickArea.MouseButton1Down:Connect(function()
                dragging = true
                updateSlider(Mouse.X)
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(input.Position.X)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                    dragging = false
                    task.spawn(callback, value)
                end
            end)

            -- Hover effect
            container.MouseEnter = nil
            clickArea.MouseEnter:Connect(function()
                Util.Tween(sliderKnob, 0.15, { Size = UDim2.fromOffset(16, 16) })
            end)
            clickArea.MouseLeave:Connect(function()
                if not dragging then
                    Util.Tween(sliderKnob, 0.15, { Size = UDim2.fromOffset(14, 14) })
                end
            end)

            if flag then
                Page._configData[flag] = value
            end

            local SliderObj = { _instance = container, _value = value }

            function SliderObj:GetValue(): number
                return value
            end

            function SliderObj:SetValue(newValue: number)
                value = math.clamp(newValue, min, max)
                local pct = (value - min) / (max - min)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                sliderKnob.Position = UDim2.new(pct, 0, 0.5, 0)
                valueLabel.Text = tostring(value) .. suffix
                if flag then
                    Page._configData[flag] = value
                end
                task.spawn(callback, value)
            end

            table.insert(self._elements, SliderObj)
            return SliderObj
        end

