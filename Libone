    })
    Util.Corner(frame, self._nexus._cornerR)
    Util.Stroke(frame, theme.Border, 1, 0.75)
    Util.Padding(frame, 0, 0, 12, 12)

    -- Hover
    frame.MouseEnter:Connect(function()
        Util.Tween(frame, 0.2, { BackgroundTransparency = 0.2 })
    end)
    frame.MouseLeave:Connect(function()
        Util.Tween(frame, 0.2, { BackgroundTransparency = 0.4 })
    end)

    -- Title label
    if config.Text then
        Util.Create("TextLabel", {
            Name = "Title",
            AnchorPoint = Vector2.new(0, 0.5),
