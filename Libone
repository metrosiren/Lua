--  Keybind
-- ══════════════════════════════════════════════════════════════

function Page:CreateKeybind(config: KeybindConfig)
    local theme = self._nexus._theme
    local frame = self:_CreateItemFrame(config)
    local currentKey = config.Default or Enum.KeyCode.Unknown
    local listening = false

    local keyBtn = Util.Create("TextButton", {
        Name = "KeyBtn",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 80, 0, 26),
        BackgroundColor3 = theme.Surface,
        Text = currentKey == Enum.KeyCode.Unknown and "None" or currentKey.Name,
        TextColor3 = theme.Text,
        TextSize = 12,
        Font = self._nexus._font,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Parent = frame,
    })
    Util.Corner(keyBtn, 6)
    Util.Stroke(keyBtn, theme.Border, 1, 0.6)

    keyBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        keyBtn.Text = "..."
        Util.Tween(keyBtn:FindFirstChildOfClass("UIStroke"), 0.2, { Color = theme.Accent, Transparency = 0 })

        local conn
        conn = UserInputService.InputBegan:Connect(function(input, processed)
            if processed then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                currentKey = input.KeyCode
                keyBtn.Text = currentKey.Name
                listening = false
                Util.Tween(keyBtn:FindFirstChildOfClass("UIStroke"), 0.2, { Color = theme.Border, Transparency = 0.6 })
                if config.Flag then self._nexus._flags[config.Flag] = currentKey end
                if config.Callback then task.spawn(config.Callback, currentKey) end
                conn:Disconnect()
            end
        end)
    end)

    if config.Flag then self._nexus._flags[config.Flag] = currentKey end

    return {
        Frame = frame,
        GetValue = function() return currentKey end,
        SetValue = function(_, key)
            currentKey = key
            keyBtn.Text = key.Name
            if config.Flag then self._nexus._flags[config.Flag] = key end
        end,
    }
end

-- ══════════════════════════════════════════════════════════════
--  Color Picker (Simplified inline HSV)
-- ══════════════════════════════════════════════════════════════

function Page:CreateColorPicker(config: ColorPickerConfig)
    local theme = self._nexus._theme
    local frame = self:_CreateItemFrame(config, 38)
    local color = config.Default or Color3.new(1, 0, 0)
    local expanded = false

    -- Color preview swatch
    local swatch = Util.Create("TextButton", {
        Name = "Swatch",
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 36, 0, 22),
        BackgroundColor3 = color,
        Text = "",
        AutoButtonColor = false,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Util.Corner(swatch, 6)
    Util.Stroke(swatch, theme.Border, 1, 0.5)

    -- Picker panel (hidden by default)
    local pickerPanel = Util.Create("Frame", {
        Name = "Picker",
        Position = UDim2.new(0, 0, 1, 4),
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        ZIndex = 60,
        Parent = frame,
    })
    Util.Corner(pickerPanel, 6)
    Util.Stroke(pickerPanel, theme.Border, 1, 0.5)

    -- Hue slider
    local hueTrack = Util.Create("Frame", {
        Name = "HueTrack",
        Position = UDim2.new(0.05, 0, 0.15, 0),
        Size = UDim2.new(0.9, 0, 0, 14),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = 61,
        Parent = pickerPanel,
    })
    Util.Corner(hueTrack, 4)

    -- Create a rainbow gradient for hue
    local hueGradient = Util.Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
            ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
            ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
            ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
            ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
            ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
        }),
        Parent = hueTrack,
    })

    -- Sat/Val area
    local svArea = Util.Create("Frame", {
        Name = "SVArea",
        Position = UDim2.new(0.05, 0, 0.45, 0),
        Size = UDim2.new(0.9, 0, 0, 60),
        BackgroundColor3 = Color3.fromHSV(0, 1, 1),
        BorderSizePixel = 0,
        ZIndex = 61,
        Parent = pickerPanel,
    })
    Util.Corner(svArea, 4)

    -- White→Transparent gradient (saturation)
    Util.Create("UIGradient", {
        Color = ColorSequence.new(Color3.new(1,1,1), Color3.new(1,1,1)),
        Transparency = NumberSequence.new(0, 1),
        Parent = svArea,
    })

    -- Black overlay (value)
    local blackOverlay = Util.Create("Frame", {
        Name = "BlackOverlay",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.new(0, 0, 0),
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        ZIndex = 62,
        Parent = svArea,
    })
    Util.Corner(blackOverlay, 4)
    Util.Create("UIGradient", {
        Color = ColorSequence.new(Color3.new(0,0,0), Color3.new(0,0,0)),
        Transparency = NumberSequence.new(1, 0),
        Rotation = 90,
        Parent = blackOverlay,
    })

    local h, s, v = Color3.toHSV(color)

    -- Interaction
    local hueDragging = false
    local svDragging = false

    local function updateColor()
        color = Color3.fromHSV(h, s, v)
        swatch.BackgroundColor3 = color
        svArea.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        if config.Flag then self._nexus._flags[config.Flag] = color end
        if config.Callback then task.spawn(config.Callback, color) end
    end

    local hueInput = Util.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 63,
        Parent = hueTrack,
    })
    hueInput.MouseButton1Down:Connect(function() hueDragging = true end)

    local svInput = Util.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 63,
        Parent = svArea,
    })
    svInput.MouseButton1Down:Connect(function() svDragging = true end)

    table.insert(self._nexus._connections, UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
        if hueDragging then
            h = math.clamp((input.Position.X - hueTrack.AbsolutePosition.X) / hueTrack.AbsoluteSize.X, 0, 1)
            updateColor()
        elseif svDragging then
            s = math.clamp((input.Position.X - svArea.AbsolutePosition.X) / svArea.AbsoluteSize.X, 0, 1)
            v = 1 - math.clamp((input.Position.Y - svArea.AbsolutePosition.Y) / svArea.AbsoluteSize.Y, 0, 1)
            updateColor()
        end
    end))

    table.insert(self._nexus._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
            svDragging = false
        end
    end))

    swatch.MouseButton1Click:Connect(function()
        expanded = not expanded
        if expanded then
            Util.Tween(pickerPanel, 0.25, { Size = UDim2.new(1, 0, 0, 100) })
            Util.Tween(frame, 0.25, { Size = UDim2.new(1, 0, 0, 38 + 106) })
        else
            Util.Tween(pickerPanel, 0.2, { Size = UDim2.new(1, 0, 0, 0) })
            Util.Tween(frame, 0.2, { Size = UDim2.new(1, 0, 0, 38) })
        end
    end)

    if config.Flag then self._nexus._flags[config.Flag] = color end

    return {
        Frame = frame,
        GetValue = function() return color end,
        SetValue = function(_, c)
            color = c
            h, s, v = Color3.toHSV(c)
            updateColor()
        end,
    }
end

