        function Page:CreateSearchBar(options: {[string]: any}?)
            options = options or {}
            local placeholder = options.Placeholder or "Search..."
            local order = options.LayoutOrder or 0
            local parent = getParentFrame(self)

            local container = Util.Create("Frame", {
                Name = "SearchBar",
                Size = UDim2.new(1, 0, 0, 32),
                BackgroundColor3 = theme.InputBackground,
                BorderSizePixel = 0,
                LayoutOrder = order,
                Parent = parent,
            })
            Util.Create("UICorner", { CornerRadius = theme.CornerRadius, Parent = container })
            Util.Create("UIStroke", { Color = theme.InputBorder, Thickness = 1, Parent = container })

            Util.Create("TextLabel", {
                Name = "SearchIcon",
                Position = UDim2.fromOffset(8, 0),
                Size = UDim2.fromOffset(20, 32),
                BackgroundTransparency = 1,
                Text = Icons.Search,
                TextColor3 = theme.DimText,
                TextSize = 12,
                Font = theme.Font,
                ZIndex = 3,
                Parent = container,
            })

            local searchBox = Util.Create("TextBox", {
                Name = "Input",
                Position = UDim2.fromOffset(30, 0),
                Size = UDim2.new(1, -38, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                PlaceholderText = placeholder,
                PlaceholderColor3 = theme.DimText,
                TextColor3 = theme.Text,
                TextSize = 12,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ClearTextOnFocus = false,
                ZIndex = 4,
                Parent = container,
            })

            searchBox:GetPropertyChangedSignal("Text"):Connect(function()
                local query = string.lower(searchBox.Text)
                for _, element in ipairs(self._elements) do
                    if element._instance then
                        local nameStr = string.lower(element._instance.Name)
                        if query == "" or string.find(nameStr, query) then
                            element._instance.Visible = true
                        else
                            element._instance.Visible = false
                        end
                    end
                end
            end)

            searchBox.Focused:Connect(function()
                Util.Tween(container:FindFirstChild("UIStroke"), 0.2, { Color = theme.InputFocusBorder })
            end)
            searchBox.FocusLost:Connect(function()
                Util.Tween(container:FindFirstChild("UIStroke"), 0.2, { Color = theme.InputBorder })
            end)

            table.insert(self._elements, { _instance = container })
        end

