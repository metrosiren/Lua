        function Page:CreateTextBox(options: {[string]: any})
            local tbName      = options.Text or options.Name or "Input"
            local placeholder  = options.Placeholder or "Type here..."
            local default      = options.Default or ""
            local numeric      = options.Numeric or false
            local clearOnFocus = if options.ClearOnFocus ~= nil then options.ClearOnFocus else false
            local callback     = options.Callback or function() end
            local onChanged    = options.OnChanged -- fires on every character
            local flag         = options.Flag
            local order        = options.LayoutOrder or (#self._elements + 1) * 10
            local parent       = getParentFrame(self)

            local container = Util.Create("Frame", {
                Name = tbName .. "_TextBox",
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = theme.SecondaryBackground,
                BorderSizePixel = 0,
                LayoutOrder = order,
                Parent = parent,
            })
            Util.Create("UICorner", { CornerRadius = theme.CornerRadius, Parent = container })
            Util.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = container })

            Util.Create("TextLabel", {
                Name = "Text",
                Position = UDim2.fromOffset(12, 0),
                Size = UDim2.new(0.4, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = tbName,
                TextColor3 = theme.Text,
                TextSize = 12,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 3,
                Parent = container,
            })

            local inputBg = Util.Create("Frame", {
                Name = "InputBg",
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -8, 0.5, 0),
                Size = UDim2.new(0.55, 0, 0, 26),
                BackgroundColor3 = theme.InputBackground,
                BorderSizePixel = 0,
                ZIndex = 3,
                Parent = container,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = inputBg })
            local inputStroke = Util.Create("UIStroke", {
                Color = theme.InputBorder,
                Thickness = 1,
                Parent = inputBg,
            })

            local textBox = Util.Create("TextBox", {
                Name = "Input",
                Size = UDim2.new(1, -12, 1, 0),
                Position = UDim2.fromOffset(6, 0),
                BackgroundTransparency = 1,
                Text = default,
                PlaceholderText = placeholder,
                PlaceholderColor3 = theme.DimText,
                TextColor3 = theme.Text,
                TextSize = 11,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ClearTextOnFocus = clearOnFocus,
                ZIndex = 4,
                Parent = inputBg,
            })

            textBox.Focused:Connect(function()
                Util.Tween(inputStroke, 0.2, { Color = theme.InputFocusBorder })
                Util.Tween(container, 0.15, { BackgroundColor3 = theme.TertiaryBackground })
            end)

            textBox.FocusLost:Connect(function(enterPressed)
                Util.Tween(inputStroke, 0.2, { Color = theme.InputBorder })
                Util.Tween(container, 0.15, { BackgroundColor3 = theme.SecondaryBackground })

                local txt = textBox.Text
                if numeric then
                    txt = tostring(tonumber(txt) or 0)
                    textBox.Text = txt
                end

                if flag then
                    Page._configData[flag] = txt
                end
                task.spawn(callback, txt, enterPressed)
            end)

            if onChanged then
                textBox:GetPropertyChangedSignal("Text"):Connect(function()
                    local txt = textBox.Text
                    if numeric then
                        -- Allow partial numeric typing
                        txt = txt:gsub("[^%d%.%-]", "")
                        if txt ~= textBox.Text then
                            textBox.Text = txt
                        end
                    end
                    task.spawn(onChanged, txt)
                end)
            end

            if flag then
                Page._configData[flag] = default
            end

            local TextBoxObj = { _instance = container, _textBox = textBox }

            function TextBoxObj:GetText(): string
                return textBox.Text
            end

            function TextBoxObj:SetText(newText: string)
                textBox.Text = newText
            end

            table.insert(self._elements, TextBoxObj)
            return TextBoxObj
        end

