        -- Tab interaction
        local function activatePage()
            -- Deactivate all pages
            for _, pg in ipairs(Window._pages) do
                pg._frame.Visible = false
                Util.Tween(pg._tabBtn, 0.2, { BackgroundTransparency = 1 })
                Util.Tween(pg._tabBtn:FindFirstChild("Label"), 0.2, { TextColor3 = theme.SubText, Font = theme.Font })
                Util.Tween(pg._tabBtn:FindFirstChild("Icon"), 0.2, { TextColor3 = theme.SubText })
                Util.Tween(pg._tabBtn:FindFirstChild("ActiveBar"), 0.2, { BackgroundTransparency = 1 })
            end
            -- Activate this page
            Page._frame.Visible = true
            Window._activePage = Page
            Util.Tween(tabBtn, 0.2, { BackgroundTransparency = 0.9 })
            Util.Tween(tabLabel, 0.2, { TextColor3 = theme.Text })
            tabLabel.Font = theme.FontBold
            Util.Tween(tabIcon, 0.2, { TextColor3 = theme.Accent })
            Util.Tween(activeBar, 0.2, { BackgroundTransparency = 0 })
        end

        tabBtn.MouseButton1Click:Connect(activatePage)

        tabBtn.MouseEnter:Connect(function()
            if Window._activePage ~= Page then
                Util.Tween(tabBtn, 0.15, { BackgroundTransparency = 0.92 })
                Util.Tween(tabLabel, 0.15, { TextColor3 = theme.Text })
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if Window._activePage ~= Page then
                Util.Tween(tabBtn, 0.15, { BackgroundTransparency = 1 })
                Util.Tween(tabLabel, 0.15, { TextColor3 = theme.SubText })
            end
        end)

        table.insert(Window._pages, Page)

        -- Auto-select first page
        if #Window._pages == 1 then
            activatePage()
        end

