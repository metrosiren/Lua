--  Constructor
-- ══════════════════════════════════════════════════════════════

function NexusUI.new(config: NexusConfig?)
    local self = setmetatable({}, NexusUI)

    config = config or {}
    self._title       = config.Title or "NexusUI"
    self._subtitle    = config.Subtitle or "v2.0"
    self._font        = config.Font or Enum.Font.Gotham
    self._titleFont   = config.TitleFont or Enum.Font.GothamBold
    self._cornerR     = config.CornerRadius or 8
    self._toggleKey   = config.ToggleKey or Enum.KeyCode.RightControl
    self._windowSize  = config.WindowSize or UDim2.new(0, 520, 0, 380)
    self._animSpeed   = config.AnimationSpeed or 0.35
    self._soundOn     = config.SoundEnabled ~= false
    self._notifDur    = config.NotificationDuration or 3
    self._watermark   = config.Watermark
    self._visible     = true
    self._pages       = {}
    self._activePage  = nil
    self._flags       = {}
    self._connections  = {}

    -- Resolve theme
    if type(config.Theme) == "table" then
        self._theme = config.Theme :: {[string]: Color3}
    elseif type(config.Theme) == "string" then
        self._theme = Util.DeepCopy(Themes[config.Theme] or Themes.Dark)
    else
        self._theme = Util.DeepCopy(Themes.Dark)
    end

    if config.AccentColor then
        self._theme.Accent = config.AccentColor
        self._theme.Glow   = config.AccentColor
        -- Generate a lighter hover variant
        local r, g, b = config.AccentColor.R, config.AccentColor.G, config.AccentColor.B
        self._theme.AccentHover = Color3.new(
            math.min(r + 0.08, 1),
            math.min(g + 0.08, 1),
            math.min(b + 0.08, 1)
        )
    end

    self:_BuildUI()
    self:_SetupInputHandlers()

    return self
end

