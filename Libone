    ---------------------------------------------------------------------------
    -- Window Methods
    ---------------------------------------------------------------------------
    function Window:Toggle()
        if self._visible then
            self:Hide()
        else
            self:Show()
        end
    end

    function Window:Show()
        self._visible = true
        mainFrame.Visible = true
        mainFrame.Size = UDim2.fromOffset(0, 0)
        Util.Tween(mainFrame, theme.AnimationSpeed + 0.1, { Size = windowSize }, theme.AnimationEasing)
    end

    function Window:Hide()
        self._visible = false
        local tween = Util.Tween(mainFrame, theme.AnimationSpeed, { Size = UDim2.fromOffset(0, 0) }, theme.AnimationEasing)
        tween.Completed:Connect(function()
            if not self._visible then
                mainFrame.Visible = false
                mainFrame.Size = windowSize
            end
        end)
    end

    function Window:Close()
        self:Hide()
    end

    function Window:Minimize()
        self._minimized = not self._minimized
        if self._minimized then
            Util.Tween(mainFrame, theme.AnimationSpeed, {
                Size = UDim2.fromOffset(windowSize.X.Offset, 38)
            }, theme.AnimationEasing)
        else
            Util.Tween(mainFrame, theme.AnimationSpeed, {
                Size = windowSize
            }, theme.AnimationEasing)
        end
    end

    function Window:Destroy()
        mainFrame:Destroy()
    end

    function Window:SetTheme(newTheme)
        -- This allows runtime theme changes
        self._theme = newTheme
        -- NOTE: Full re-render would be required for complete theme swap
        -- For simplicity, accent colors on new elements will use the new theme
    end

    function Window:Notify(options)
        options.Theme = self._theme
        NexusUI:Notify(options)
    end

