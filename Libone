            local callback = options.Callback or function() end
            local flag     = options.Flag
            local order    = options.LayoutOrder or (#self._elements + 1) * 10
            local parent   = getParentFrame(self)

            local currentKey = default
            local listening = false

            local container = Util.Create("Frame", {
                Name = kbName .. "_Keybind",
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = theme.SecondaryBackground,
                BorderSizePixel = 0,
                LayoutOrder = order,
                Parent = parent,
            })
            Util.Create("UICorner", { CornerRadius = theme.CornerRadius, Parent = container })
            Util.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = container })

            Util.Create("TextLabel", {
                Name = "Text",
                Position = UDim2.fromOffset(12, 0),
                Size = UDim2.new(0.6, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = kbName,
                TextColor3 = theme.Text,
                TextSize = 12,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 3,
                Parent = container,
            })

            local keyBtn = Util.Create("TextButton", {
                Name = "KeyBtn",
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -10, 0.5, 0),
                Size = UDim2.new(0, 70, 0, 24),
                BackgroundColor3 = theme.InputBackground,
                Text = if currentKey ~= Enum.KeyCode.Unknown then currentKey.Name else "None",
                TextColor3 = theme.SubText,
                TextSize = 11,
                Font = theme.Font,
                AutoButtonColor = false,
                ZIndex = 4,
                Parent = container,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = keyBtn })
            Util.Create("UIStroke", { Color = theme.InputBorder, Thickness = 1, Parent = keyBtn })

            keyBtn.MouseButton1Click:Connect(function()
                listening = true
                keyBtn.Text = "..."
                Util.Tween(keyBtn:FindFirstChild("UIStroke"), 0.2, { Color = theme.Accent })
            end)

            UserInputService.InputBegan:Connect(function(input, processed)
                if listening then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = input.KeyCode
                        keyBtn.Text = currentKey.Name
                        listening = false
                        Util.Tween(keyBtn:FindFirstChild("UIStroke"), 0.2, { Color = theme.InputBorder })
                        if flag then
                            Page._configData[flag] = currentKey.Name
                        end
                    end
                elseif not processed and input.UserInputType == Enum.UserInputType.Keyboard then
                    if input.KeyCode == currentKey then
                        task.spawn(callback, currentKey)
                    end
                end
            end)

            container.MouseEnter = nil
            keyBtn.MouseEnter:Connect(function()
                Util.Tween(container, 0.15, { BackgroundColor3 = theme.TertiaryBackground })
            end)
            keyBtn.MouseLeave:Connect(function()
                Util.Tween(container, 0.15, { BackgroundColor3 = theme.SecondaryBackground })
            end)

            if flag then
                Page._configData[flag] = if currentKey ~= Enum.KeyCode.Unknown then currentKey.Name else "None"
            end

            local KeybindObj = { _instance = container }

            function KeybindObj:GetKey(): Enum.KeyCode
                return currentKey
            end

            function KeybindObj:SetKey(newKey: Enum.KeyCode)
                currentKey = newKey
                keyBtn.Text = newKey.Name
                if flag then
                    Page._configData[flag] = newKey.Name
                end
            end

            table.insert(self._elements, KeybindObj)
            return KeybindObj
        end

