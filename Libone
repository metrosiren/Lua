        function Page:CreateDropdown(options: {[string]: any})
            local dropdownName = options.Text or options.Name or "Dropdown"
            local items        = options.Items or options.Options or {}
            local default      = options.Default
            local multi        = options.Multi or false
            local callback     = options.Callback or function() end
            local flag         = options.Flag
            local order        = options.LayoutOrder or (#self._elements + 1) * 10
            local parent       = getParentFrame(self)

            local isOpen = false
            local selectedItems = {}

            if default then
                if multi and type(default) == "table" then
                    for _, item in ipairs(default) do
                        selectedItems[item] = true
                    end
                elseif type(default) == "string" then
                    selectedItems[default] = true
                end
            end

            local container = Util.Create("Frame", {
                Name = dropdownName .. "_Dropdown",
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = theme.SecondaryBackground,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                LayoutOrder = order,
                Parent = parent,
            })
            Util.Create("UICorner", { CornerRadius = theme.CornerRadius, Parent = container })
            Util.Create("UIStroke", { Color = theme.Border, Thickness = 1, Parent = container })

            local headerBtn = Util.Create("TextButton", {
                Name = "Header",
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 4,
                Parent = container,
            })

            Util.Create("TextLabel", {
                Name = "Text",
                Position = UDim2.fromOffset(12, 0),
                Size = UDim2.new(0.5, 0, 0, 36),
                BackgroundTransparency = 1,
                Text = dropdownName,
                TextColor3 = theme.Text,
                TextSize = 12,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
                Parent = container,
            })

            local selectedLabel = Util.Create("TextLabel", {
                Name = "Selected",
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -32, 0, 0),
                Size = UDim2.new(0.4, 0, 0, 36),
                BackgroundTransparency = 1,
                Text = default or "Select...",
                TextColor3 = theme.SubText,
                TextSize = 11,
                Font = theme.Font,
                TextXAlignment = Enum.TextXAlignment.Right,
                TextTruncate = Enum.TextTruncate.AtEnd,
                ZIndex = 5,
                Parent = container,
            })

            local arrow = Util.Create("TextLabel", {
                Name = "Arrow",
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -10, 0, 0),
                Size = UDim2.fromOffset(14, 36),
                BackgroundTransparency = 1,
                Text = Icons.ArrowDown,
                TextColor3 = theme.DimText,
                TextSize = 14,
                Font = theme.Font,
                ZIndex = 5,
                Parent = container,
            })

            -- Items container
            local itemsContainer = Util.Create("Frame", {
                Name = "Items",
                Position = UDim2.fromOffset(4, 38),
                Size = UDim2.new(1, -8, 0, 0),
                BackgroundTransparency = 1,
                ZIndex = 5,
                Parent = container,
            })
            Util.Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 2),
                Parent = itemsContainer,
            })

            local function getSelectedText(): string
                local sel = {}
                for item, _ in pairs(selectedItems) do
                    table.insert(sel, item)
                end
                if #sel == 0 then return "Select..." end
                return table.concat(sel, ", ")
            end

            local function updateDisplay()
                selectedLabel.Text = Util.Truncate(getSelectedText(), 25)
            end

            local function createItem(itemName: string, idx: number)
                local itemBtn = Util.Create("TextButton", {
                    Name = itemName,
                    Size = UDim2.new(1, 0, 0, 28),
                    BackgroundColor3 = theme.TertiaryBackground,
                    BackgroundTransparency = 0.5,
                    Text = "",
                    AutoButtonColor = false,
                    LayoutOrder = idx,
                    ZIndex = 6,
                    Parent = itemsContainer,
                })
                Util.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = itemBtn })

                local checkMark = Util.Create("TextLabel", {
                    Name = "Check",
                    Position = UDim2.fromOffset(8, 0),
                    Size = UDim2.fromOffset(14, 28),
                    BackgroundTransparency = 1,
                    Text = if selectedItems[itemName] then Icons.Check else "",
                    TextColor3 = theme.Accent,
                    TextSize = 12,
                    Font = theme.FontBold,
                    ZIndex = 7,
                    Parent = itemBtn,
                })

                Util.Create("TextLabel", {
                    Name = "ItemLabel",
                    Position = UDim2.fromOffset(24, 0),
                    Size = UDim2.new(1, -32, 1, 0),
                    BackgroundTransparency = 1,
                    Text = itemName,
                    TextColor3 = if selectedItems[itemName] then theme.Text else theme.SubText,
                    TextSize = 11,
                    Font = theme.Font,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 7,
                    Parent = itemBtn,
                })

                itemBtn.MouseEnter:Connect(function()
                    Util.Tween(itemBtn, 0.1, { BackgroundTransparency = 0 })
                end)
                itemBtn.MouseLeave:Connect(function()
                    Util.Tween(itemBtn, 0.1, { BackgroundTransparency = 0.5 })
                end)

                itemBtn.MouseButton1Click:Connect(function()
                    if multi then
                        selectedItems[itemName] = not selectedItems[itemName] or nil
                        checkMark.Text = if selectedItems[itemName] then Icons.Check else ""
                        itemBtn:FindFirstChild("ItemLabel").TextColor3 = if selectedItems[itemName] then theme.Text else theme.SubText
                    else
                        -- Single select: clear all, select this
                        selectedItems = {}
                        for _, child in ipairs(itemsContainer:GetChildren()) do
                            if child:IsA("TextButton") then
                                local cm = child:FindFirstChild("Check")
                                local il = child:FindFirstChild("ItemLabel")
                                if cm then cm.Text = "" end
                                if il then il.TextColor3 = theme.SubText end
                            end
                        end
                        selectedItems[itemName] = true
                        checkMark.Text = Icons.Check
                        itemBtn:FindFirstChild("ItemLabel").TextColor3 = theme.Text
                    end
                    updateDisplay()
                    if flag then
                        if multi then
                            local sel = {}
                            for k, _ in pairs(selectedItems) do table.insert(sel, k) end
                            Page._configData[flag] = sel
                        else
                            Page._configData[flag] = itemName
                        end
                    end
                    task.spawn(callback, if multi then selectedItems else itemName)

                    if not multi then
                        -- Auto close on single select
                        task.delay(0.1, function()
                            headerBtn.MouseButton1Click:Fire()
                        end)
                    end
                end)
            end

            for i, item in ipairs(items) do
                createItem(item, i)
            end

            local expandedHeight = 36 + 4 + (#items * 30) + 6

            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    Util.Tween(container, 0.25, { Size = UDim2.new(1, 0, 0, expandedHeight) }, Enum.EasingStyle.Quint)
                    arrow.Text = Icons.ArrowUp
                    Util.Tween(container:FindFirstChild("UIStroke"), 0.2, { Color = theme.Accent })
                else
                    Util.Tween(container, 0.25, { Size = UDim2.new(1, 0, 0, 36) }, Enum.EasingStyle.Quint)
                    arrow.Text = Icons.ArrowDown
                    Util.Tween(container:FindFirstChild("UIStroke"), 0.2, { Color = theme.Border })
                end
            end)

            headerBtn.MouseEnter:Connect(function()
                if not isOpen then
                    Util.Tween(container, 0.15, { BackgroundColor3 = theme.TertiaryBackground })
                end
            end)
            headerBtn.MouseLeave:Connect(function()
                if not isOpen then
                    Util.Tween(container, 0.15, { BackgroundColor3 = theme.SecondaryBackground })
                end
            end)

            updateDisplay()

            if flag then
                if multi then
                    local sel = {}
                    for k, _ in pairs(selectedItems) do table.insert(sel, k) end
                    Page._configData[flag] = sel
                elseif default then
                    Page._configData[flag] = default
                end
            end

            local DropdownObj = { _instance = container }

            function DropdownObj:GetSelected()
                if multi then
                    local sel = {}
                    for k, _ in pairs(selectedItems) do table.insert(sel, k) end
                    return sel
                else
                    for k, _ in pairs(selectedItems) do return k end
                    return nil
                end
            end

            function DropdownObj:SetItems(newItems: {string})
                -- Clear existing
                for _, child in ipairs(itemsContainer:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                items = newItems
                selectedItems = {}
                for i, item in ipairs(newItems) do
                    createItem(item, i)
                end
                expandedHeight = 36 + 4 + (#newItems * 30) + 6
                updateDisplay()
                if isOpen then
                    container.Size = UDim2.new(1, 0, 0, expandedHeight)
                end
            end

            table.insert(self._elements, DropdownObj)
            return DropdownObj
        end

        -------------------------------------------------------------------
        -- TEXTBOX / INPUT
