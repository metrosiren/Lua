        BorderSizePixel = 0,
        ZIndex = 11,
        Parent = topBar,
    })

    -- Title with accent dot
    local titleLabel = Util.Create("TextLabel", {
        Name = "Title",
        Position = UDim2.fromOffset(14, 0),
