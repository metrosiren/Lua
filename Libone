local NotificationHolder = nil

local function ensureNotificationHolder()
    if NotificationHolder and NotificationHolder.Parent then return NotificationHolder end
    local gui = getScreenGui()
    NotificationHolder = Util.Create("Frame", {
        Name = "NotificationHolder",
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -20, 1, -20),
        Size = UDim2.new(0, 320, 1, -40),
        BackgroundTransparency = 1,
        Parent = gui,
        ZIndex = 9999,
    })
    Util.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        Padding = UDim.new(0, 8),
        Parent = NotificationHolder,
    })
    return NotificationHolder
end

function NexusUI:Notify(options: {[string]: any})
    local title     = options.Title or "Notification"
    local message   = options.Message or ""
    local duration  = options.Duration or 4
    local nType     = options.Type or "Info" -- Info, Success, Warning, Error
    local theme     = options.Theme or self._activeTheme or NexusUI.Themes.Dark

    local holder = ensureNotificationHolder()

    local accentColor = theme.Info
    if nType == "Success" then accentColor = theme.Success
    elseif nType == "Warning" then accentColor = theme.Warning
    elseif nType == "Error" then accentColor = theme.Error end

    local icon = Icons.Info
    if nType == "Success" then icon = Icons.Check
    elseif nType == "Warning" then icon = Icons.Warn
    elseif nType == "Error" then icon = Icons.Close end

    local notif = Util.Create("Frame", {
        Name = "Notification",
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = theme.SecondaryBackground,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        BackgroundTransparency = 1,
        Parent = holder,
    })
    Util.Create("UICorner", { CornerRadius = theme.CornerRadius, Parent = notif })
    Util.Create("UIStroke", {
        Color = theme.Border,
        Thickness = 1,
        Transparency = 1,
        Parent = notif,
    })

    -- Accent stripe on the left
    Util.Create("Frame", {
        Name = "AccentStripe",
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = notif,
    })

    -- Content padding
    local content = Util.Create("Frame", {
        Name = "Content",
        Position = UDim2.fromOffset(14, 0),
        Size = UDim2.new(1, -18, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = notif,
    })
    Util.Create("UIPadding", {
        PaddingTop = UDim.new(0, 12),
        PaddingBottom = UDim.new(0, 12),
        PaddingLeft = UDim.new(0, 4),
        PaddingRight = UDim.new(0, 8),
        Parent = content,
    })
    Util.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 4),
        Parent = content,
    })

    -- Icon + Title Row
    local titleRow = Util.Create("Frame", {
        Name = "TitleRow",
        Size = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency = 1,
        LayoutOrder = 1,
        Parent = content,
    })
    Util.Create("TextLabel", {
        Name = "Icon",
        Size = UDim2.fromOffset(18, 18),
        BackgroundTransparency = 1,
        Text = icon,
        TextColor3 = accentColor,
        TextSize = 14,
        Font = theme.FontBold,
        Parent = titleRow,
    })
    Util.Create("TextLabel", {
        Name = "Title",
        Position = UDim2.fromOffset(24, 0),
        Size = UDim2.new(1, -24, 1, 0),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = theme.Text,
        TextSize = 13,
        Font = theme.FontBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = titleRow,
    })

    -- Message
    if message ~= "" then
        Util.Create("TextLabel", {
            Name = "Message",
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Text = message,
            TextColor3 = theme.SubText,
            TextSize = 12,
            Font = theme.Font,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            LayoutOrder = 2,
            Parent = content,
        })
    end

    -- Progress bar
    local progressBg = Util.Create("Frame", {
        Name = "ProgressBg",
        Size = UDim2.new(1, 0, 0, 2),
        BackgroundColor3 = theme.TertiaryBackground,
        BorderSizePixel = 0,
        LayoutOrder = 3,
        Parent = content,
    })
    Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = progressBg })
    local progressFill = Util.Create("Frame", {
        Name = "Fill",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = progressBg,
    })
    Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = progressFill })

    -- Animate in
    Util.Tween(notif, 0.35, { BackgroundTransparency = 0 }, Enum.EasingStyle.Quint)
    Util.Tween(notif:FindFirstChild("UIStroke"), 0.35, { Transparency = 0 })

    -- Progress countdown
    Util.Tween(progressFill, duration, { Size = UDim2.new(0, 0, 1, 0) }, Enum.EasingStyle.Linear)

    -- Animate out
    task.delay(duration, function()
        Util.Tween(notif, 0.4, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quint)
        Util.Tween(notif:FindFirstChild("UIStroke"), 0.3, { Transparency = 1 })
        task.wait(0.45)
        notif:Destroy()
    end)

    return notif
end

