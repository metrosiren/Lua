                    ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
                    ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
                    ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
                    ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
                }),
                Rotation = 90,
                Parent = hueBar,
            })

            -- Hue cursor
            local hueCursor = Util.Create("Frame", {
                Name = "HueCursor",
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0.5, 0, 0, 0),
                Size = UDim2.new(1, 4, 0, 5),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel = 0,
                ZIndex = 8,
                Parent = hueBar,
            })
            Util.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = hueCursor })

            -- RGB inputs
            local rgbRow = Util.Create("Frame", {
                Name = "RGBRow",
                Position = UDim2.new(0, 0, 0, 96),
                Size = UDim2.new(1, 0, 0, 22),
                BackgroundTransparency = 1,
                ZIndex = 6,
                Parent = pickerBody,
            })
            Util.Create("UIListLayout", {
                FillDirection = Enum.FillDirection.Horizontal,
                Padding = UDim.new(0, 4),
                Parent = rgbRow,
            })

            local h, s, v = currentColor:ToHSV()

            local function updateColor(newH, newS, newV)
                h, s, v = newH, newS, newV
                currentColor = Color3.fromHSV(h, s, v)
                colorPreview.BackgroundColor3 = currentColor
                svBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                hueCursor.Position = UDim2.new(0.5, 0, h, 0)
                if flag then
                    Page._configData[flag] = { R = currentColor.R * 255, G = currentColor.G * 255, B = currentColor.B * 255 }
                end
                task.spawn(callback, currentColor)
            end

            -- Create mini RGB input
            local function createMiniInput(label: string, initialValue: number)
                local miniFrame = Util.Create("Frame", {
                    Size = UDim2.new(0.33, -3, 1, 0),
                    BackgroundColor3 = theme.InputBackground,
                    BorderSizePixel = 0,
                    ZIndex = 7,
                    Parent = rgbRow,
                })
                Util.Create("UICorner", { CornerRadius = UDim.new(0, 3), Parent = miniFrame })

                Util.Create("TextLabel", {
                    Position = UDim2.fromOffset(4, 0),
                    Size = UDim2.fromOffset(10, 22),
                    BackgroundTransparency = 1,
                    Text = label,
                    TextColor3 = theme.DimText,
                    TextSize = 9,
                    Font = theme.FontBold,
                    ZIndex = 8,
                    Parent = miniFrame,
                })

                local miniBox = Util.Create("TextBox", {
                    Position = UDim2.fromOffset(16, 0),
                    Size = UDim2.new(1, -20, 1, 0),
                    BackgroundTransparency = 1,
                    Text = tostring(math.floor(initialValue * 255)),
                    TextColor3 = theme.Text,
                    TextSize = 10,
                    Font = theme.Font,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ClearTextOnFocus = true,
                    ZIndex = 8,
                    Parent = miniFrame,
                })

                return miniBox
            end

            local rBox = createMiniInput("R", currentColor.R)
            local gBox = createMiniInput("G", currentColor.G)
            local bBox = createMiniInput("B", currentColor.B)

            local function updateFromRGB()
                local r = math.clamp(tonumber(rBox.Text) or 0, 0, 255) / 255
                local g = math.clamp(tonumber(gBox.Text) or 0, 0, 255) / 255
                local b = math.clamp(tonumber(bBox.Text) or 0, 0, 255) / 255
                local newColor = Color3.new(r, g, b)
                local nh, ns, nv = newColor:ToHSV()
                updateColor(nh, ns, nv)
            end

            rBox.FocusLost:Connect(updateFromRGB)
            gBox.FocusLost:Connect(updateFromRGB)
            bBox.FocusLost:Connect(updateFromRGB)

            -- SV interaction
            local svDragging = false
            local svClickArea = Util.Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 10,
                Parent = svBox,
            })

            svClickArea.MouseButton1Down:Connect(function()
                svDragging = true
            end)

            -- Hue interaction
            local hueDragging = false
            local hueClickArea = Util.Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
                ZIndex = 9,
                Parent = hueBar,
            })

            hueClickArea.MouseButton1Down:Connect(function()
                hueDragging = true
            end)

            UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    if svDragging then
                        local relX = math.clamp((input.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
                        local relY = math.clamp((input.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
                        updateColor(h, relX, 1 - relY)
                        rBox.Text = tostring(math.floor(currentColor.R * 255))
                        gBox.Text = tostring(math.floor(currentColor.G * 255))
                        bBox.Text = tostring(math.floor(currentColor.B * 255))
                    elseif hueDragging then
                        local relY = math.clamp((input.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                        updateColor(relY, s, v)
                        rBox.Text = tostring(math.floor(currentColor.R * 255))
                        gBox.Text = tostring(math.floor(currentColor.G * 255))
                        bBox.Text = tostring(math.floor(currentColor.B * 255))
                    end
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDragging = false
                    hueDragging = false
                end
            end)

            -- Open/Close
            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    Util.Tween(container, 0.3, { Size = UDim2.new(1, 0, 0, 172) }, Enum.EasingStyle.Quint)
                else
                    Util.Tween(container, 0.3, { Size = UDim2.new(1, 0, 0, 36) }, Enum.EasingStyle.Quint)
                end
            end)

            -- Initialize position
            updateColor(h, s, v)

            if flag then
                Page._configData[flag] = { R = currentColor.R * 255, G = currentColor.G * 255, B = currentColor.B * 255 }
            end

            local ColorPickerObj = { _instance = container }

            function ColorPickerObj:GetColor(): Color3
                return currentColor
            end

            function ColorPickerObj:SetColor(newColor: Color3)
                local nh, ns, nv = newColor:ToHSV()
                updateColor(nh, ns, nv)
                rBox.Text = tostring(math.floor(newColor.R * 255))
                gBox.Text = tostring(math.floor(newColor.G * 255))
                bBox.Text = tostring(math.floor(newColor.B * 255))
            end

            table.insert(self._elements, ColorPickerObj)
            return ColorPickerObj
        end

        -------------------------------------------------------------------
