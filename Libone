--  Notification System
-- ══════════════════════════════════════════════════════════════

function NexusUI:Notify(config: {Title: string?, Message: string?, Duration: number?, Type: string?})
    local theme = self._theme
    local duration = config.Duration or self._notifDur
    local notifType = config.Type or "Info"

    local accentColor = theme.Accent
    if notifType == "Success" then accentColor = theme.Success
    elseif notifType == "Warning" then accentColor = theme.Warning
    elseif notifType == "Error" then accentColor = theme.Error end

    local notif = Util.Create("Frame", {
        Name = "Notif",
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = self._notifContainer,
    })
    Util.Corner(notif, 8)
    Util.Stroke(notif, theme.Border, 1, 0.5)
    Util.Shadow(notif, theme.Shadow, 20)

    -- Accent bar on left
    Util.Create("Frame", {
        Name = "AccentBar",
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = notif,
    })

    if config.Title then
        Util.Create("TextLabel", {
            Name = "Title",
            Position = UDim2.new(0, 14, 0, 10),
            Size = UDim2.new(1, -20, 0, 16),
            BackgroundTransparency = 1,
            Text = config.Title,
            TextColor3 = theme.Text,
            TextSize = 13,
            Font = self._titleFont,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = notif,
        })
    end

    if config.Message then
        Util.Create("TextLabel", {
            Name = "Message",
            Position = UDim2.new(0, 14, 0, config.Title and 28 or 10),
            Size = UDim2.new(1, -20, 0, 30),
            BackgroundTransparency = 1,
            Text = config.Message,
            TextColor3 = theme.TextDim,
            TextSize = 12,
            Font = self._font,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            Parent = notif,
        })
    end

    -- Animate in
    local targetH = (config.Title and config.Message) and 65 or 40
    Util.Tween(notif, 0.3, { Size = UDim2.new(1, 0, 0, targetH) }, Enum.EasingStyle.Back)

    -- Auto dismiss
    task.delay(duration, function()
        Util.Tween(notif, 0.25, { Size = UDim2.new(1, 0, 0, 0) })
        task.delay(0.3, function()
            if notif then notif:Destroy() end
        end)
    end)
end

-- ══════════════════════════════════════════════════════════════
--  Modal / Dialog
-- ══════════════════════════════════════════════════════════════

function NexusUI:CreateModal(config: {Title: string?, Message: string?, Buttons: {{Text: string, Callback: (() -> ())?}}?})
    local theme = self._theme

    -- Overlay
    local overlay = Util.Create("Frame", {
        Name = "ModalOverlay",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.new(0, 0, 0),
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        ZIndex = 100,
        Parent = self._screenGui,
    })

    local modal = Util.Create("Frame", {
        Name = "Modal",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 320, 0, 0),
        BackgroundColor3 = theme.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        ZIndex = 101,
        Parent = overlay,
    })
    Util.Corner(modal, 12)
    Util.Shadow(modal, theme.Shadow, 40)

    -- Title
    if config.Title then
        Util.Create("TextLabel", {
            Name = "Title",
            Position = UDim2.new(0, 24, 0, 20),
            Size = UDim2.new(1, -48, 0, 22),
            BackgroundTransparency = 1,
            Text = config.Title,
            TextColor3 = theme.Text,
            TextSize = 16,
            Font = self._titleFont,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 102,
            Parent = modal,
        })
    end

    -- Message
    if config.Message then
        Util.Create("TextLabel", {
            Name = "Message",
            Position = UDim2.new(0, 24, 0, 50),
            Size = UDim2.new(1, -48, 0, 50),
            BackgroundTransparency = 1,
            Text = config.Message,
            TextColor3 = theme.TextDim,
            TextSize = 13,
            Font = self._font,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            TextYAlignment = Enum.TextYAlignment.Top,
            ZIndex = 102,
            Parent = modal,
        })
    end

    -- Buttons
    local buttons = config.Buttons or {{ Text = "OK" }}
    local btnContainer = Util.Create("Frame", {
        Name = "Buttons",
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -20, 1, -16),
        Size = UDim2.new(1, -40, 0, 32),
        BackgroundTransparency = 1,
        ZIndex = 102,
        Parent = modal,
    })
    Util.ListLayout(btnContainer, 8, Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Center)

    for i, btnConfig in ipairs(buttons) do
        local isPrimary = (i == #buttons)
        local btn = Util.Create("TextButton", {
            Name = btnConfig.Text,
            Size = UDim2.new(0, 80, 0, 30),
            BackgroundColor3 = isPrimary and theme.Accent or theme.SurfaceAlt,
            Text = btnConfig.Text,
            TextColor3 = isPrimary and Color3.new(1,1,1) or theme.Text,
            TextSize = 12,
            Font = self._titleFont,
            BorderSizePixel = 0,
            AutoButtonColor = false,
            ZIndex = 103,
            LayoutOrder = i,
            Parent = btnContainer,
        })
        Util.Corner(btn, 6)

        btn.MouseEnter:Connect(function()
            Util.Tween(btn, 0.15, {
                BackgroundColor3 = isPrimary and theme.AccentHover or theme.Border
            })
        end)
        btn.MouseLeave:Connect(function()
            Util.Tween(btn, 0.15, {
                BackgroundColor3 = isPrimary and theme.Accent or theme.SurfaceAlt
            })
        end)

        btn.MouseButton1Click:Connect(function()
            -- Close modal
            Util.Tween(modal, 0.2, { Size = UDim2.new(0, 320, 0, 0) })
            Util.Tween(overlay, 0.2, { BackgroundTransparency = 1 })
            task.delay(0.25, function()
                overlay:Destroy()
            end)
            if btnConfig.Callback then
                task.spawn(btnConfig.Callback)
            end
        end)
    end

    -- Animate in
    overlay.BackgroundTransparency = 1
    Util.Tween(overlay, 0.25, { BackgroundTransparency = 0.5 })
    Util.Tween(modal, 0.3, { Size = UDim2.new(0, 320, 0, 160) }, Enum.EasingStyle.Back)
end

-- ══════════════════════════════════════════════════════════════
--  Cleanup
-- ══════════════════════════════════════════════════════════════

function NexusUI:Destroy()
    -- Animate out
    Util.Tween(self._container, self._animSpeed * 0.6, {
        Size = UDim2.new(0, 0, 0, 0),
    }, Enum.EasingStyle.Back, Enum.EasingDirection.In)

    task.delay(self._animSpeed * 0.7, function()
        -- Disconnect all events
        for _, conn in ipairs(self._connections) do
            if conn and conn.Connected then
                conn:Disconnect()
            end
        end
        self._connections = {}

        -- Remove GUI
        if self._screenGui then
            self._screenGui:Destroy()
        end
    end)
end

