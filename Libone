local Page = {}
Page.__index = Page

function NexusUI:CreatePage(config: PageConfig): any
    local theme = self._theme
    local page = setmetatable({}, Page)
    page._nexus  = self
    page._name   = config.Name
    page._icon   = config.Icon
    page._items  = {}

    -- Tab button in sidebar
    local tabBtn = Util.Create("TextButton", {
        Name = config.Name .. "_Tab",
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        BorderSizePixel = 0,
        LayoutOrder = config.LayoutOrder or #self._pages + 1,
        Parent = self._tabHolder,
    })
    Util.Corner(tabBtn, 6)

    -- Active indicator bar
    local indicator = Util.Create("Frame", {
        Name = "Indicator",
        Position = UDim2.new(0, 0, 0.15, 0),
        Size = UDim2.new(0, 3, 0.7, 0),
        BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = tabBtn,
    })
    Util.Corner(indicator, 2)

    -- Icon
    if config.Icon then
        Util.Create("ImageLabel", {
            Name = "Icon",
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 10, 0.5, 0),
            Size = UDim2.new(0, 16, 0, 16),
            BackgroundTransparency = 1,
            Image = config.Icon,
            ImageColor3 = theme.TextDim,
            Parent = tabBtn,
        })
    end

    local textOffset = config.Icon and 32 or 10
    local tabLabel = Util.Create("TextLabel", {
        Name = "Label",
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, textOffset, 0.5, 0),
        Size = UDim2.new(1, -textOffset - 8, 1, 0),
        BackgroundTransparency = 1,
        Text = config.Name,
        TextColor3 = theme.TextDim,
        TextSize = 13,
        Font = self._font,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
        Parent = tabBtn,
    })

    -- Content scroll frame for this page
    local contentFrame = Util.Create("ScrollingFrame", {
        Name = config.Name .. "_Content",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = theme.Accent,
        ScrollBarImageTransparency = 0.5,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        BorderSizePixel = 0,
        Visible = false,
        Parent = self._contentArea,
    })
    Util.Padding(contentFrame, 12, 12, 14, 14)
    Util.ListLayout(contentFrame, 8)

    page._tabBtn       = tabBtn
    page._indicator    = indicator
    page._tabLabel     = tabLabel
    page._contentFrame = contentFrame

    -- Hover effects
    tabBtn.MouseEnter:Connect(function()
        if self._activePage ~= page then
            Util.Tween(tabBtn, 0.2, { BackgroundTransparency = 0.85 })
            Util.Tween(tabLabel, 0.2, { TextColor3 = theme.Text })
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if self._activePage ~= page then
            Util.Tween(tabBtn, 0.2, { BackgroundTransparency = 1 })
            Util.Tween(tabLabel, 0.2, { TextColor3 = theme.TextDim })
        end
    end)

    -- Click to select
    tabBtn.MouseButton1Click:Connect(function()
        self:_SelectPage(page)
    end)

    table.insert(self._pages, page)

    -- Auto-select first page
    if #self._pages == 1 then
        task.defer(function()
            self:_SelectPage(page)
        end)
    end

    return page
end

function NexusUI:_SelectPage(page)
    local theme = self._theme

    -- Deselect previous
    if self._activePage then
        local prev = self._activePage
        prev._contentFrame.Visible = false
        Util.Tween(prev._tabBtn, 0.25, { BackgroundTransparency = 1 })
        Util.Tween(prev._tabLabel, 0.25, { TextColor3 = theme.TextDim })
        Util.Tween(prev._indicator, 0.25, { BackgroundTransparency = 1 })
    end

    -- Select new
    self._activePage = page
    page._contentFrame.Visible = true
    Util.Tween(page._tabBtn, 0.25, { BackgroundTransparency = 0.88 })
    Util.Tween(page._tabLabel, 0.25, { TextColor3 = theme.Text })
    Util.Tween(page._indicator, 0.25, { BackgroundTransparency = 0 })

    -- Slide-in animation for content
    for _, child in ipairs(page._contentFrame:GetChildren()) do
        if child:IsA("GuiObject") and child.Name ~= "UIListLayout" and child.Name ~= "UIPadding" then
            child.Position = UDim2.new(0.03, 0, child.Position.Y.Scale, child.Position.Y.Offset)
            local originalTransp = child.BackgroundTransparency
            child.BackgroundTransparency = math.min(originalTransp + 0.3, 1)
            task.defer(function()
                Util.Tween(child, 0.3, {
                    Position = UDim2.new(0, 0, child.Position.Y.Scale, child.Position.Y.Offset),
                    BackgroundTransparency = originalTransp,
                })
            end)
        end
    end
end

