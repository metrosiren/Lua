function NexusUI:CreateWindow(options: {[string]: any})
    local windowTitle = options.Title or "NexusUI"
    local windowSize  = options.Size or UDim2.fromOffset(620, 450)
    local theme       = options.Theme or NexusUI.Themes.Dark
    local toggleKey   = options.ToggleKey or Enum.KeyCode.RightControl
    local showClose   = if options.ShowClose ~= nil then options.ShowClose else true
    local showMinimize = if options.ShowMinimize ~= nil then options.ShowMinimize else true
    local accentColor = options.AccentColor -- optional override

    if accentColor then
        theme = Util.DeepCopy(theme)
        theme.Accent = accentColor
        theme.AccentHover = Util.LerpColor(accentColor, Color3.new(1,1,1), 0.15)
        theme.AccentDark = Util.LerpColor(accentColor, Color3.new(0,0,0), 0.15)
        theme.SliderFill = accentColor
        theme.Info = accentColor
        theme.InputFocusBorder = accentColor
    end

    self._activeTheme = theme

    local gui = getScreenGui()

    -- Window object table
    local Window = {
        _theme  = theme,
        _pages  = {},
        _activePage = nil,
        _visible = true,
        _minimized = false,
