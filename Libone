        TextSize = 10,
        Font = theme.FontBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 11,
        Parent = topBar,
    })

    -- Window control buttons
    local controlsFrame = Util.Create("Frame", {
        Name = "Controls",
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -8, 0, 0),
        Size = UDim2.new(0, 80, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 11,
        Parent = topBar,
    })
