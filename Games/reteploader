-- === Notifications Framework ===
local function showNotif(msg)
    local notif = Instance.new("Frame", screen)
    notif.Size = UDim2.new(0, 220, 0, 36)
    notif.Position = UDim2.new(0.5, -110, 1, -65)
    notif.BackgroundColor3 = CONFIG.ColorContainer
    notif.BorderSizePixel = 0
    notif.BackgroundTransparency = 1

    local notifCorner = Instance.new("UICorner", notif)
    notifCorner.CornerRadius = UDim.new(0, 6)

    local ns = Instance.new("UIStroke", notif)
    ns.Color = CONFIG.ColorBorder
    ns.Thickness = 1
    ns.Transparency = 1

    local nl = Instance.new("TextLabel", notif)
    nl.Size = UDim2.new(1, 0, 1, 0)
    nl.BackgroundTransparency = 1
    nl.Text = msg
    nl.TextColor3 = CONFIG.ColorTextMain
    nl.Font = Enum.Font.GothamMedium
    nl.TextSize = 11
    nl.TextTransparency = 1

    TweenService:Create(notif, TWEEN, {BackgroundTransparency = 0}):Play()
    TweenService:Create(ns, TWEEN, {Transparency = 0}):Play()
    TweenService:Create(nl, TWEEN, {TextTransparency = 0}):Play()

    task.delay(2.5, function()
        local tw = TweenService:Create(notif, TWEEN, {BackgroundTransparency = 1})
        TweenService:Create(ns, TWEEN, {Transparency = 1}):Play()
        TweenService:Create(nl, TWEEN, {TextTransparency = 1}):Play()
        tw:Play()
        tw.Completed:Wait()
        notif:Destroy()
    end)
end

