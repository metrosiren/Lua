local ESP_OBJECTS = {}

local function createLine()
    if not Drawing then return nil end
    local line = Drawing.new("Line")
    line.Thickness = 1
    line.Color = Color3.new(1, 1, 1)
    line.Transparency = 1
    return line
end

local SKELETON_CONNECTIONS = {
    {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
    {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
    {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
    {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"},
    {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"}
}

local function setupESP(player)
    if not Drawing then return end
    if player == LocalPlayer then return end

    local Box = Drawing.new("Square")
    Box.Color = Color3.fromRGB(240, 240, 240)
    Box.Thickness = 1
    Box.Filled = false

    local Tracer = Drawing.new("Line")
    Tracer.Color = Color3.fromRGB(200, 200, 200)
    Tracer.Thickness = 1

    local Name = Drawing.new("Text")
    Name.Color = Color3.new(1, 1, 1)
    Name.Size = 13
    Name.Center = true
    Name.Outline = true

    local DistText = Drawing.new("Text")
    DistText.Color = Color3.fromRGB(200, 200, 200)
    DistText.Size = 12
    DistText.Center = true
    DistText.Outline = true
    
    local HealthBarBG = Drawing.new("Line")
    HealthBarBG.Thickness = 2
    HealthBarBG.Color = Color3.fromRGB(15, 15, 15)
    
    local HealthBarFG = Drawing.new("Line")
    HealthBarFG.Thickness = 1
    HealthBarFG.Color = Color3.fromRGB(0, 255, 0)

    local SkeletonLines = {}
    for i = 1, #SKELETON_CONNECTIONS do
        SkeletonLines[i] = createLine()
    end

    ESP_OBJECTS[player] = { Box = Box, Tracer = Tracer, Name = Name, DistText = DistText, HealthBarBG = HealthBarBG, HealthBarFG = HealthBarFG, SkeletonLines = SkeletonLines }

    local function espLoop()
        local obj = ESP_OBJECTS[player]
        if not obj then return end
        
        local isAlv = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
        local isEnemy = not STATE.ESPTeamCheck or player.Team ~= LocalPlayer.Team
        local isActive = STATE.ESP and STATE.Master and isEnemy

        if isAlv and isActive then
            local hrp = player.Character.HumanoidRootPart
            local head = player.Character:FindFirstChild("Head")
            local hum = player.Character.Humanoid
            
            local hrpPos, onScreen, depth = worldToScreen(hrp.Position)
            local dist = getDistance(player)
            
            if onScreen and depth > 0 and dist <= STATE.ESPMaxDistance then
                local headScreen = head and worldToScreen(head.Position + Vector3.new(0, 1, 0)) or worldToScreen(hrp.Position + Vector3.new(0, 3, 0))
                local footScreen = worldToScreen(hrp.Position - Vector3.new(0, 3.5, 0))
                
                local height = math.abs(headScreen.Y - footScreen.Y)
                local width = height / 2

                if STATE.ESPBox then
                    Box.Size = Vector2.new(width, height)
                    Box.Position = Vector2.new(hrpPos.X - width / 2, headScreen.Y)
                    Box.Visible = true
                else
                    Box.Visible = false
                end

                if STATE.ESPTracer then
                    Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    Tracer.To = Vector2.new(hrpPos.X, footScreen.Y)
                    Tracer.Visible = true
                else
                    Tracer.Visible = false
                end

                if STATE.ESPName then
                    Name.Text = player.DisplayName
                    Name.Position = Vector2.new(hrpPos.X, headScreen.Y - 18)
                    Name.Visible = true
                else
                    Name.Visible = false
                end
                
                if STATE.ESPDistance then
                    DistText.Text = string.format("[%dm]", math.floor(dist))
                    DistText.Position = Vector2.new(hrpPos.X, footScreen.Y + 2)
                    DistText.Visible = true
                else
                    DistText.Visible = false
                end
                
                if STATE.ESPHealthBar then
                    local ratio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    local barX = hrpPos.X - width / 2 - 5
                    HealthBarBG.From = Vector2.new(barX, headScreen.Y)
                    HealthBarBG.To = Vector2.new(barX, footScreen.Y)
                    HealthBarBG.Visible = true
                    
                    local fillY = footScreen.Y - (height * ratio)
                    HealthBarFG.From = Vector2.new(barX, footScreen.Y)
                    HealthBarFG.To = Vector2.new(barX, fillY)
                    HealthBarFG.Color = Color3.fromRGB(255 * (1 - ratio), 255 * ratio, 0)
                    HealthBarFG.Visible = true
                else
                    HealthBarBG.Visible = false
                    HealthBarFG.Visible = false
                end

                if STATE.ESPSkeleton then
                    for i, conn in ipairs(SKELETON_CONNECTIONS) do
                        local part1 = player.Character:FindFirstChild(conn[1])
                        local part2 = player.Character:FindFirstChild(conn[2])
                        local line = SkeletonLines[i]
                        
                        if part1 and part2 then
                            local p1C, on1 = worldToScreen(part1.Position)
                            local p2C, on2 = worldToScreen(part2.Position)
                            if on1 or on2 then
                                line.From = Vector2.new(p1C.X, p1C.Y)
                                line.To = Vector2.new(p2C.X, p2C.Y)
                                line.Visible = true
                            else
                                line.Visible = false
                            end
                        else
                            line.Visible = false
                        end
                    end
                else
                    for _, line in ipairs(SkeletonLines) do line.Visible = false end
                end
            else
                Box.Visible = false
                Tracer.Visible = false
                Name.Visible = false
                DistText.Visible = false
                HealthBarBG.Visible = false
                HealthBarFG.Visible = false
                for _, line in ipairs(SkeletonLines) do line.Visible = false end
            end
        else
            Box.Visible = false
            Tracer.Visible = false
            Name.Visible = false
            DistText.Visible = false
            HealthBarBG.Visible = false
            HealthBarFG.Visible = false
            for _, line in ipairs(SkeletonLines) do line.Visible = false end
        end
    end

    local con
    con = RunService.RenderStepped:Connect(function()
        if not ESP_OBJECTS[player] then
            con:Disconnect()
            return
        end
        espLoop()
    end)
end

local function removeESP(player)
    if ESP_OBJECTS[player] then
        for k, v in pairs(ESP_OBJECTS[player]) do
            if type(v) == "table" then
                for _, l in ipairs(v) do l:Remove() end
            else
                v:Remove()
            end
        end
        ESP_OBJECTS[player] = nil
    end
end

for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then setupESP(p) end
end
Players.PlayerAdded:Connect(setupESP)
Players.PlayerRemoving:Connect(removeESP)


