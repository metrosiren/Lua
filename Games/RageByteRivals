local function selectTab(idx)
    currentTabIdx = idx
    for i, p in pairs(tabPages) do 
        p.Visible = (i == idx)
        if i == idx then p.CanvasPosition = Vector2.new(0, 0) end
    end
    for i, b in pairs(tabButtons) do
        local isSelected = (i == idx)
        
        TweenService:Create(b.btn, TWEEN_INFO, {
            BackgroundColor3 = isSelected and Color3.fromRGB(22, 22, 26) or UI_SECTION,
            BackgroundTransparency = isSelected and 0 or 1
        }):Play()

        TweenService:Create(b.btn, TWEEN_INFO, {
            TextColor3 = isSelected and UI_TEXT or UI_TEXT_MUTED
        }):Play()

        TweenService:Create(b.indicator, TWEEN_INFO, {
            BackgroundTransparency = isSelected and 0 or 1
        }):Play()
    end
end

