--// Aim Key Input
local function isAimKeyInput(input)
	if typeof(Settings.AimKey) == "EnumItem" then
		return input.UserInputType == Settings.AimKey or input.KeyCode == Settings.AimKey
	end
	return false
end

UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if not isAimKeyInput(input) then return end
	if Settings.AimMode == "Toggle" then
		Settings.AimActive = not Settings.AimActive
	else
		Settings.AimActive = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if not isAimKeyInput(input) then return end
	if Settings.AimMode == "Hold" then
		Settings.AimActive = false
	end
end)

--// Triggerbot
local lastTrigger = 0
local function tryTriggerbot()
	if not Settings.Triggerbot then return end
	local now = tick() * 1000
	if now - lastTrigger < Settings.TriggerbotDelay then return end

	local target = getClosestPlayer()
	if not target then return end
	local char = getCharacter(target)
	if not char then return end
	local part = char:FindFirstChild(Settings.AimPart) or char:FindFirstChild("Head")
	if not part then return end

	local screenPos, onScreen = worldToScreen(part.Position)
	if not onScreen then return end
	local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	if (screenPos - center).Magnitude < 15 then
		mouse1click()
		lastTrigger = now
	end
end

--// WalkSpeed / JumpPower Override
local function hookHumanoid(hum)
	hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
		if hum.WalkSpeed ~= Settings.WalkSpeed then
			hum.WalkSpeed = Settings.WalkSpeed
		end
	end)
	hum:GetPropertyChangedSignal("JumpPower"):Connect(function()
		if hum.JumpPower ~= Settings.JumpPower then
			hum.JumpPower = Settings.JumpPower
		end
	end)
	hum.WalkSpeed = Settings.WalkSpeed
	hum.JumpPower = Settings.JumpPower
end

LocalPlayer.CharacterAdded:Connect(function(char)
	local hum = char:WaitForChild("Humanoid", 10)
	if hum then hookHumanoid(hum) end
end)

if LocalPlayer.Character then
	local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if hum then hookHumanoid(hum) end
end

