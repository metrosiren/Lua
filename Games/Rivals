--// Anti-FOV: stay behind nearest enemy, face them, avoid hazards
local hazardCache = {}
local lastHazardScan = 0

local function refreshHazardCache()
	local now = tick()
	if now - lastHazardScan < 1 then return end -- refresh once per second
	lastHazardScan = now
	table.clear(hazardCache)
	for _, obj in Workspace:GetDescendants() do
		if obj:IsA("BasePart") then
			local n = obj.Name:lower()
			if string.find(n, "molotov") or string.find(n, "fire") or string.find(n, "flame") or string.find(n, "burn") or string.find(n, "lava") then
				table.insert(hazardCache, obj)
			end
		end
	end
end

local function isHazardNearby(pos, radius)
	for _, obj in hazardCache do
		if obj.Parent and (obj.Position - pos).Magnitude < radius then
			return true
		end
	end
	return false
end

local function getAntiFOVPosition()
	local localChar = LocalPlayer.Character
	if not localChar then return nil end
	local localRoot = localChar:FindFirstChild("HumanoidRootPart")
	if not localRoot then return nil end

	refreshHazardCache()

	local closest, closestDist = nil, math.huge
	for _, player in Players:GetPlayers() do
		if player == LocalPlayer then continue end
		if not isAlive(player) then continue end
		local char = getCharacter(player)
		if not char then continue end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then continue end
		local d = (root.Position - localRoot.Position).Magnitude
		if d < closestDist then
			closest = root
			closestDist = d
		end
	end

	if not closest then return nil end
	if Settings.AntiFOVMaxDistance > 0 and closestDist > Settings.AntiFOVMaxDistance then return nil end

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {localChar, closest.Parent}

	local dist = Settings.AntiFOVDistance
	local angles = {0, 30, -30, 60, -60, 90, -90, 120, -120, 150, -150, 180}
	local elevate = 6 -- studs above enemy head

	for _, angle in angles do
		local rad = math.rad(angle)
		local behindDir = -closest.CFrame.LookVector
		local flat = Vector3.new(behindDir.X, 0, behindDir.Z)
		if flat.Magnitude < 0.01 then flat = Vector3.new(0, 0, -1) end
		flat = flat.Unit
		local rotated = (CFrame.Angles(0, rad, 0) * flat)
		local targetPos = closest.Position + rotated * dist + Vector3.new(0, elevate, 0)

		-- Wall check from enemy to target
		local dir = targetPos - closest.Position
		local ray = Workspace:Raycast(closest.Position, dir, params)
		if ray and (ray.Position - closest.Position).Magnitude < dir.Magnitude * 0.8 then
			continue -- too close to wall, skip this angle
		end

		-- Hazard check
		if isHazardNearby(targetPos, 10) then continue end

		-- Face the enemy
		local lookAt = Vector3.new(closest.Position.X, targetPos.Y, closest.Position.Z)
		return CFrame.new(targetPos, lookAt)
	end

	return nil
end

--// Main Loop
RunService.RenderStepped:Connect(function()
	Camera = Workspace.CurrentCamera

	-- Anti-FOV (only in match)
	if Settings.AntiFOV and isInMatch() then
		local cf = getAntiFOVPosition()
		if cf then
			local localChar = LocalPlayer.Character
			local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
			if localRoot then
				localRoot.CFrame = cf
				local enemy = getNearestEnemyRoot()
				if enemy then
					lookAtTarget(enemy.Position)
				end
			end
		end
	end

	-- Autofarm (only in match)
	if Settings.Autofarm and isInMatch() then
		local localChar = LocalPlayer.Character
		local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
		if localRoot then
			-- Find lowest health ALIVE enemy within max distance
			local enemy = nil
			local lowestHP = math.huge
			for _, player in Players:GetPlayers() do
				if player == LocalPlayer then continue end
				if not isAlive(player) then continue end
				local char = getCharacter(player)
				if not char then continue end
				local root = char:FindFirstChild("HumanoidRootPart")
				if not root then continue end
				local hum = char:FindFirstChildOfClass("Humanoid")
				if not hum then continue end
				local d = (root.Position - localRoot.Position).Magnitude
				if Settings.AutofarmMaxDistance > 0 and d > Settings.AutofarmMaxDistance then continue end
				if hum.Health < lowestHP then
					enemy = root
					lowestHP = hum.Health
				end
			end

			if enemy then
				-- Hover high above the enemy
				local hoverHeight = 50
				local targetPos = enemy.Position + Vector3.new(0, hoverHeight, 0)
				local dir = (targetPos - localRoot.Position)
				if dir.Magnitude > 2 then
					local step = dir.Unit * math.min(dir.Magnitude, Settings.AutofarmSpeed / 60)
					localRoot.CFrame = CFrame.new(localRoot.Position + step)
				else
					localRoot.CFrame = CFrame.new(targetPos)
				end
				lookAtTarget(enemy.Position)
			end
		end
	end

	-- FOV Circle
	FOVCircle.Radius = Settings.AimFOV
	FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	FOVCircle.Visible = Settings.Aimbot

	-- Aimbot (only in match)
	if Settings.Aimbot and Settings.AimActive and isInMatch() then
		local target = getClosestPlayer()
		if target then
			aimAt(target)
		end
	end

	-- Triggerbot
	tryTriggerbot()

