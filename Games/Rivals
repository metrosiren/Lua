--// Aimbot
local function getClosestPlayer()
	local closest, closestDist = nil, Settings.AimFOV
	local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

	for _, player in Players:GetPlayers() do
		if player == LocalPlayer then continue end
		if not isAlive(player) then continue end
		local char = getCharacter(player)
		if not char then continue end
		local part = char:FindFirstChild(Settings.AimPart) or char:FindFirstChild("Head")
		if not part then continue end

		local screenPos, onScreen = worldToScreen(part.Position)
		if not onScreen then continue end
		if Settings.AimVisibleOnly and not isVisible(part) then continue end
		if Settings.AimMaxDistance > 0 and getDistance(player) > Settings.AimMaxDistance then continue end

		local dist = (screenPos - center).Magnitude
		if dist < closestDist then
			closest = player
			closestDist = dist
		end
	end

	return closest
end

local function aimAt(target)
	local char = getCharacter(target)
	if not char then return end
	local part = char:FindFirstChild(Settings.AimPart) or char:FindFirstChild("Head")
	if not part then return end

	local screenPos, onScreen = worldToScreen(part.Position)
	if not onScreen then return end

	local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local delta = screenPos - center

	local smooth = math.clamp(Settings.AimSmoothness, 1, 20)
	local move = delta / smooth

	if Settings.AimHumanize then
		move = move + Vector2.new(math.random(-2, 2), math.random(-2, 2))
	end

	mousemoverel(math.floor(move.X), math.floor(move.Y))
end

--// ESP Functions
local function createESP(player)
	if ESPObjects[player] then return end

	local obj = {
		Highlight = Instance.new("Highlight"),
		NameText = Drawing.new("Text"),
		DistText = Drawing.new("Text"),
		BoxLines = {},
		SkeletonLines = {},
		HealthBarBG = Drawing.new("Line"),
		HealthBarFG = Drawing.new("Line"),
	}

	obj.Highlight.FillTransparency = Settings.ESPFillOpacity
	obj.Highlight.OutlineColor = Settings.ESPColor
	obj.Highlight.OutlineTransparency = Settings.ESPOutlineOpacity
	obj.Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	obj.Highlight.Enabled = false

	obj.NameText.Size = Settings.ESPTextSize
	obj.NameText.Center = true
	obj.NameText.Outline = true
	obj.NameText.Color = Color3.new(1, 1, 1)
	obj.NameText.Visible = false
	obj.NameText.Text = player.DisplayName

	obj.DistText.Size = Settings.ESPTextSize - 2
	obj.DistText.Center = true
	obj.DistText.Outline = true
	obj.DistText.Color = Color3.fromRGB(200, 200, 200)
	obj.DistText.Visible = false

	obj.HealthBarBG.Thickness = 3
	obj.HealthBarBG.Color = Color3.fromRGB(30, 30, 30)
	obj.HealthBarBG.Visible = false

	obj.HealthBarFG.Thickness = 1
	obj.HealthBarFG.Color = Color3.fromRGB(0, 255, 0)
	obj.HealthBarFG.Visible = false

	for i = 1, 4 do
		local line = Drawing.new("Line")
		line.Thickness = Settings.ESPBoxThickness
		line.Color = Settings.ESPColor
		line.Visible = false
		obj.BoxLines[i] = line
	end

	for i = 1, #SkeletonJoints do
		local line = Drawing.new("Line")
		line.Thickness = Settings.ESPSkeletonThickness
		line.Color = Settings.ESPColor
		line.Visible = false
		obj.SkeletonLines[i] = line
	end

	ESPObjects[player] = obj
end

local function removeESP(player)
	local obj = ESPObjects[player]
	if not obj then return end

	obj.Highlight:Destroy()
	obj.NameText:Remove()
	obj.DistText:Remove()
	obj.HealthBarBG:Remove()
	obj.HealthBarFG:Remove()
	for _, l in obj.BoxLines do l:Remove() end
	for _, l in obj.SkeletonLines do l:Remove() end
	ESPObjects[player] = nil
end

local function hideAllESP(obj)
	obj.Highlight.Enabled = false
	obj.NameText.Visible = false
	obj.DistText.Visible = false
	obj.HealthBarBG.Visible = false
	obj.HealthBarFG.Visible = false
	for _, l in obj.BoxLines do l.Visible = false end
	for _, l in obj.SkeletonLines do l.Visible = false end
end

local function getHealthColor(ratio)
	return Color3.fromRGB(
		math.floor(255 * math.clamp(1 - ratio, 0, 1)),
		math.floor(255 * math.clamp(ratio, 0, 1)),
		0
	)
end

local function updateESP(player)
	local obj = ESPObjects[player]
	if not obj then return end

	local char = getCharacter(player)
	local alive = char and isAlive(player)
	local root = alive and char:FindFirstChild("HumanoidRootPart")
	local head = alive and char:FindFirstChild("Head")
	local hum = alive and char:FindFirstChildOfClass("Humanoid")

	if not alive or not root then
		hideAllESP(obj)
		return
	end

	local dist = getDistance(player)

	if Settings.ESPMaxDistance > 0 and dist > Settings.ESPMaxDistance then
		hideAllESP(obj)
		return
	end

	if Settings.ESPVisibleOnly and not isVisible(root) then
		hideAllESP(obj)
		return
	end

	local rootScreen, onScreen, depth = worldToScreen(root.Position)
	if not onScreen or depth < 0 then
		hideAllESP(obj)
		return
	end

	-- Bounding dimensions (reused by box, health bar, name, distance)
	local headScreen = head and worldToScreen(head.Position + Vector3.new(0, 1, 0)) or rootScreen
	local footScreen = worldToScreen(root.Position - Vector3.new(0, 3, 0))
	local height = math.abs(headScreen.Y - footScreen.Y)
	local width = height / 2

	-- Highlight
	if Settings.ESP then
		obj.Highlight.Adornee = char
		obj.Highlight.Enabled = true
		obj.Highlight.OutlineColor = Settings.ESPColor
		obj.Highlight.FillTransparency = Settings.ESPFillOpacity
		obj.Highlight.OutlineTransparency = Settings.ESPOutlineOpacity
	else
		obj.Highlight.Enabled = false
	end

	-- Box ESP
	if Settings.ESPBox then
		local topLeft = Vector2.new(rootScreen.X - width / 2, headScreen.Y)
		local topRight = Vector2.new(rootScreen.X + width / 2, headScreen.Y)
		local botLeft = Vector2.new(rootScreen.X - width / 2, footScreen.Y)
		local botRight = Vector2.new(rootScreen.X + width / 2, footScreen.Y)

		obj.BoxLines[1].From = topLeft; obj.BoxLines[1].To = topRight
		obj.BoxLines[2].From = topRight; obj.BoxLines[2].To = botRight
		obj.BoxLines[3].From = botRight; obj.BoxLines[3].To = botLeft
		obj.BoxLines[4].From = botLeft; obj.BoxLines[4].To = topLeft

		for _, l in obj.BoxLines do
			l.Color = Settings.ESPColor
			l.Thickness = Settings.ESPBoxThickness
			l.Visible = true
		end
	else
		for _, l in obj.BoxLines do l.Visible = false end
	end

	-- Health Bar (left side of box)
	if Settings.ESPHealthBar and hum then
		local ratio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
		local barX = rootScreen.X - width / 2 - 5
		local barTop = headScreen.Y
		local barBot = footScreen.Y
		local barFilledBot = barBot - (barBot - barTop) * ratio

		obj.HealthBarBG.From = Vector2.new(barX, barTop)
		obj.HealthBarBG.To = Vector2.new(barX, barBot)
		obj.HealthBarBG.Visible = true

		obj.HealthBarFG.From = Vector2.new(barX, barFilledBot)
		obj.HealthBarFG.To = Vector2.new(barX, barBot)
		obj.HealthBarFG.Color = getHealthColor(ratio)
		obj.HealthBarFG.Visible = true
	else
		obj.HealthBarBG.Visible = false
		obj.HealthBarFG.Visible = false
	end

	-- Name ESP
	if Settings.ESPName then
		local nameY = headScreen.Y - Settings.ESPTextSize - 2
		obj.NameText.Text = player.DisplayName
		obj.NameText.Position = Vector2.new(rootScreen.X, nameY)
		obj.NameText.Size = Settings.ESPTextSize
		obj.NameText.Visible = true
	else
		obj.NameText.Visible = false
	end

	-- Distance ESP
	if Settings.ESPDistance then
		obj.DistText.Text = string.format("%dm", math.floor(dist))
		obj.DistText.Position = Vector2.new(rootScreen.X, footScreen.Y + 2)
		obj.DistText.Size = Settings.ESPTextSize - 2
		obj.DistText.Visible = true
	else
		obj.DistText.Visible = false
	end

	-- Skeleton ESP
	if Settings.ESPSkeleton then
		for i, joint in SkeletonJoints do
			local partA = char:FindFirstChild(joint[1])
			local partB = char:FindFirstChild(joint[2])
			if partA and partB then
				local sA, onA = worldToScreen(partA.Position)
				local sB, onB = worldToScreen(partB.Position)
				if onA and onB then
					obj.SkeletonLines[i].From = sA
					obj.SkeletonLines[i].To = sB
					obj.SkeletonLines[i].Color = Settings.ESPColor
					obj.SkeletonLines[i].Thickness = Settings.ESPSkeletonThickness
					obj.SkeletonLines[i].Visible = true
				else
					obj.SkeletonLines[i].Visible = false
				end
			else
				obj.SkeletonLines[i].Visible = false
			end
		end
	else
		for _, l in obj.SkeletonLines do l.Visible = false end
	end
end

