--// Utility
local function getCharacter(player)
	-- Rivals spawns entities under Assets.Temp.Entities or default character
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		return char
	end
	-- Check entities folder
	local entities = Workspace:FindFirstChild("Assets")
		and Workspace.Assets:FindFirstChild("Temp")
		and Workspace.Assets.Temp:FindFirstChild("Entities")
	if entities then
		for _, ent in entities:GetChildren() do
			if ent.Name == player.Name and ent:FindFirstChild("HumanoidRootPart") then
				return ent
			end
		end
	end
	return char
end

local function isAlive(player)
	local char = getCharacter(player)
	if not char then return false end
	local hum = char:FindFirstChildOfClass("Humanoid")
	return hum and hum.Health > 0
end

local function worldToScreen(pos)
	local vec, onScreen = Camera:WorldToViewportPoint(pos)
	return Vector2.new(vec.X, vec.Y), onScreen, vec.Z
end

local function isVisible(part)
	local origin = Camera.CFrame.Position
	local dir = (part.Position - origin)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	local localChar = LocalPlayer.Character
	params.FilterDescendantsInstances = localChar and {localChar} or {}
	local result = Workspace:Raycast(origin, dir, params)
	if not result then return true end
	return result.Instance:IsDescendantOf(part.Parent)
end

local function getDistance(player)
	local char = getCharacter(player)
	if not char then return math.huge end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return math.huge end
	local localChar = LocalPlayer.Character
	if not localChar or not localChar:FindFirstChild("HumanoidRootPart") then return math.huge end
	return (root.Position - localChar.HumanoidRootPart.Position).Magnitude
end

--// In-Match Detection
local LOBBY_Y = -600 -- lobby is deep underground (~-635)

local function isInMatch()
	local char = LocalPlayer.Character
	if not char then return false end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return false end
	-- In lobby, Y is around -635. In match, maps are above ground.
	if root.Position.Y < LOBBY_Y then return false end
	-- Also check if fighter HUD elements are active
	local pg = LocalPlayer:FindFirstChild("PlayerGui")
	if pg then
		for _, gui in pg:GetChildren() do
			if gui:IsA("ScreenGui") then
				local scoreboard = gui:FindFirstChild("Scoreboard", true)
				local timer = gui:FindFirstChild("Timer", true)
				if scoreboard or timer then
					if (scoreboard and scoreboard.Visible) or (timer and timer.Visible) then
						return true
					end
				end
			end
		end
	end
	-- Fallback: above lobby Y = probably in match
	return root.Position.Y > LOBBY_Y
end

--// Look at target using mousemoverel (shared by anti-fov & autofarm)
local function lookAtTarget(targetPos)
	local screenPos, onScreen = worldToScreen(targetPos)
	if not onScreen then return end
	local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local delta = screenPos - center
	mousemoverel(math.floor(delta.X / 2), math.floor(delta.Y / 2))
end

local function getNearestEnemyRoot()
	local localChar = LocalPlayer.Character
	if not localChar then return nil end
	local localRoot = localChar:FindFirstChild("HumanoidRootPart")
	if not localRoot then return nil end
	local closest, closestDist = nil, math.huge
	for _, player in Players:GetPlayers() do
		if player == LocalPlayer then continue end
		if not isAlive(player) then continue end
		local char = getCharacter(player)
		if not char then continue end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then continue end
		local d = (root.Position - localRoot.Position).Magnitude
		if d < closestDist then
			closest = root
			closestDist = d
		end
	end
	return closest
end

